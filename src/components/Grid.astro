---
interface Props {
	variant?: 'offset' | 'small' | 'projects';
}

const { variant } = Astro.props;
---

<ul class:list={['grid', { offset: variant === 'offset', small: variant === 'small', projects: variant === 'projects' }]}>
	<slot />
</ul>

<style>
	.grid {
		display: grid;
		gap: 1.25rem;
		list-style: none;
		padding: 0;
		grid-template-columns: 1fr;
	}

	@media (min-width: 40em) {
		.grid {
			grid-template-columns: repeat(2, 1fr);
			gap: 1.5rem;
		}
	}

	@media (min-width: 60em) {
		.grid {
			grid-template-columns: repeat(2, 1fr);
			gap: 2.5rem;
		}

		.grid.projects {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (min-width: 90em) {
		.grid {
			grid-template-columns: repeat(3, 1fr);
			gap: 3rem;
		}

		.grid.projects {
			grid-template-columns: repeat(3, 1fr);
		}
	}

	.grid.small {
		grid-template-columns: 1fr;
		gap: 1rem;
	}

	@media (min-width: 30em) {
		.grid.small {
			grid-template-columns: 1fr 1fr;
			gap: 1.25rem;
		}
	}

	@media (min-width: 50em) {
		.grid.small {
			grid-template-columns: repeat(3, 1fr);
			gap: 1.5rem;
		}
	}

	@media (min-width: 64em) {
		.grid.small {
			gap: 2rem;
		}
	}

	/* If last row contains only one item, make it span all columns. */
	.grid.small > :global(:last-child:nth-child(odd)) {
		grid-column: 1 / -1;
	}
</style>
