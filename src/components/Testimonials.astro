---
import Icon from './Icon.astro';
---

<section id="testimonials" class="section testimonials">
	<div class="testimonials-bg"></div>
	<div class="section-shell stack gap-12 lg:gap-20">
		<header class="section-header stack gap-4 centered">
			<div class="badge-accent mx-auto">Témoignages</div>
			<h2>Avis clients</h2>
			<p class="max-w-2xl mx-auto">La réussite de vos projets est ma meilleure récompense. Voici quelques retours d'expérience.</p>
		</header>

		<div class="gallery">
			<div class="recovery-message">
				<Icon icon="chat-circle-dots" size="3rem" gradient />
				<p>Avis en cours de récupération, ça arrive :) ...</p>
			</div>
		</div>
	</div>
</section>

<style>
	.badge-accent {
		display: inline-block;
		padding: 0.4rem 1.25rem;
		background: var(--accent-subtle-overlay);
		color: var(--accent-regular);
		border-radius: var(--radius-full);
		font-size: var(--text-xs);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		margin-top: 1.5rem;
		margin-bottom: 0.75rem;
	}

	.testimonials {
		padding: 4rem 0;
		position: relative;
		overflow: hidden;
	}

	@media (min-width: 50em) {
		.testimonials {
			padding: 6rem 0;
		}
	}

	.testimonials-bg {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background: radial-gradient(circle at 20% 50%, var(--accent-overlay) 0%, transparent 40%),
		            radial-gradient(circle at 80% 80%, var(--accent-overlay) 0%, transparent 40%);
		z-index: -1;
		opacity: 0.5;
	}

	.recovery-message {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 1.5rem;
		padding: 4rem 2rem;
		background: var(--gray-999_40);
		border: 1px solid var(--gray-800);
		border-radius: 1.5rem;
		text-align: center;
		color: var(--gray-200);
		font-style: italic;
		font-size: var(--text-lg);
		backdrop-filter: blur(10px);
		animation: pulse 2s infinite ease-in-out;
	}

	@keyframes pulse {
		0% { opacity: 0.7; transform: scale(0.98); }
		50% { opacity: 1; transform: scale(1); }
		100% { opacity: 0.7; transform: scale(0.98); }
	}

	@media (min-width: 50em) {
		.recovery-message {
			padding: 6rem 3rem;
		}
	}

	.section-header {
		margin-bottom: 0;
	}

	.centered {
		text-align: center;
		margin-inline: auto;
	}

	.mx-auto {
		margin-inline: auto;
	}

	.max-w-2xl {
		max-width: 65ch;
	}
</style>
