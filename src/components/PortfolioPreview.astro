---
import type { CollectionEntry } from 'astro:content';
import Icon from './Icon.astro';

interface Props {
	project: CollectionEntry<'work'>;
}

const { data, id } = Astro.props.project;
---

<div 
	class="card" 
	data-project-id={id}
	data-project-data={JSON.stringify({
		title: data.title,
		img: data.img,
		status: data.status === 'finish' ? 'Projet terminé' : 'En cours',
		tags: data.tags,
		description: data.description,
		highlights: data.highlights,
		stack: data.stack,
		gallery: data.gallery,
		services: data.services,
		client: data.client,
		year: data.year,
		href: data.href,
		slug: id
	})}
	role="button"
	tabindex="0"
>
	<span class="card-image-container">
		<img src={data.img} alt={data.img_alt || ''} loading="lazy" decoding="async" width="480" height="340" />
		<span class="card-overlay">
			<span class="tags-container">
				{data.tags.some(tag => tag.toLowerCase().includes('seo') || tag.toLowerCase().includes('visibilité')) && (
					<span class="tag tag-seo">
						<Icon icon="strategy" size="1.2em" />
						SEO & Visibilité
					</span>
				)}
				{data.tags.filter(tag => !tag.toLowerCase().includes('seo') && !tag.toLowerCase().includes('visibilité')).slice(0, 2).map((tag) => (
					<span class="tag">{tag}</span>
				))}
			</span>
			<span class="details">
				<span class="details-content">
					<span class="category">{data.status === 'in_progress' ? 'En cours' : (data.status === 'finish' ? 'Projet terminé' : '')}</span>
					<span class="title">{data.title}</span>
				</span>
				<span class="open-icon">
					<Icon icon="plus" size="1.2rem" />
				</span>
			</span>
		</span>
	</span>
</div>

<script>
	const cards = document.querySelectorAll('.card[data-project-id]');
	const modal = document.getElementById('project-modal') as HTMLDialogElement;

	cards.forEach(card => {
		card.addEventListener('click', () => {
			const data = JSON.parse(card.getAttribute('data-project-data') || '{}');
			
			if (modal) {
				const modalImage = modal.querySelector('.modal-image') as HTMLImageElement;
				const modalTitle = modal.querySelector('.modal-title');
				const modalStatus = modal.querySelector('.modal-status');
				const modalDescription = modal.querySelector('.modal-description');
				const modalTags = modal.querySelector('.modal-tags');
				const modalStack = modal.querySelector('.modal-stack-list');
				const modalResult = modal.querySelector('.modal-result');
				const modalSolution = modal.querySelector('.modal-solution-content');
				const modalGallery = modal.querySelector('.modal-gallery-grid');
				const modalLink = modal.querySelector('.modal-project-link') as HTMLAnchorElement;

				if (modalImage) modalImage.src = data.img;
				if (modalTitle) modalTitle.textContent = data.title;
				if (modalStatus) modalStatus.textContent = data.status;
				if (modalDescription) modalDescription.textContent = data.description;
				
				if (modalTags) {
					modalTags.innerHTML = data.tags.map((tag: string) => `<span class="tag">${tag}</span>`).join('');
				}

				if (modalStack && data.stack) {
					modalStack.innerHTML = data.stack.map((item: string) => `<span class="tag">${item}</span>`).join('');
				} else if (modalStack) {
					modalStack.innerHTML = data.tags.map((tag: string) => `<span class="tag">${tag}</span>`).join('');
				}

				if (modalResult && data.highlights) {
					modalResult.innerHTML = `<ul class="highlights-list">${data.highlights.map((h: string) => `<li>${h}</li>`).join('')}</ul>`;
				} else if (modalResult) {
					modalResult.textContent = "Projet livré avec succès, répondant à toutes les attentes techniques et fonctionnelles.";
				}

				if (modalSolution && data.services) {
					modalSolution.innerHTML = `<ul class="services-list">${data.services.map((s: string) => `<li>${s}</li>`).join('')}</ul>`;
				} else if (modalSolution) {
					modalSolution.innerHTML = "<p>Mise en place d'une architecture robuste et évolutive, optimisée pour la performance et l'expérience utilisateur.</p>";
				}

				if (modalGallery && data.gallery) {
					modalGallery.innerHTML = data.gallery.slice(0, 3).map((img: any) => {
						const imgSrc = typeof img === 'string' ? img : img.src;
						return `
							<div class="gallery-item">
								<img src="${imgSrc}" alt="Capture d'écran du projet" loading="lazy" />
							</div>
						`;
					}).join('');
				} else if (modalGallery) {
					modalGallery.innerHTML = '';
				}

				if (modalLink) {
					modalLink.href = `/work/${data.slug}`;
					modalLink.style.display = 'flex';
				}

				modal.showModal();
			}
		});

		card.addEventListener('keydown', (e) => {
			if ((e as KeyboardEvent).key === 'Enter' || (e as KeyboardEvent).key === ' ') {
				e.preventDefault();
				(card as HTMLElement).click();
			}
		});
	});
</script>

<style>
	.card {
		display: flex;
		flex-direction: column;
		width: 100%;
		padding: 0;
		cursor: pointer;
		text-align: left;
		border-radius: var(--radius-md);
		overflow: hidden;
		background: var(--gray-999);
		box-shadow: var(--shadow-sm);
		transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275), 
					box-shadow 0.4s ease,
					border-color 0.4s ease;
		position: relative;
		border: 1px solid var(--gray-800);
		user-select: none;
	}

	.card:focus-visible {
		outline: 3px solid var(--accent-regular);
		outline-offset: 4px;
	}

	:global(.grid-projets) .card {
		border-color: rgba(var(--accent-regular-rgb), 0.15);
		background: linear-gradient(to bottom right, var(--gray-999), color-mix(in oklab, var(--gray-999), var(--accent-regular) 2%));
	}

	.card:hover {
		transform: translateY(-6px) scale(1.03);
		box-shadow: var(--shadow-lg), var(--glow-accent);
		border-color: var(--accent-regular);
	}

	.card:focus-visible {
		outline: 3px solid var(--accent-regular);
		outline-offset: 4px;
	}

	.card-image-container {
		display: block;
		position: relative;
		aspect-ratio: 16 / 9;
		overflow: hidden;
		width: 100%;
	}

	@media (min-width: 40em) {
		.card-image-container {
			aspect-ratio: 16 / 10;
		}
	}

	img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.6s ease;
	}

	.card:hover img {
		transform: scale(1.1);
	}

	.card-overlay {
		position: absolute;
		inset: 0;
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		padding: 0;
		background: linear-gradient(
			to bottom,
			rgba(0, 0, 0, 0.05) 0%,
			transparent 25%,
			rgba(0, 0, 0, 0.15) 65%,
			rgba(0, 0, 0, 0.45) 100%
		);
		backdrop-filter: brightness(1.05);
		transition: all 0.4s ease;
		pointer-events: none;
		z-index: 1;
	}

	.card:hover .card-overlay {
		background: linear-gradient(
			to bottom,
			rgba(0, 0, 0, 0.1) 0%,
			transparent 20%,
			rgba(0, 0, 0, 0.25) 55%,
			rgba(0, 0, 0, 0.6) 100%
		);
		backdrop-filter: brightness(1.1);
	}

	.tags-container {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
		padding: 0.75rem;
		width: 100%;
		justify-content: flex-start;
		transform: translateY(0);
		transition: transform 0.4s ease;
	}

	@media (max-width: 40em) {
		.tags-container .tag:nth-child(n+3) {
			display: none;
		}
	}

	@media (min-width: 64em) {
		.tags-container {
			padding: 1rem;
			transform: translateY(-5px);
		}
	}

	.card:hover .tags-container {
		transform: translateY(0);
	}

	.tag {
		background: rgba(0, 0, 0, 0.5);
		border: 1px solid rgba(var(--accent-regular-rgb), 0.5);
		backdrop-filter: blur(8px);
		color: white;
		padding: 0.25rem 0.5rem;
		border-radius: 4px;
		font-size: 0.65rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
		white-space: nowrap;
		display: flex;
		align-items: center;
		gap: 0.3rem;
	}

	.tag-seo {
		background: var(--accent-regular);
		border: 2px solid var(--accent-light);
		box-shadow: 0 2px 10px rgba(var(--accent-regular-rgb), 0.4);
		color: white;
		z-index: 2;
	}

	.details {
		position: absolute;
		left: 0;
		right: 0;
		bottom: 0;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
		background: rgba(0, 0, 0, 0.55);
		backdrop-filter: blur(16px);
		padding: 0.75rem 1rem;
		border-top: 1px solid rgba(255, 255, 255, 0.15);
		border-left: 4px solid var(--accent-regular);
		transition: all 0.4s ease;
		width: 100%;
	}

	@media (min-width: 50em) {
		.details {
			padding: 1rem 1.25rem;
			background: rgba(0, 0, 0, 0.45);
		}
	}

	.details-content {
		flex: 1;
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
		min-width: 0;
	}

	.open-icon {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2rem;
		height: 2rem;
		border-radius: 50%;
		background: var(--accent-regular);
		color: white;
		transition: all 0.3s ease;
		flex-shrink: 0;
		box-shadow: 0 2px 10px rgba(var(--accent-regular-rgb), 0.4);
	}

	.card:hover .open-icon {
		transform: rotate(90deg) scale(1.1);
		background: var(--accent-light);
		box-shadow: 0 4px 15px rgba(var(--accent-regular-rgb), 0.6);
	}

	.card:hover .details {
		background: rgba(0, 0, 0, 0.8);
		border-left-color: var(--accent-light);
	}

	.category {
		display: block;
		font-size: 0.65rem;
		color: var(--accent-light);
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		opacity: 1;
		text-shadow: 0 1px 2px rgba(0, 0, 0, 0.5);
	}

	.title {
		font-size: var(--text-md);
		color: white;
		margin: 0;
		font-family: var(--font-brand), system-ui, sans-serif;
		line-height: 1.2;
		font-weight: 700;
		letter-spacing: -0.01em;
		overflow: hidden;
		text-overflow: ellipsis;
		display: -webkit-box;
		-webkit-line-clamp: 1;
		-webkit-box-orient: vertical;
		text-shadow: 0 2px 8px rgba(0, 0, 0, 0.5);
	}

	@media (min-width: 40em) {
		.title {
			-webkit-line-clamp: 2;
		}
	}

	@media (min-width: 50em) {
		.title {
			font-size: var(--text-lg);
		}

		.category {
			font-size: 0.7rem;
		}

		.tag {
			padding: 0.25rem 0.6rem;
			font-size: 0.65rem;
		}

		.details {
			padding: 1.25rem;
			gap: 1.25rem;
		}

		.open-icon {
			width: 2.6rem;
			height: 2.6rem;
		}
	}

	@media (min-width: 80em) {
		.title {
			font-size: var(--text-xl);
		}

		.tag {
			padding: 0.3rem 0.8rem;
			font-size: var(--text-xs);
		}
	}
</style>
