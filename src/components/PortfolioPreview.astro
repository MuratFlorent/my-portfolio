---
import type { CollectionEntry } from 'astro:content';

interface Props {
	project: CollectionEntry<'work'>;
}

const { data, id } = Astro.props.project;
---

<button 
	class="card" 
	data-project-id={id}
	data-project-data={JSON.stringify({
		title: data.title,
		img: data.img,
		status: data.status === 'in_progress' ? 'En cours' : 'Projet terminé',
		tags: data.tags,
		description: data.description,
		// On pourrait extraire plus de données si le markdown était parsé ici, 
		// mais pour l'instant on se base sur le schema
	})}
>
	<div class="card-image-container">
		<img src={data.img} alt={data.img_alt || ''} loading="lazy" decoding="async" />
		<div class="card-overlay">
			<div class="tags-container">
				{data.tags.slice(0, 3).map((tag) => (
					<span class="tag">{tag}</span>
				))}
			</div>
			<div class="details">
				<span class="category">{data.status === 'in_progress' ? 'En cours' : 'Projet terminé'}</span>
				<h3 class="title">{data.title}</h3>
			</div>
		</div>
	</div>
</button>

<script>
	const cards = document.querySelectorAll('.card[data-project-id]');
	const modal = document.getElementById('project-modal') as HTMLDialogElement;

	cards.forEach(card => {
		card.addEventListener('click', () => {
			const data = JSON.parse(card.getAttribute('data-project-data') || '{}');
			
			if (modal) {
				const modalImage = modal.querySelector('.modal-image') as HTMLImageElement;
				const modalTitle = modal.querySelector('.modal-title');
				const modalStatus = modal.querySelector('.modal-status');
				const modalDescription = modal.querySelector('.modal-description');
				const modalTags = modal.querySelector('.modal-tags');
				const modalStack = modal.querySelector('.modal-stack-list');
				const modalResult = modal.querySelector('.modal-result');
				const modalSolution = modal.querySelector('.modal-solution-content');

				if (modalImage) modalImage.src = data.img;
				if (modalTitle) modalTitle.textContent = data.title;
				if (modalStatus) modalStatus.textContent = data.status;
				if (modalDescription) modalDescription.textContent = data.description;
				
				if (modalTags) {
					modalTags.innerHTML = data.tags.map((tag: string) => `<span class="tag">${tag}</span>`).join('');
				}

				// Pour la démo, on remplit ces champs avec des valeurs par défaut 
				// car ils ne sont pas encore dans le frontmatter
				if (modalStack) {
					modalStack.innerHTML = data.tags.map((tag: string) => `<span class="tag">${tag}</span>`).join('');
				}
				if (modalResult) modalResult.textContent = "Projet livré avec succès, répondant à toutes les attentes techniques et fonctionnelles.";
				if (modalSolution) modalSolution.innerHTML = "<p>Mise en place d'une architecture robuste et évolutive, optimisée pour la performance et l'expérience utilisateur.</p>";

				modal.showModal();
			}
		});
	});
</script>

<style>
	.card {
		display: block;
		width: 100%;
		padding: 0;
		cursor: pointer;
		text-align: left;
		border-radius: var(--radius-md);
		overflow: hidden;
		background: var(--gray-999);
		box-shadow: var(--shadow-sm);
		transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275), 
					box-shadow 0.4s ease,
					border-color 0.4s ease;
		position: relative;
		border: 1px solid var(--gray-800);
	}

	.card:hover {
		transform: translateY(-8px) scale(1.02);
		box-shadow: var(--glow-accent-strong);
		border-color: var(--accent-regular);
	}

	.card:focus-visible {
		outline: 3px solid var(--accent-regular);
		outline-offset: 4px;
	}

	.card-image-container {
		position: relative;
		aspect-ratio: 16 / 10;
		overflow: hidden;
	}

	img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.6s ease;
	}

	.card:hover img {
		transform: scale(1.1);
	}

	.card-overlay {
		position: absolute;
		inset: 0;
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		padding: 1.5rem;
		background: linear-gradient(
			to bottom,
			rgba(0, 0, 0, 0.4) 0%,
			transparent 30%,
			transparent 60%,
			rgba(0, 0, 0, 0.8) 100%
		);
		opacity: 0.9;
		transition: opacity 0.4s ease;
	}

	.card:hover .card-overlay {
		opacity: 1;
	}

	.tags-container {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		transform: translateY(-10px);
		transition: transform 0.4s ease;
	}

	.card:hover .tags-container {
		transform: translateY(0);
	}

	.tag {
		background: rgba(255, 255, 255, 0.2);
		backdrop-filter: blur(4px);
		color: white;
		padding: 0.2rem 0.8rem;
		border-radius: 99rem;
		font-size: var(--text-sm);
		font-weight: 500;
		border: 1px solid rgba(255, 255, 255, 0.3);
		text-transform: capitalize;
	}

	.details {
		transform: translateY(10px);
		transition: transform 0.4s ease;
	}

	.card:hover .details {
		transform: translateY(0);
	}

	.category {
		display: block;
		font-size: var(--text-sm);
		color: var(--accent-light);
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin-bottom: 0.25rem;
	}

	.title {
		font-size: var(--text-lg);
		color: white;
		margin: 0;
		font-family: var(--font-brand);
		line-height: 1.2;
		text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
	}

	@media (min-width: 50em) {
		.card-image-container {
			aspect-ratio: 3 / 2;
		}

		.title {
			font-size: var(--text-xl);
		}

		.tag {
			padding: 0.3rem 1rem;
		}
	}
</style>
