---
interface Props {
	href: string;
	class?: string;
	id?: string;
	'data-tab'?: string;
	'data-project-type'?: string;
	'data-message'?: string;
	'data-source'?: string;
}

const { href, class: className, id, ...rest } = Astro.props;
---

<a href={href} class={className} id={id} {...rest}><slot /></a>

<style>
	a {
		position: relative;
		display: flex;
		place-content: center;
		text-align: center;
		padding: 0.56em 2em;
		gap: 0.8em;
		color: var(--accent-text-over);
		text-decoration: none;
		line-height: 1.1;
		border-radius: var(--radius-full);
		overflow: hidden;
		background: var(--gradient-accent-orange);
		box-shadow: var(--shadow-md);
		white-space: nowrap;
		transition: transform var(--theme-transition), box-shadow var(--theme-transition);
	}

	a:hover {
		transform: translateY(-3px);
		box-shadow: var(--glow-accent);
	}

	a:active {
		transform: translateY(-1px);
	}

	@media (min-width: 20em) {
		a {
			font-size: var(--text-md);
		}
	}

	/* Overlay for hover effects. */
	a::after {
		content: '';
		position: absolute;
		inset: 0;
		pointer-events: none;
		transition: background-color var(--theme-transition);
		mix-blend-mode: overlay;
	}

	a:focus::after,
	a:hover::after {
		background-color: hsla(var(--gray-999-basis), 0.3);
	}

	@media (min-width: 50em) {
		a {
			padding: 0.8rem 2rem;
			font-size: var(--text-lg);
		}
	}

	@media (min-width: 80em) {
		a {
			padding: 1.125rem 2.5rem;
			font-size: var(--text-xl);
		}
	}

	@media (max-width: 50em) {
		 a{
			padding: 0.56em 1.5rem;
		}
	}
</style>
