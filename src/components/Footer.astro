---
import Icon from './Icon.astro';
const currentYear = new Date().getFullYear();
---

<footer>
	<div class="group">
		<p>&copy; {currentYear} Florent Murat — Light Developer</p>
		<p class="location">
			<Icon icon="map-pin" size="1.1em" />
			<span>Saint-Jeannet (06640) — Côte d'Azur & Alpes-Maritimes (Vence, Nice, Cannes, Antibes)</span>
		</p>
		<p class="emails">
			<a href="mailto:julienblondin.lightdeveloper@gmail.com" id="main-email-link">julienblondin.lightdeveloper@gmail.com</a>
		</p>
	</div>
	<div class="footer-links stack gap-4">
		<p class="socials">
			<a href="https://github.com/MuratFlorent"> GitHub</a>
			<a href="https://www.linkedin.com/in/florent-murat-a1962810b/"> Linkedin</a>
		</p>
		<p class="legal">
			<a href="/mentions-legales">Mentions légales</a>
			<a href="/politique-confidentialite">Confidentialité & RGPD</a>
			<a href="/cgv">CGV</a>
			<a href="/cookies">Cookies</a>
		</p>
	</div>
</footer>

<script>
	// Force l'ouverture du mailto avec CC au clic sur l'email principal
	const emailLink = document.getElementById('main-email-link');
	if (emailLink) {
		emailLink.addEventListener('click', (e) => {
			// Sur certains navigateurs mobiles, le mailto simple peut ne pas prendre le CC correctement
			// En réassignant window.location, on force l'interprétation par le client mail par défaut
			e.preventDefault();
			const href = emailLink.getAttribute('href');
			if (href) {
				window.location.href = href;
			}
		});
	}
</script>
<style>
	footer {
		display: flex;
		flex-direction: column;
		gap: 3rem;
		margin-top: auto;
		padding: 4rem 2rem;
		text-align: center;
		color: var(--gray-400);
		font-size: var(--text-sm);
		border-top: 1px solid var(--gray-800);
		background: var(--gray-999_40);
		backdrop-filter: blur(10px);
	}

	footer a {
		color: var(--gray-400);
		text-decoration: none;
		transition: color var(--theme-transition);
	}

	footer a:hover,
	footer a:focus {
		color: var(--accent-regular);
	}

	.group {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		align-items: center;
	}

	.location {
		display: flex;
		align-items: center;
		gap: 0.4rem;
		font-size: var(--text-xs);
		color: var(--gray-400);
		opacity: 0.9;
	}

	.emails {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		font-size: var(--text-xs);
	}

	.sep {
		display: none;
		color: var(--gray-800);
	}

	.footer-links {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.socials, .legal {
		display: flex;
		justify-content: center;
		gap: 1.5rem;
		flex-wrap: wrap;
	}

	.legal {
		font-size: var(--text-xs);
		opacity: 0.8;
	}

	@media (min-width: 50em) {
		footer {
			flex-direction: row;
			justify-content: space-between;
			padding: 4rem 5rem;
			text-align: left;
		}

		.group {
			align-items: flex-start;
		}

		.emails {
			flex-direction: row;
			gap: 1rem;
		}

		.sep {
			display: inline;
		}

		.footer-links {
			align-items: flex-end;
		}

		.socials, .legal {
			justify-content: flex-end;
		}
	}
</style>
