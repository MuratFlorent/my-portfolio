---
import Icon from './Icon.astro';
const currentYear = new Date().getFullYear();
---

<footer>
	<div class="group">
		<p>&copy; {currentYear} Florent Murat — Light Developer</p>
		<p class="emails">
			<a href="mailto:murat.light.developer@gmail.com">murat.light.developer@gmail.com</a>
			<span class="sep">|</span>
			<a href="mailto:julienblondin.lightdeveloper@gmail.com">Collaborateur : julienblondin.lightdeveloper@gmail.com</a>
		</p>
	</div>
	<div class="footer-links stack gap-4">
		<p class="socials">
			<a href="https://github.com/MuratFlorent"> GitHub</a>
			<a href="https://www.linkedin.com/in/florent-murat-a1962810b/"> Linkedin</a>
		</p>
		<p class="legal">
			<a href="/mentions-legales">Mentions légales</a>
			<a href="/politique-confidentialite">Confidentialité & RGPD</a>
			<a href="/cgv">CGV</a>
			<a href="/cookies">Cookies</a>
		</p>
	</div>
</footer>
<style>
	footer {
		display: flex;
		flex-direction: column;
		gap: 3rem;
		margin-top: auto;
		padding: 4rem 2rem;
		text-align: center;
		color: var(--gray-400);
		font-size: var(--text-sm);
		border-top: 1px solid var(--gray-800);
		background: var(--gray-999_40);
		backdrop-filter: blur(10px);
	}

	footer a {
		color: var(--gray-400);
		text-decoration: none;
		transition: color var(--theme-transition);
	}

	footer a:hover,
	footer a:focus {
		color: var(--accent-regular);
	}

	.group {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		align-items: center;
	}

	.emails {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		font-size: var(--text-xs);
	}

	.sep {
		display: none;
		color: var(--gray-800);
	}

	.footer-links {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.socials, .legal {
		display: flex;
		justify-content: center;
		gap: 1.5rem;
		flex-wrap: wrap;
	}

	.legal {
		font-size: var(--text-xs);
		opacity: 0.8;
	}

	@media (min-width: 50em) {
		footer {
			flex-direction: row;
			justify-content: space-between;
			padding: 4rem 5rem;
			text-align: left;
		}

		.group {
			align-items: flex-start;
		}

		.emails {
			flex-direction: row;
			gap: 1rem;
		}

		.sep {
			display: inline;
		}

		.footer-links {
			align-items: flex-end;
		}

		.socials, .legal {
			justify-content: flex-end;
		}
	}
</style>
