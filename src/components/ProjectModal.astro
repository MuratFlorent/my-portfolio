---
import Icon from './Icon.astro';
import CallToAction from './CallToAction.astro';

interface Props {
	id: string;
}

const { id } = Astro.props;
---

<dialog id={id} class="project-modal">
	<div class="modal-container">
		<button class="close-button" aria-label="Fermer la modale" data-close-modal>
			<Icon icon="arrow-left" size="1.2em" />
			<span>Retour</span>
		</button>
		
		<div class="modal-content stack gap-8">
			<div class="modal-header">
				<div class="image-wrapper">
					<img src="" alt="" class="modal-image" />
				</div>
				<div class="title-wrapper stack gap-2">
					<span class="modal-status"></span>
					<h2 class="modal-title"></h2>
					<div class="modal-tags"></div>
				</div>
			</div>

			<div class="modal-grid">
				<div class="main-info stack gap-6">
					<section>
						<h3><Icon icon="strategy" size="1.2em" /> Contexte & Besoin</h3>
						<p class="modal-description"></p>
					</section>
					
					<section>
						<h3><Icon icon="magic-wand" size="1.2em" /> Solution apportée</h3>
						<div class="modal-solution-content"></div>
					</section>
				</div>

				<aside class="side-info stack gap-6">
					<section class="stack gap-2">
						<h3><Icon icon="code" size="1.2em" /> Technologies utilisées</h3>
						<div class="modal-stack-list"></div>
					</section>

					<section class="stack gap-2">
						<h3><Icon icon="rocket-launch" size="1.2em" /> Bénéfices & Résultat</h3>
						<p class="modal-result"></p>
					</section>

					<div class="modal-cta">
						<button id={`${id}-cta`} class="cta-button">
							Discuter d'un projet similaire
							<Icon icon="paper-plane-tilt" size="1.2em" />
						</button>
					</div>
				</aside>
			</div>
		</div>
	</div>
</dialog>

<script>
	const modals = document.querySelectorAll('.project-modal');
	
	modals.forEach(modal => {
		const id = modal.id;
		const closeBtn = modal.querySelector('[data-close-modal]');
		const ctaBtn = modal.querySelector(`#${id}-cta`);
		
		closeBtn?.addEventListener('click', () => {
			(modal as HTMLDialogElement).close();
		});

		modal.addEventListener('click', (e) => {
			if (e.target === modal) {
				(modal as HTMLDialogElement).close();
			}
		});

		ctaBtn?.addEventListener('click', () => {
			const projectTitle = modal.querySelector('.modal-title')?.textContent;
			const projectTags = Array.from(modal.querySelectorAll('.modal-tags .tag')).map(t => t.textContent?.toLowerCase());
			
			// Essayer de déterminer le type de projet à partir des tags
			let projectType = 'autre';
			if (projectTags.includes('seo')) projectType = 'seo';
			else if (projectTags.includes('woocommerce') || projectTags.includes('e-commerce')) projectType = 'ecommerce';
			else if (projectTags.includes('refonte')) projectType = 'refonte';
			else if (projectTags.includes('automatisation')) projectType = 'automation';
			else if (projectTags.includes('formation')) projectType = 'formation';
			else if (projectTags.includes('wordpress') || projectTags.includes('statamic')) projectType = 'creation';

			(modal as HTMLDialogElement).close();

			// Déclencher l'ouverture de la modale de contact
			window.dispatchEvent(new CustomEvent('open-contact', {
				detail: {
					tab: 'quote',
					projectType: projectType,
					source: `Projet: ${projectTitle}`,
					message: `Bonjour, je souhaiterais discuter d'un projet similaire au projet "${projectTitle}"...`
				}
			}));
		});
	});
</script>

<style>
	.project-modal {
		border: none;
		padding: 0;
		background: transparent;
		max-width: 100vw;
		max-height: 100vh;
		width: 100%;
		height: 100%;
		position: fixed;
		inset: 0;
	}

	.project-modal::backdrop {
		background: rgba(9, 11, 17, 0.6);
		backdrop-filter: blur(8px);
		animation: fadeIn 0.3s ease-out;
	}

	@keyframes fadeIn {
		from { opacity: 0; }
		to { opacity: 1; }
	}

	.modal-container {
		background: var(--gray-999);
		width: 95%;
		max-width: 1000px;
		margin: 2rem auto;
		border-radius: 1.5rem;
		position: relative;
		overflow-y: auto;
		max-height: 90vh;
		box-shadow: var(--shadow-lg);
		border: 1px solid var(--gray-800);
		animation: slideUp 0.4s cubic-bezier(0.16, 1, 0.3, 1);
	}

	@keyframes slideUp {
		from { transform: translateY(30px); opacity: 0; }
		to { transform: translateY(0); opacity: 1; }
	}

	.close-button {
		position: sticky;
		top: 1.5rem;
		left: 1.5rem;
		z-index: 10;
		display: flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.5rem 1rem;
		border-radius: 99rem;
		border: 1px solid var(--gray-800);
		background: var(--gray-999_40);
		backdrop-filter: blur(4px);
		color: var(--gray-200);
		cursor: pointer;
		font-weight: 500;
		transition: all 0.2s ease;
	}

	.close-button:hover {
		background: var(--gray-800);
		color: var(--gray-0);
	}

	.modal-content {
		padding: 1.5rem;
	}

	.modal-header {
		display: grid;
		gap: 2rem;
	}

	.image-wrapper {
		border-radius: 1rem;
		overflow: hidden;
		aspect-ratio: 16 / 9;
		box-shadow: var(--shadow-md);
	}

	.modal-image {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.title-wrapper {
		justify-content: center;
	}

	.modal-status {
		font-size: var(--text-sm);
		color: var(--accent-regular);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
	}

	.modal-title {
		font-size: var(--text-2xl);
		color: var(--gray-0);
	}

	.modal-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	/* Utiliser le style des tags de PortfolioPreview */
	:global(.modal-tags .tag) {
		background: var(--gray-800);
		color: var(--gray-200);
		padding: 0.2rem 0.8rem;
		border-radius: 99rem;
		font-size: var(--text-sm);
	}

	.modal-grid {
		display: grid;
		gap: 3rem;
	}

	h3 {
		font-size: var(--text-lg);
		color: var(--gray-0);
		display: flex;
		align-items: center;
		gap: 0.5rem;
		margin-bottom: 1rem;
	}

	.side-info {
		padding: 2rem;
		background: var(--gradient-subtle);
		border-radius: 1rem;
		border: 1px solid var(--gray-800);
	}

	.modal-stack-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.modal-cta {
		margin-top: 1rem;
	}

	.cta-button {
		display: flex;
		padding: 0.8rem 1.6rem;
		gap: 0.8rem;
		color: var(--accent-text-over);
		text-decoration: none;
		line-height: 1.1;
		border-radius: 999rem;
		overflow: hidden;
		background: var(--gradient-accent-orange);
		box-shadow: var(--shadow-md);
		white-space: nowrap;
		border: 0;
		font-size: var(--text-md);
		font-weight: 600;
		cursor: pointer;
		transition: transform var(--theme-transition), box-shadow var(--theme-transition);
		width: 100%;
		justify-content: center;
		align-items: center;
	}

	.cta-button:hover {
		transform: translateY(-2px);
		box-shadow: var(--glow-accent);
	}

	@media (min-width: 50em) {
		.modal-content {
			padding: 3rem;
		}

		.modal-header {
			grid-template-columns: 1fr 1fr;
			align-items: center;
		}

		.modal-grid {
			grid-template-columns: 1.5fr 1fr;
		}

		.modal-title {
			font-size: var(--text-4xl);
		}
	}
</style>
