---
import Icon from './Icon.astro';
import CallToAction from './CallToAction.astro';

interface Props {
	id: string;
}

const { id } = Astro.props;
---

<dialog id={id} class="project-modal">
	<div class="modal-container">
		<button class="close-button" aria-label="Fermer la modale" data-close-modal>
			<Icon icon="arrow-left" size="1.2em" />
			<span>Retour</span>
		</button>
		
		<div class="modal-content stack gap-8">
			<div class="modal-header">
				<div class="image-wrapper">
					<img src="" alt="" class="modal-image" />
				</div>
				<div class="title-wrapper stack gap-2">
					<span class="modal-status"></span>
					<h2 class="modal-title"></h2>
					<div class="modal-tags"></div>
				</div>
			</div>

			<div class="modal-grid">
				<div class="main-info stack gap-6">
					<section>
						<h3><Icon icon="strategy" size="1.2em" /> Contexte & Besoin</h3>
						<p class="modal-description"></p>
					</section>
					
					<section>
						<h3><Icon icon="magic-wand" size="1.2em" /> Services & Solution</h3>
						<div class="modal-solution-content"></div>
					</section>

					<section>
						<h3><Icon icon="strategy" size="1.2em" /> Aperçu Galerie</h3>
						<div class="modal-gallery-grid"></div>
					</section>
				</div>

				<aside class="side-info stack gap-6">
					<section class="stack gap-2">
						<h3><Icon icon="code" size="1.2em" /> Stack Technique</h3>
						<div class="modal-stack-list"></div>
					</section>

					<section class="stack gap-2">
						<h3><Icon icon="rocket-launch" size="1.2em" /> Points clés</h3>
						<div class="modal-result"></div>
					</section>

					<div class="modal-cta stack gap-4">
						<a href="" class="modal-project-link cta-button secondary">
							Voir l'étude de cas complète
							<Icon icon="arrow-right" size="1.2em" />
						</a>
						<button id={`${id}-cta`} class="cta-button">
							Discuter d'un projet similaire
							<Icon icon="paper-plane-tilt" size="1.2em" />
						</button>
					</div>
				</aside>
			</div>
		</div>
	</div>
</dialog>

<script>
	const modals = document.querySelectorAll('.project-modal');
	
	modals.forEach(modal => {
		const id = modal.id;
		const closeBtn = modal.querySelector('[data-close-modal]');
		const ctaBtn = modal.querySelector(`#${id}-cta`);

		// Force closed on load
		if ((modal as HTMLDialogElement).open) (modal as HTMLDialogElement).close();
		
		closeBtn?.addEventListener('click', () => {
			(modal as HTMLDialogElement).close();
		});

		modal.addEventListener('close', () => {
			// Réinitialiser l'affichage des sections masquées pour les références
			const resultEl = modal.querySelector('.modal-result');
			const galleryEl = modal.querySelector('.modal-gallery-grid');
			const caseStudyLink = modal.querySelector('.modal-project-link') as HTMLAnchorElement;
			const modalGrid = modal.querySelector('.modal-grid') as HTMLElement;

			if (resultEl) (resultEl.parentElement as HTMLElement).style.display = '';
			if (galleryEl) (galleryEl.parentElement as HTMLElement).style.display = '';
			if (caseStudyLink) caseStudyLink.style.display = '';
			if (modalGrid) modalGrid.style.display = '';
		});

		modal.addEventListener('click', (e) => {
			if (e.target === modal) {
				(modal as HTMLDialogElement).close();
			}
		});

		ctaBtn?.addEventListener('click', () => {
			const projectTitle = modal.querySelector('.modal-title')?.textContent;
			const projectTags = Array.from(modal.querySelectorAll('.modal-tags .tag')).map(t => t.textContent?.toLowerCase());
			
			// Essayer de déterminer le type de projet à partir des tags
			let projectType = 'autre';
			if (projectTags.includes('seo')) projectType = 'seo';
			else if (projectTags.includes('woocommerce') || projectTags.includes('e-commerce')) projectType = 'ecommerce';
			else if (projectTags.includes('refonte')) projectType = 'refonte';
			else if (projectTags.includes('automatisation')) projectType = 'automation';
			else if (projectTags.includes('formation')) projectType = 'formation';
			else if (projectTags.includes('wordpress') || projectTags.includes('statamic')) projectType = 'creation';

			(modal as HTMLDialogElement).close();

			// Déclencher l'ouverture de la modale de contact
			window.dispatchEvent(new CustomEvent('open-contact', {
				detail: {
					tab: 'quote',
					projectType: projectType,
					source: `Projet: ${projectTitle}`,
					message: `Bonjour, je souhaiterais discuter d'un projet similaire au projet "${projectTitle}"...`
				}
			}));
		});
	});

	// Gestion globale de l'ouverture pour les ReferenceCard
	window.addEventListener('open-reference-modal', (e: any) => {
		const data = e.detail;
		const modal = document.querySelector('.project-modal') as HTMLDialogElement;
		if (!modal) return;

		// Remplir la modale avec les données de la référence
		const titleEl = modal.querySelector('.modal-title');
		const imageEl = modal.querySelector('.modal-image') as HTMLImageElement;
		const statusEl = modal.querySelector('.modal-status');
		const tagsEl = modal.querySelector('.modal-tags');
		const descEl = modal.querySelector('.modal-description');
		const solutionEl = modal.querySelector('.modal-solution-content');
		const stackEl = modal.querySelector('.modal-stack-list');
		const resultEl = modal.querySelector('.modal-result');
		const galleryEl = modal.querySelector('.modal-gallery-grid');
		const caseStudyLink = modal.querySelector('.modal-project-link') as HTMLAnchorElement;

		if (titleEl) titleEl.textContent = data.title;
		if (imageEl) {
			imageEl.src = data.image;
			imageEl.alt = data.title;
		}
		if (statusEl) statusEl.textContent = data.period || '';
		
		if (tagsEl) {
			tagsEl.innerHTML = '';
			data.tags.forEach((tag: string) => {
				const span = document.createElement('span');
				span.className = 'tag';
				span.textContent = tag;
				tagsEl.appendChild(span);
			});
		}

		if (descEl) descEl.textContent = data.role ? `${data.role} : ${data.description}` : data.description;
		
		if (solutionEl) {
			solutionEl.innerHTML = `<p>${data.details || data.description}</p>`;
		}

		if (stackEl) {
			stackEl.innerHTML = '';
			data.tags.forEach((tag: string) => {
				const span = document.createElement('span');
				span.className = 'tag';
				span.textContent = tag;
				stackEl.appendChild(span);
			});
		}

		// Masquer les sections non pertinentes pour une simple référence
		if (resultEl) (resultEl.parentElement as HTMLElement).style.display = 'none';
		if (galleryEl) (galleryEl.parentElement as HTMLElement).style.display = 'none';
		if (caseStudyLink) caseStudyLink.style.display = 'none';

		modal.showModal();
	});
</script>

<style>
	.project-modal {
		display: none;
		border: none;
		padding: 0;
		background: transparent;
		max-width: 100vw;
		max-height: 100vh;
		width: 100%;
		height: 100%;
		position: fixed;
		inset: 0;
		z-index: 1000;
	}

	.project-modal[open] {
		display: block;
	}

	.project-modal::backdrop {
		background: rgba(9, 11, 17, 0.6);
		backdrop-filter: blur(8px);
		animation: fadeIn 0.3s ease-out;
	}

	@keyframes fadeIn {
		from { opacity: 0; }
		to { opacity: 1; }
	}

	.modal-container {
		background: var(--gray-999);
		width: calc(100% - 2rem);
		max-width: 1000px;
		margin: 1rem auto;
		border-radius: 1.5rem;
		position: relative;
		overflow-y: auto;
		max-height: calc(100vh - 2rem);
		box-shadow: var(--shadow-lg);
		border: 1px solid var(--gray-800);
		animation: slideUp 0.4s cubic-bezier(0.16, 1, 0.3, 1);
	}

	@keyframes slideUp {
		from { transform: translateY(30px); opacity: 0; }
		to { transform: translateY(0); opacity: 1; }
	}

	.close-button {
		position: sticky;
		top: 1rem;
		left: 1rem;
		margin-bottom: -2.5rem; /* Réduire l'espace pris par le bouton sticky */
		z-index: 10;
		display: flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.5rem 1rem;
		border-radius: 99rem;
		border: 1px solid var(--gray-800);
		background: var(--gray-999_40);
		backdrop-filter: blur(4px);
		color: var(--gray-200);
		cursor: pointer;
		font-weight: 500;
		transition: all 0.2s ease;
	}

	.close-button:hover {
		background: var(--gray-800);
		color: var(--gray-0);
	}

	.modal-content {
		padding: 1rem;
		padding-top: 4rem; /* Espace pour le bouton close sticky */
	}

	.modal-header {
		display: grid;
		gap: 2rem;
	}

	.image-wrapper {
		border-radius: 1rem;
		overflow: hidden;
		aspect-ratio: 16 / 9;
		box-shadow: var(--shadow-md);
	}

	.modal-image {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.title-wrapper {
		justify-content: center;
	}

	.modal-status {
		font-size: var(--text-sm);
		color: var(--accent-regular);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
	}

	.modal-title {
		font-size: var(--text-xl);
		color: var(--gray-0);
		word-break: break-word;
	}

	.modal-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	/* Utiliser le style des tags de PortfolioPreview */
	:global(.modal-tags .tag) {
		background: var(--gray-800);
		color: var(--gray-200);
		padding: 0.2rem 0.8rem;
		border-radius: 99rem;
		font-size: var(--text-sm);
	}

	.modal-grid {
		display: grid;
		gap: 3rem;
	}

	h3 {
		font-size: var(--text-lg);
		color: var(--gray-0);
		display: flex;
		align-items: center;
		gap: 0.5rem;
		margin-bottom: 1rem;
	}

	.side-info {
		padding: 2rem;
		background: var(--gradient-subtle);
		border-radius: 1rem;
		border: 1px solid var(--gray-800);
	}

	.modal-stack-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.modal-cta {
		margin-top: 1rem;
	}

	.cta-button {
		display: flex;
		padding: 0.8rem 1.2rem;
		gap: 0.6rem;
		color: var(--accent-text-over);
		text-decoration: none;
		line-height: 1.2;
		border-radius: 999rem;
		overflow: hidden;
		background: var(--gradient-accent-orange);
		box-shadow: var(--shadow-md);
		border: 0;
		font-size: var(--text-sm);
		font-weight: 600;
		cursor: pointer;
		transition: transform var(--theme-transition), box-shadow var(--theme-transition);
		width: 100%;
		justify-content: center;
		align-items: center;
	}

	.cta-button:hover {
		transform: translateY(-2px);
		box-shadow: var(--glow-accent);
	}

	.modal-result :global(ul), .modal-solution-content :global(ul) {
		margin: 0;
		padding-left: 1.5rem;
		list-style-type: disc;
	}

	.modal-result :global(li), .modal-solution-content :global(li) {
		margin-bottom: 0.5rem;
		color: var(--gray-300);
	}

	.modal-gallery-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
		gap: 1rem;
		margin-top: 0.5rem;
	}

	.gallery-item {
		border-radius: 0.5rem;
		overflow: hidden;
		aspect-ratio: 16 / 9;
		border: 1px solid var(--gray-800);
	}

	.gallery-item img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.cta-button.secondary {
		background: var(--gray-800);
		color: var(--gray-0);
	}

	.cta-button.secondary:hover {
		background: var(--gray-700);
	}

	@media (min-width: 50em) {
		.modal-container {
			margin: 2rem auto;
			max-height: 90vh;
			width: 95%;
		}

		.modal-content {
			padding: 3rem;
		}

		.close-button {
			top: 1.5rem;
			left: 1.5rem;
			margin-bottom: 0;
		}

		.modal-header {
			grid-template-columns: 1fr 1fr;
			align-items: center;
		}

		.modal-grid {
			grid-template-columns: 1.5fr 1fr;
		}

		.modal-title {
			font-size: var(--text-4xl);
		}

		.cta-button {
			font-size: var(--text-md);
			padding: 0.8rem 1.6rem;
		}
	}
</style>
