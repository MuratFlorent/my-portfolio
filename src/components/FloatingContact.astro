---
import Icon from './Icon.astro';
---

<div class="floating-controls">
	<button id="back-to-top" class="fab back-to-top" aria-label="Retour en haut" hidden>
		<Icon icon="arrow-up" size="1rem" />
	</button>
	<button id="fab-contact" class="fab contact-fab" aria-label="Parlons de votre projet">
		<Icon icon="chat-circle-dots" size="1.5rem" />
		<span class="fab-text">Parlons de votre projet</span>
	</button>
</div>

<dialog id="contact-modal" class="contact-modal">
	<div class="modal-container">
		<button class="close-button" aria-label="Fermer la modale" data-close-contact-modal>
			<Icon icon="arrow-left" size="1.2em" />
			<span>Retour</span>
		</button>

		<div id="close-confirm-dialog" class="confirm-overlay" style="display: none;">
			<div class="confirm-dialog stack gap-4">
				<header class="stack gap-2">
					<h3>Fermer le formulaire ?</h3>
					<p>Vos modifications ne seront pas enregistrées.</p>
				</header>
				<div class="confirm-actions">
					<button type="button" id="confirm-stay" class="btn-confirm secondary">Continuer</button>
					<button type="button" id="confirm-leave" class="btn-confirm danger">Quitter</button>
				</div>
			</div>
		</div>

		<div class="modal-content stack gap-8">
			<header class="modal-header-text stack gap-2">
				<h2 class="modal-title">Lancez votre projet</h2>
				<p>Besoin d'un devis précis ou d'un simple échange ? Voici comment me joindre.</p>
			</header>

			<div class="direct-contact-options stack gap-4">
				<div class="contact-option-card">
					<Icon icon="mail-box" size="1.2em" />
					<div class="option-details stack gap-1">
						<span class="option-label">Email :</span>
								<a href="mailto:contact@lightdeveloper.fr" class="option-value">contact@lightdeveloper.fr</a>
					</div>
					<button type="button" class="copy-btn" id="copy-email-btn" title="Copier l'email" aria-label="Copier l'adresse email">
						<Icon icon="copy" size="1.2em" />
					</button>
				</div>
				<div class="contact-option-card">
					<Icon icon="phone-call" size="1.2em" />
					<div class="option-details stack gap-1">
						<span class="option-label">Relation clientèle :</span>
						<a href="tel:+33669952710" class="option-value">06 69 95 27 10</a>
					</div>
				</div>
			</div>

			<div class="modal-separator">
				<span class="separator-text">OU remplissez ce formulaire pour un devis</span>
			</div>

			<div id="quote-contact-panel" class="quote-panel">
				<form 
					id="demande-devis"
					name="demande-devis" 
					method="POST" 
					data-netlify="true" 
					data-netlify-recaptcha="true"
					data-netlify-honeypot="bot-field"
					action="/merci-devis"
					class="contact-form stack gap-6"
				>
					<input type="hidden" name="form-name" value="demande-devis" />
					<p class="hidden">
						<label>Ne pas remplir si vous êtes humain : <input name="bot-field" /></label>
					</p>
					<input type="hidden" name="source" id="quote-source-project" value="Direct" />
					<div class="form-grid">
						<div class="field">
							<label for="quote-name">Nom complet</label>
							<input type="text" id="quote-name" name="name" placeholder="Votre nom" required />
						</div>
						<div class="field">
							<label for="quote-email">Email</label>
							<input type="email" id="quote-email" name="email" placeholder="votre@email.com" required />
						</div>
					</div>
					
					<div class="form-grid">
						<div class="field">
							<label for="project-type">Type de projet</label>
							<select id="project-type" name="projectType" required>
								<option value="" disabled selected>Sélectionnez un type de besoin</option>
								<option value="creation">Création de site web</option>
								<option value="refonte">Amélioration / Refonte de site</option>
								<option value="seo">Visibilité Google (SEO)</option>
								<option value="ecommerce">Boutique en ligne (E-commerce)</option>
								<option value="automation">Gain de temps (Automatisation)</option>
								<option value="formation">Formation & Accompagnement</option>
								<option value="autre">Autre projet sur mesure</option>
							</select>
						</div>
						<div class="field">
							<label for="budget">Budget indicatif</label>
							<select id="budget" name="budget">
								<option value="small">&lt; 1500€</option>
								<option value="medium">1500€ - 5000€</option>
								<option value="large">> 5000€</option>
								<option value="unknown">Je ne sais pas encore</option>
							</select>
						</div>
					</div>

					<!-- Champs conditionnels (visibles via JS selon type de projet) -->
					<div id="conditional-fields" class="stack gap-4">
						<div class="field" data-condition="creation refonte ecommerce seo">
							<label for="site-url">URL du site actuel (si existant)</label>
							<input type="url" id="site-url" name="siteUrl" placeholder="https://..." />
						</div>
						<div class="field" data-condition="formation">
							<label for="trainees">Nombre de personnes à former</label>
							<input type="number" id="trainees" name="trainees" min="1" placeholder="1" />
						</div>
					</div>

					<div class="field">
						<label for="quote-message">Détails de votre demande</label>
						<textarea id="quote-message" name="message" placeholder="Dites-m'en plus sur votre projet..." required rows="4"></textarea>
					</div>
					<div data-netlify-recaptcha="true"></div>
					<div class="form-feedback-message" hidden></div>
					<button type="submit" class="submit-btn">
						Demander mon devis personnalisé
						<Icon icon="magic-wand" size="1.2em" />
					</button>
				</form>
			</div>
		</div>
	</div>
</dialog>

<script>
	const fab = document.getElementById('fab-contact');
	const backToTop = document.getElementById('back-to-top');
	const modal = document.getElementById('contact-modal') as HTMLDialogElement;
	const confirmDialog = document.getElementById('close-confirm-dialog') as HTMLElement;
	const stayBtn = document.getElementById('confirm-stay') as HTMLButtonElement;
	const leaveBtn = document.getElementById('confirm-leave') as HTMLButtonElement;
	const copyEmailBtn = document.getElementById('copy-email-btn');
	copyEmailBtn?.addEventListener('click', () => {
 	const email = "contact@lightdeveloper.fr";
		navigator.clipboard.writeText(email).then(() => {
			const originalIcon = copyEmailBtn.innerHTML;
			copyEmailBtn.innerHTML = `<span style="color: var(--accent-regular); font-size: 0.8em; font-weight: bold;">Copié !</span>`;
			setTimeout(() => {
				copyEmailBtn.innerHTML = originalIcon;
			}, 2000);
		});
	});

	// Back to top logic with optimized scroll handling
	let isBackToTopVisible = false;
	const handleScroll = () => {
		const shouldBeVisible = window.scrollY > 300;
		if (shouldBeVisible !== isBackToTopVisible) {
			isBackToTopVisible = shouldBeVisible;
			if (isBackToTopVisible) {
				backToTop?.removeAttribute('hidden');
				if (backToTop) backToTop.style.display = 'flex';
			} else {
				backToTop?.setAttribute('hidden', '');
				if (backToTop) backToTop.style.display = 'none';
			}
		}
	};
	window.addEventListener('scroll', handleScroll, { passive: true });

	backToTop?.addEventListener('click', () => {
		window.scrollTo({ top: 0, behavior: 'smooth' });
	});
	const closeBtn = modal?.querySelector('[data-close-contact-modal]');
	const projectTypeSelect = document.getElementById('project-type') as HTMLSelectElement;
	const conditionalFields = document.querySelectorAll('#conditional-fields .field[data-condition]');

	const handleCloseIntent = () => {
		const activeTextarea = modal.querySelector('textarea') as HTMLTextAreaElement;
		if (activeTextarea && activeTextarea.value.length > 50) {
			if (confirmDialog) confirmDialog.style.display = 'flex';
		} else {
			modal.close();
		}
	};

	stayBtn?.addEventListener('click', () => {
		if (confirmDialog) confirmDialog.style.display = 'none';
	});

	leaveBtn?.addEventListener('click', () => {
		if (confirmDialog) confirmDialog.style.display = 'none';
		modal.close();
	});

	// Toggle Modal
	fab?.addEventListener('click', (e) => {
		e.preventDefault();
		e.stopPropagation();
		modal.showModal();
	});

	closeBtn?.addEventListener('click', (e) => {
		e.preventDefault();
		e.stopPropagation();
		handleCloseIntent();
	});

	modal?.addEventListener('click', (e) => {
		if (e.target === modal) {
			handleCloseIntent();
		}
	});

	// Conditional fields logic
	function updateConditionalFields(selectedType: string) {
		conditionalFields.forEach(field => {
			const conditions = (field as HTMLElement).dataset.condition?.split(' ') || [];
			if (conditions.includes(selectedType)) {
				(field as HTMLElement).style.display = 'block';
			} else {
				(field as HTMLElement).style.display = 'none';
			}
		});
	}

	projectTypeSelect?.addEventListener('change', (e) => {
		updateConditionalFields((e.target as HTMLSelectElement).value);
	});

	// Initial hide conditional fields
	conditionalFields.forEach(field => (field as HTMLElement).style.display = 'none');

	// Ensure modal is closed on page load (Astro fix for some hydration issues)
	const forceClose = () => {
		if (modal && modal.open) {
			modal.close();
		}
		if (confirmDialog) confirmDialog.style.display = 'none';
	};
	forceClose();
	setTimeout(forceClose, 100);
	setTimeout(forceClose, 500);

	// Global delegation for all quote CTA buttons
	// This captures clicks on elements that might be added dynamically or
	// where the script would otherwise need to be re-attached (Astro View Transitions)
	function setupGlobalCtaDelegation() {
		document.addEventListener('click', (e) => {
			const target = e.target as HTMLElement;
			const btn = target.closest('.quote-cta-button, [href="#contact"], [href="/#contact"]') as HTMLAnchorElement | HTMLButtonElement;
			
			if (btn) {
				const href = btn.getAttribute('href');
				// On intercepte si c'est une ancre interne vers contact, ou si le bouton n'a pas de href (bouton pur)
				// ou s'il a explicitement la classe quote-cta-button
				if (btn.classList.contains('quote-cta-button') || 
					(href && (href === '#contact' || href === '/#contact' || href.endsWith('/#contact')))) {
					
					e.preventDefault();
					e.stopPropagation();
					
					const tab = btn.getAttribute('data-tab') || 'quote';
					const projectType = btn.getAttribute('data-project-type');
					const message = btn.getAttribute('data-message');
					const source = btn.getAttribute('data-source') || btn.innerText.trim() || 'Global Delegation';

					window.dispatchEvent(new CustomEvent('open-contact', {
						detail: {
							tab,
							projectType,
							message,
							source
						}
					}));
				}
			}
		}, { capture: true }); // Capture phase to ensure we intercept before other listeners
	}
	
	setupGlobalCtaDelegation();
	
	// External Trigger Support (for ProjectModal)
	window.addEventListener('open-contact', (e: any) => {
		const { projectType, message, source } = e.detail || {};
		
		if (projectType && projectTypeSelect) {
			projectTypeSelect.value = projectType;
			updateConditionalFields(projectType);
		}
		
		const textarea = modal.querySelector('textarea') as HTMLTextAreaElement;
		if (message && textarea) {
			textarea.value = message;
		} else if (textarea) {
			textarea.value = 'Je souhaite obtenir un devis gratuit pour mon projet.';
		}

		if (source) {
			const quoteSource = document.getElementById('quote-source-project') as HTMLInputElement;
			if (quoteSource) quoteSource.value = source;
		}
		
		if (!modal.open) {
			modal.showModal();
		}
	});

	// Form Submission logic
	let isSubmitting = false;

	modal?.querySelectorAll('form').forEach(form => {
		form.addEventListener('submit', async (e) => {
			e.preventDefault();

			if (isSubmitting) return;
			
			const formData = new FormData(form as HTMLFormElement);
			const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
			const feedbackMsg = form.querySelector('.form-feedback-message') as HTMLElement;
			
			if (submitBtn) {
				isSubmitting = true;
				submitBtn.disabled = true;
				const originalContent = submitBtn.innerHTML;
				submitBtn.innerHTML = 'Envoi en cours...';
				
				try {
					const response = await fetch('/', {
						method: 'POST',
						body: formData,
					});

					if (response.ok) {
						if (feedbackMsg) {
							feedbackMsg.textContent = "Merci ! Votre demande a bien été envoyée. Je reviens vers vous très rapidement.";
							feedbackMsg.classList.remove('error');
							feedbackMsg.classList.add('success');
							feedbackMsg.removeAttribute('hidden');
						}
						form.reset();
						
						// On attend un peu avant de fermer la modale pour que l'utilisateur lise le message
						setTimeout(() => {
							modal.close();
							if (feedbackMsg) feedbackMsg.setAttribute('hidden', '');
							isSubmitting = false;
						}, 4000);
					} else {
						isSubmitting = false;
						if (feedbackMsg) {
							feedbackMsg.textContent = "Oups ! Une erreur est survenue lors de l'envoi. Veuillez réessayer ou me contacter par email directement.";
							feedbackMsg.classList.add('error');
							feedbackMsg.removeAttribute('hidden');
						}
					}
				} catch (error) {
					isSubmitting = false;
					if (feedbackMsg) {
						feedbackMsg.textContent = "Oups ! Une erreur est survenue lors de l'envoi. Veuillez réessayer ou me contacter par email directement.";
						feedbackMsg.classList.add('error');
						feedbackMsg.removeAttribute('hidden');
					}
				} finally {
					if (submitBtn) {
						submitBtn.disabled = false;
						submitBtn.innerHTML = originalContent;
					}
				}
			}
		});
	});
</script>

<style>
	.floating-controls {
		position: fixed;
		bottom: 2rem;
		right: 2rem;
		z-index: 100;
		display: flex;
		flex-direction: column;
		gap: 1rem;
		align-items: flex-end;
		pointer-events: none;
	}

	@media (min-width: 50em) {
		.floating-controls {
			bottom: 8.5rem; /* Rehaussé pour être au-dessus des liens sociaux du footer */
		}
	}

	.floating-controls > * {
		pointer-events: auto;
	}

	@media (max-width: 50em) {
		.floating-controls {
			bottom: 1.5rem;
			right: 1.5rem;
			gap: 0.75rem;
		}
	}

	.fab {
		display: flex;
		align-items: center;
		justify-content: center;
		background: var(--gradient-accent-orange);
		color: white;
		border: none;
		border-radius: var(--radius-full);
		box-shadow: var(--shadow-lg);
		cursor: pointer;
		transition: transform var(--theme-transition-slow), box-shadow var(--theme-transition), opacity 0.3s ease;
	}

	.contact-fab {
		gap: 0.75rem;
		padding: 0.75rem 1.5rem;
	}

	.back-to-top {
		width: 3rem;
		height: 3rem;
		background: var(--gradient-accent-orange);
		color: white;
		border: none;
		box-shadow: var(--shadow-md);
		opacity: 0.8;
	}

	.back-to-top:hover {
		transform: translateY(-5px);
		box-shadow: var(--glow-accent-strong);
		filter: brightness(1.1);
		opacity: 1;
	}

	.contact-fab:hover {
		transform: scale(1.05) translateY(-5px);
		box-shadow: var(--glow-accent-strong);
	}

	.fab-text {
		font-weight: 600;
		font-size: var(--text-base);
	}

	@media (max-width: 50em) {
		.back-to-top {
			width: 2.5rem;
			height: 2.5rem;
		}
		
		.fab-text {
			display: block;
			font-size: var(--text-xs);
			max-width: 8ch;
			line-height: 1;
			text-align: left;
		}
		.contact-fab {
			padding: 0.75rem 1rem;
		}
	}

	/* Modal styles */
	.contact-modal {
		display: none;
		border: none;
		padding: 0;
		background: transparent;
		max-width: 100vw;
		max-height: 100vh;
		width: 100%;
		height: 100%;
		position: fixed;
		inset: 0;
		align-items: center;
		justify-content: center;
		z-index: 1000;
	}

	.contact-modal[open] {
		display: flex;
	}

	.confirm-overlay {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background: rgba(0, 0, 0, 0.85);
		backdrop-filter: blur(8px);
		display: flex;
		align-items: center;
		justify-content: center;
		z-index: 10000;
		padding: 2rem;
		animation: overlay-fade-in 0.2s ease-out forwards;
	}

	.confirm-dialog {
		background: var(--gray-999);
		border: 1px solid var(--gray-800);
		border-radius: 1.5rem;
		padding: 2.5rem 2rem;
		width: 100%;
		max-width: 360px;
		text-align: center;
		box-shadow: 0 20px 50px rgba(0, 0, 0, 0.6);
		transform: scale(0.95);
		animation: dialog-pop 0.3s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
	}

	.confirm-dialog h3 {
		font-size: var(--text-lg);
		color: var(--gray-0);
		margin: 0;
	}

	.confirm-dialog p {
		font-size: var(--text-md);
		color: var(--gray-300);
		line-height: 1.5;
	}

	.confirm-actions {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		margin-top: 1.5rem;
	}

	.btn-confirm {
		padding: 0.8rem 1.5rem;
		border-radius: 0.8rem;
		font-weight: 600;
		cursor: pointer;
		border: none;
		font-size: var(--text-md);
		transition: all 0.2s ease;
	}

	.btn-confirm.secondary {
		background: var(--accent-regular);
		color: var(--accent-text-over);
	}

	.btn-confirm.danger {
		background: transparent;
		color: var(--gray-400);
		font-weight: 400;
		font-size: var(--text-sm);
		text-decoration: underline;
	}

	.btn-confirm:hover {
		transform: translateY(-2px);
		filter: brightness(1.1);
	}

	@keyframes overlay-fade-in {
		from { opacity: 0; }
		to { opacity: 1; }
	}

	@keyframes dialog-pop {
		to { transform: scale(1); }
	}

	.contact-modal::backdrop {
		background: rgba(9, 11, 17, 0.6);
		backdrop-filter: blur(8px);
	}

	.modal-container {
		background: var(--gray-999);
		width: 100%;
		height: 100%;
		max-width: 100%;
		margin: 0;
		border-radius: 0;
		position: relative;
		overflow-y: auto;
		scrollbar-width: thin;
		scrollbar-color: var(--gray-700) transparent;
		scroll-behavior: smooth;
		box-shadow: none;
		border: none;
		transition: transform var(--theme-transition-slow);
	}

	.modal-container::-webkit-scrollbar {
		width: 8px;
	}

	.modal-container::-webkit-scrollbar-track {
		background: transparent;
	}

	.modal-container::-webkit-scrollbar-thumb {
		background-color: var(--gray-700);
		border-radius: 10px;
		border: 2px solid var(--gray-999);
	}

	.modal-container::-webkit-scrollbar-thumb:hover {
		background-color: var(--gray-600);
	}

	@media (min-width: 40em) {
		.modal-container {
			width: 95%;
			height: auto;
			max-height: 90vh;
			max-width: 800px;
			margin: 2rem auto;
			border-radius: var(--radius-lg);
			box-shadow: var(--shadow-lg);
			border: 1px solid var(--gray-800);
		}
	}

	.close-button {
		position: sticky;
		top: 1rem;
		left: 1rem;
		z-index: 10;
		display: flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.5rem 1rem;
		border-radius: var(--radius-full);
		border: 1px solid var(--gray-800);
		background: var(--gray-999_40);
		backdrop-filter: blur(4px);
		color: var(--gray-200);
		cursor: pointer;
		font-weight: 500;
		transition: all var(--theme-transition);
		font-size: var(--text-sm);
	}

	@media (min-width: 40em) {
		.close-button {
			top: 1.5rem;
			left: 1.5rem;
		}
	}

	.close-button:hover {
		background: var(--gray-900);
		color: var(--gray-0);
		border-color: var(--accent-regular);
	}

	.modal-content {
		padding: 2rem;
	}

	.modal-header-text {
		text-align: center;
	}

	.modal-title {
		font-size: var(--text-3xl);
		color: var(--gray-0);
	}

	/* Direct Contact Styles */
	.direct-contact-options {
		display: grid;
		grid-template-columns: 1fr;
		gap: 0.75rem;
		margin-top: 1rem;
	}

	@media (min-width: 48em) {
		.direct-contact-options {
			grid-template-columns: 1fr 1fr;
			gap: 1.5rem;
		}
	}

	.contact-option-card {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		padding: 0.75rem 1rem;
		background: var(--gray-999_40);
		border: 1px solid var(--gray-800);
		border-radius: 0.75rem;
		transition: all 0.2s ease;
		position: relative;
		overflow: hidden;
	}

	.option-details {
		display: flex;
		flex-direction: column;
		min-width: 0; /* Important for text truncation */
	}

	.option-label {
		font-size: 0.65rem;
		color: var(--gray-400);
		text-transform: uppercase;
		letter-spacing: 0.05em;
		white-space: nowrap;
	}

	.option-value {
		font-size: var(--text-sm);
		font-weight: 600;
		color: var(--gray-100);
		text-decoration: none;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}

	@media (max-width: 30em) {
		.option-value {
			font-size: 0.8rem;
		}
		
		.contact-option-card {
			padding: 0.5rem 0.75rem;
		}
	}

	.option-value:hover {
		color: var(--accent-regular);
	}

	.copy-btn {
		margin-left: auto;
		background: transparent;
		border: none;
		color: var(--gray-400);
		cursor: pointer;
		padding: 0.5rem;
		border-radius: 0.4rem;
		transition: all 0.2s ease;
	}

	.copy-btn:hover {
		color: var(--accent-regular);
		background: var(--gray-900);
	}

