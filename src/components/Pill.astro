---
interface Props {
	href?: string;
	target?: string;
	ariaLabel?: string;
	rel?: string;
}
const { href, target, ariaLabel, rel } = Astro.props as Props;
---
{href ? (
	<a class="pill" href={href} target={target} rel={rel} aria-label={ariaLabel}><slot /></a>
) : (
	<div class="pill" role="button"><slot /></div>
)}

<style>
	.pill {
		display: inline-flex;
		align-items: center;
		padding: 0.4rem 0.85rem;
		gap: 0.5rem;
		color: var(--accent-text-over);
		border: 1px solid color-mix(in oklab, var(--accent-regular), transparent 20%);
		background: linear-gradient(
			to bottom right,
			color-mix(in oklab, var(--accent-regular), black 6%),
			var(--accent-regular)
		);
		border-radius: var(--radius-full);
		font-size: var(--text-sm);
		font-weight: 550;
		line-height: 1.35;
		white-space: nowrap;
		text-decoration: none;
		box-shadow: var(--shadow-sm);
		transition: transform var(--theme-transition), box-shadow var(--theme-transition), background-color var(--theme-transition);
	}

	.pill :global(svg) {
		flex: 0 0 auto;
	}

	@media (min-width: 50em) {
		.pill {
			padding: 0.5rem 1rem;
			font-size: var(--text-md);
		}
	}

	.pill:hover {
		transform: translateY(-2px);
		box-shadow: var(--glow-accent);
	}

	.pill:focus-visible {
		outline: 2px solid color-mix(in oklab, var(--accent-regular), white 20%);
		outline-offset: 2px;
	}
</style>
