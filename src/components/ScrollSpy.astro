---
import Icon from './Icon.astro';

interface Section {
    id: string;
    label: string;
    icon: string;
}

const sections: Section[] = [
    { id: 'accueil', label: 'Accueil', icon: 'sun' },
    { id: 'solutions', label: 'Solutions', icon: 'magic-wand' },
    { id: 'projets', label: 'Projets', icon: 'rocket-launch' },
    { id: 'univers', label: 'Approche', icon: 'heart' },
    { id: 'formation', label: 'Formation', icon: 'strategy' },
    { id: 'faq', label: 'FAQ', icon: 'question' },
    { id: 'contact', label: 'Contact', icon: 'paper-plane-tilt' },
];
---

<nav class="scroll-spy" aria-label="Navigation rapide">
    <ul class="stack gap-4">
        {sections.map((section) => (
            <li>
                <a href={`#${section.id}`} class="spy-link" data-section={section.id}>
                    <span class="spy-label">{section.label}</span>
                    <span class="spy-dot"></span>
                </a>
            </li>
        ))}
    </ul>
</nav>

<div class="mobile-section-indicator" aria-hidden="true">
    <span class="current-section">Accueil</span>
</div>

<script>
    const observerOptions = {
        root: null,
        rootMargin: '-20% 0px -70% 0px',
        threshold: 0
    };

    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                const id = entry.target.id;
                document.querySelectorAll('.spy-link').forEach(link => {
                    const isActive = link.getAttribute('data-section') === id;
                    link.classList.toggle('active', isActive);
                    
                    if (isActive) {
                        const label = link.querySelector('.spy-label')?.textContent;
                        const mobileIndicator = document.querySelector('.mobile-section-indicator .current-section');
                        if (mobileIndicator && label) {
                            mobileIndicator.textContent = label;
                        }
                    }
                });
            }
        });
    }, observerOptions);

    document.querySelectorAll('section[id], header[id]').forEach(section => {
        observer.observe(section);
    });

    // Smooth scroll
    document.querySelectorAll('.spy-link').forEach(anchor => {
        anchor.addEventListener('click', function (e) {
            e.preventDefault();
            const targetId = anchor.getAttribute('href');
            const targetElement = targetId ? document.querySelector(targetId) : null;
            if (targetElement) {
                targetElement.scrollIntoView({
                    behavior: 'smooth'
                });
            }
        });
    });
</script>

<style>
    .scroll-spy {
        position: fixed;
        right: 2rem;
        top: 50%;
        transform: translateY(-50%);
        z-index: 100;
        display: none;
    }

    @media (min-width: 75em) {
        .scroll-spy {
            display: block;
        }
    }

    ul {
        list-style: none;
        padding: 0;
        margin: 0;
        align-items: flex-end;
    }

    .spy-link {
        display: flex;
        align-items: center;
        gap: 1rem;
        text-decoration: none;
        color: var(--gray-400);
        transition: all 0.3s ease;
    }

    .spy-label {
        font-size: var(--text-sm);
        font-weight: 500;
        opacity: 0;
        transform: translateX(10px);
        transition: all 0.3s ease;
        background: var(--gray-999_40);
        backdrop-filter: blur(4px);
        padding: 0.2rem 0.6rem;
        border-radius: 0.4rem;
        border: 1px solid var(--gray-800);
        white-space: nowrap;
    }

    .spy-dot {
        width: 10px;
        height: 10px;
        background: var(--gray-700);
        border-radius: 50%;
        transition: all 0.3s ease;
        border: 2px solid transparent;
    }

    .spy-link:hover .spy-label {
        opacity: 1;
        transform: translateX(0);
    }

    .spy-link:hover .spy-dot {
        background: var(--accent-regular);
        transform: scale(1.2);
    }

    .spy-link.active .spy-dot {
        background: var(--accent-regular);
        transform: scale(1.5);
        border-color: var(--accent-light);
        box-shadow: 0 0 10px var(--accent-overlay);
    }

    .spy-link.active .spy-label {
        color: var(--accent-regular);
        font-weight: 700;
    }

    /* Mobile Section Indicator */
    .mobile-section-indicator {
        position: fixed;
        top: 1rem;
        left: 50%;
        transform: translateX(-50%);
        z-index: 90;
        background: var(--gray-999_40);
        backdrop-filter: blur(8px);
        border: 1px solid var(--gray-800);
        padding: 0.4rem 1rem;
        border-radius: var(--radius-full);
        box-shadow: var(--shadow-sm);
        pointer-events: none;
        transition: opacity 0.3s ease;
        opacity: 0;
    }

    @media (max-width: 75em) {
        .mobile-section-indicator {
            opacity: 1;
        }
    }

    @media (max-width: 50em) {
        .mobile-section-indicator {
            top: auto;
            bottom: 1.5rem;
            left: 1.5rem;
            transform: none;
            padding: 0.3rem 0.8rem;
        }
    }

    .current-section {
        font-size: var(--text-xs);
        font-weight: 700;
        color: var(--accent-regular);
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
</style>
