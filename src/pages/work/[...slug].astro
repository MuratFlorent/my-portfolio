---
import { type CollectionEntry, getCollection, render } from 'astro:content';

import BaseLayout from '../../layouts/BaseLayout.astro';

import ContactCTA from '../../components/ContactCTA.astro';
import Hero from '../../components/Hero.astro';
import Icon from '../../components/Icon.astro';
import Pill from '../../components/Pill.astro';

interface Props {
	entry: CollectionEntry<'work'>;
}

// This is a dynamic route that generates a page for every Markdown file in src/content/
// Read more about dynamic routes and this `getStaticPaths` function in the Astro docs:
// https://docs.astro.build/en/core-concepts/routing/#dynamic-routes
export async function getStaticPaths() {
	const work = await getCollection('work');
	return work.map((entry) => ({
		params: { slug: entry.id },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout 
	title={entry.data.seoTitle || entry.data.title} 
	description={entry.data.seoDescription || entry.data.description}
>
	<div class="stack gap-20">
		<div class="stack gap-15">
			<header>
				<div class="wrapper stack gap-2">
					<a class="back-link" href="/work/"><Icon icon="arrow-left" /> Tous les projets</a>
					<Hero title={entry.data.title} align="start">
						<div class="details">
								<div class="tags">
									{entry.data.tags.map((t) => <Pill>{t}</Pill>)}
								</div>
							<p class="description">{entry.data.description}</p>
						</div>
					</Hero>
				</div>
			</header>
			<main class="wrapper">
				<div class="stack gap-10 content">
					<div class="project-info-grid">
						<div class="main-column stack gap-10">
							{entry.data.img && (
								<div class="hero-image-wrapper">
									<img src={entry.data.img} alt={entry.data.img_alt || ''} />
								</div>
							)}
							
							<div class="prose content">
								<Content />
							</div>

							{entry.data.gallery && entry.data.gallery.length > 0 && (
								<section class="gallery stack gap-4">
									<h2 class="section-title">Galerie du projet</h2>
									<div class="gallery-container">
										<div class="gallery-grid" id="project-gallery">
											{entry.data.gallery.map((image, index) => (
												<div class={`gallery-item ${index >= 3 ? 'hidden-item' : ''}`}>
													<img src={image} alt="Capture d'écran du projet" loading="lazy" />
												</div>
											))}
										</div>
										{entry.data.gallery.length > 3 && (
											<button id="show-more-gallery" class="show-more-button">
												Voir plus d'images ({entry.data.gallery.length - 3})
												<Icon icon="arrow-down" size="1.2em" />
											</button>
										)}
									</div>
								</section>
							)}
						</div>

						<aside class="sidebar stack gap-8">
							{entry.data.client && (
								<section class="sidebar-section">
									<h4>Client</h4>
									<p>{entry.data.client}</p>
								</section>
							)}

							{entry.data.year && (
								<section class="sidebar-section">
									<h4>Année</h4>
									<p>{entry.data.year}</p>
								</section>
							)}

							{entry.data.services && (
								<section class="sidebar-section">
									<h4>Services</h4>
									<ul class="sidebar-list">
										{entry.data.services.map(s => <li>{s}</li>)}
									</ul>
								</section>
							)}

							{entry.data.stack && (
								<section class="sidebar-section">
									<h4>Stack</h4>
									<div class="stack-tags">
										{entry.data.stack.map(s => <span class="stack-tag">{s}</span>)}
									</div>
								</section>
							)}

							{entry.data.highlights && (
								<section class="sidebar-section">
									<h4>Points clés</h4>
									<ul class="sidebar-list highlights">
										{entry.data.highlights.map(h => <li>{h}</li>)}
									</ul>
								</section>
							)}

							{entry.data.href && (
								<div class="sidebar-cta">
									<a href={entry.data.href} target="_blank" rel="noopener noreferrer" class="visit-link">
										Visiter le site
										<Icon icon="arrow-right" size="1.2em" />
									</a>
								</div>
							)}
						</aside>
					</div>
				</div>
			</main>
		</div>
		<ContactCTA />
	</div>
</BaseLayout>

<style>
	header {
		padding-bottom: 2.5rem;
		border-bottom: 1px solid var(--gray-800);
	}

	.back-link {
		display: none;
	}

	.details {
		display: flex;
		flex-direction: column;
		padding: 0.5rem;
		gap: 1.5rem;
		justify-content: space-between;
		align-items: center;
	}

	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		justify-content: center;
	}

	.description {
		font-size: var(--text-lg);
		max-width: 54ch;
	}

	.project-info-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 2rem;
	}

	.hero-image-wrapper img {
		width: 100%;
		border-radius: 1.5rem;
		box-shadow: var(--shadow-sm);
		border: 1px solid var(--gray-800);
	}

	.content {
		max-width: 65ch;
	}

	.prose :global(h2) {
		font-size: var(--text-2xl);
		margin-top: 2rem;
	}

	.section-title {
		font-size: var(--text-2xl);
	}

	.gallery-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
		gap: 1.5rem;
		transition: all 0.5s ease-in-out;
	}

	.gallery-item {
		transition: transform 0.3s ease, opacity 0.3s ease;
	}

	.gallery-item.hidden-item {
		display: none;
	}

	.gallery-item:hover {
		transform: scale(1.02);
		z-index: 2;
	}

	.gallery-container {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		align-items: center;
	}

	.show-more-button {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.75rem 1.5rem;
		background: var(--gray-800);
		color: var(--gray-200);
		border: 1px solid var(--gray-700);
		border-radius: 99rem;
		cursor: pointer;
		font-weight: 600;
		transition: all 0.2s ease;
	}

	.show-more-button:hover {
		background: var(--gray-700);
		color: var(--gray-0);
	}

	.gallery-item img {
		width: 100%;
		border-radius: 1rem;
		border: 1px solid var(--gray-800);
		aspect-ratio: 16 / 9;
		object-fit: cover;
	}

	.sidebar {
		background: var(--gray-999_40);
		padding: 1.5rem;
		border-radius: 1.5rem;
		border: 1px solid var(--gray-800);
		height: fit-content;
		width: 100%;
	}

	.sidebar-section h4 {
		font-size: var(--text-sm);
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--gray-400);
		margin-bottom: 0.5rem;
	}

	.sidebar-section p {
		font-size: var(--text-md);
		color: var(--gray-100);
	}

	.sidebar-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.sidebar-list li {
		color: var(--gray-100);
		margin-bottom: 0.25rem;
		font-size: var(--text-md);
	}

	.sidebar-list.highlights li::before {
		content: "•";
		color: var(--accent-regular);
		margin-right: 0.5rem;
	}

	.stack-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.stack-tag {
		background: var(--gray-800);
		color: var(--gray-200);
		padding: 0.2rem 0.6rem;
		border-radius: 0.5rem;
		font-size: var(--text-xs);
	}

	.visit-link {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		padding: 1rem;
		background: var(--accent-regular);
		color: white;
		text-decoration: none;
		border-radius: 0.75rem;
		font-weight: 700;
		transition: all var(--theme-transition);
	}

	.visit-link:hover {
		background: var(--accent-light);
		transform: translateY(-2px);
		box-shadow: var(--glow-accent);
	}

	@media (min-width: 50em) {
		.back-link {
			display: block;
			align-self: flex-start;
		}

		.details {
			flex-direction: row;
			gap: 2.5rem;
		}

		.tags {
			justify-content: flex-start;
		}

		.project-info-grid {
			grid-template-columns: 1.2fr 0.8fr;
			gap: 4rem;
		}

		.sidebar {
			padding: 2rem;
		}

		.gallery-grid:not(.expanded) .gallery-item:nth-child(n+4) {
			display: none;
		}

		.gallery-grid.expanded .gallery-item.hidden-item {
			display: block;
			animation: fadeIn 0.5s ease forwards;
		}
	}

	@keyframes fadeIn {
		from { opacity: 0; transform: translateY(10px); }
		to { opacity: 1; transform: translateY(0); }
	}
</style>

<script>
	const showMoreBtn = document.getElementById('show-more-gallery');
	const galleryGrid = document.getElementById('project-gallery');

	if (showMoreBtn && galleryGrid) {
		showMoreBtn.addEventListener('click', () => {
			const hiddenItems = galleryGrid.querySelectorAll('.hidden-item');
			const isExpanded = galleryGrid.classList.contains('expanded');

			if (!isExpanded) {
				hiddenItems.forEach(item => {
					(item as HTMLElement).style.display = 'block';
				});
				galleryGrid.classList.add('expanded');
				showMoreBtn.innerHTML = `Voir moins <svg viewBox="0 0 256 256" width="1.2em" height="1.2em" fill="currentColor"><path d="M216.49,168.49a12,12,0,0,1-17,0L128,97,56.49,168.49a12,12,0,0,1-17-17l80-80a12,12,0,0,1,17,0l80,80A12,12,0,0,1,216.49,168.49Z"></path></svg>`;
			} else {
				hiddenItems.forEach(item => {
					(item as HTMLElement).style.display = 'none';
				});
				galleryGrid.classList.remove('expanded');
				showMoreBtn.innerHTML = `Voir plus d'images (${hiddenItems.length}) <svg viewBox="0 0 256 256" width="1.2em" height="1.2em" fill="currentColor"><path d="M216.49,104.49l-80,80a12,12,0,0,1-17,0l-80-80a12,12,0,0,1,17-17L128,159l71.51-71.52a12,12,0,0,1,17,17Z"></path></svg>`;
			}
		});
	}
</script>
