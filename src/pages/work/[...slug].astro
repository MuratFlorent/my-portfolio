---
import { type CollectionEntry, getCollection, render } from 'astro:content';

import BaseLayout from '../../layouts/BaseLayout.astro';

import ContactCTA from '../../components/ContactCTA.astro';
import Hero from '../../components/Hero.astro';
import Icon from '../../components/Icon.astro';
import Pill from '../../components/Pill.astro';

interface Props {
	entry: CollectionEntry<'work'>;
}

// This is a dynamic route that generates a page for every Markdown file in src/content/
// Read more about dynamic routes and this `getStaticPaths` function in the Astro docs:
// https://docs.astro.build/en/core-concepts/routing/#dynamic-routes
export async function getStaticPaths() {
	const work = await getCollection('work');
	return work.map((entry) => ({
		params: { slug: entry.id },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const galleryData = entry.data.gallery?.map((item) => {
	if (typeof item === 'string') {
		return { src: item, alt: 'Vue du projet', label: '' };
	}
	return {
		src: item.src,
		alt: item.alt || 'Vue du projet',
		label: item.label || ''
	};
}) || [];
---

<BaseLayout 
	title={entry.data.seoTitle || entry.data.title} 
	description={entry.data.seoDescription || entry.data.description}
>
	<div class="stack gap-20">
		<div class="stack gap-15">
			<header>
				<div class="wrapper stack gap-2">
					<a class="back-link" href="/work/"><Icon icon="arrow-left" /> Tous les projets</a>
				</div>
			</header>
			<main class="wrapper">
				<div class="stack gap-10 content-grid-full">
					<div class="project-layout-grid">
						<div class="main-column stack gap-8">
							<Hero title={entry.data.title} align="start">
								<div class="details">
									<div class="tags">
										{entry.data.tags.map((t) => <Pill>{t}</Pill>)}
									</div>
									<p class="description">{entry.data.description}</p>
									{entry.data.href && (
										<div class="project-cta-wrapper">
											<a href={entry.data.href} target="_blank" rel="noopener noreferrer" class="project-external-link">
												<Icon icon="rocket-launch" size="1.2em" />
												Visiter le site web
											</a>
										</div>
									)}
								</div>
							</Hero>

							<div class="prose content">
								<Content />
							</div>

							{galleryData.length > 0 && (
								<section class="gallery stack gap-4">
									<div class="gallery-header">
										<h2 class="section-title">Aperçu du projet</h2>
										<p class="section-subtitle">Explorez les détails de l'interface et des fonctionnalités</p>
									</div>
									
									<div class="premium-gallery" id="premium-gallery">
										<div class="main-viewer">
											<div class="active-image-container">
												<div class="image-label" id="active-label">{galleryData[0].label}</div>
												<img 
													id="active-gallery-img" 
													src={galleryData[0].src} 
													alt={galleryData[0].alt} 
													class="active-img"
												/>
												<button class="expand-button" id="open-lightbox" aria-label="Agrandir l'image">
													<Icon icon="plus" size="1.5rem" />
												</button>
											</div>
										</div>

										<div class="thumbnails-container">
											<div class="thumbnails-grid">
												{galleryData.map((image, index) => (
													<button 
														class={`thumb-item ${index === 0 ? 'active' : ''}`}
														data-index={index}
														data-src={image.src}
														data-label={image.label}
														data-alt={image.alt}
														aria-label={`Voir ${image.label || 'l\'image ' + (index + 1)}`}
													>
														<img src={image.src} alt="" loading="lazy" />
														<span class="thumb-overlay"></span>
														{image.label && <span class="thumb-label">{image.label}</span>}
													</button>
												))}
											</div>
										</div>
									</div>

									{/* Lightbox Structure */}
									<div id="gallery-lightbox" class="lightbox" aria-hidden="true">
										<div class="lightbox-overlay"></div>
										<button class="lightbox-close" aria-label="Fermer la galerie">
											<Icon icon="x" size="2rem" />
										</button>
										
										<div class="lightbox-content">
											<button class="lightbox-nav prev" aria-label="Image précédente">
												<Icon icon="arrow-left" size="2rem" />
											</button>
											
											<div class="lightbox-image-wrapper">
												<img id="lightbox-img" src="" alt="Vue agrandie" />
												<div class="lightbox-info">
													<div class="lightbox-label" id="lightbox-label"></div>
													<div class="lightbox-caption" id="lightbox-caption"></div>
												</div>
											</div>
											
											<button class="lightbox-nav next" aria-label="Image suivante">
												<Icon icon="arrow-right" size="2rem" />
											</button>
										</div>

										<div class="lightbox-thumbnails">
											{galleryData.map((image, index) => (
												<button 
													class="lightbox-thumb" 
													data-index={index}
													data-src={image.src}
													data-label={image.label}
													data-alt={image.alt}
												>
													<img src={image.src} alt="" />
												</button>
											))}
										</div>
									</div>
								</section>
							)}
						</div>

						<aside class="sidebar-column stack gap-8">
							{entry.data.img && (
								<div class="hero-image-wrapper">
									<img src={entry.data.img} alt={entry.data.img_alt || ''} />
								</div>
							)}

							<div class="sidebar stack gap-8">
								<div class="sidebar-header">
									<h4>Méta Projet</h4>
								</div>
								
								<div class="sidebar-content-grid">
									{entry.data.client && (
										<section class="sidebar-section">
											<h4>Client</h4>
											<p>{entry.data.client}</p>
										</section>
									)}

									{entry.data.year && (
										<section class="sidebar-section">
											<h4>Année</h4>
											<p>{entry.data.year}</p>
										</section>
									)}
								</div>

								{entry.data.services && (
									<section class="sidebar-section">
										<h4>Services</h4>
										<ul class="sidebar-list">
											{entry.data.services.map(s => <li>{s}</li>)}
										</ul>
									</section>
								)}

								{entry.data.stack && (
									<section class="sidebar-section">
										<h4>Stack</h4>
										<div class="stack-tags">
											{entry.data.stack.map(s => <span class="stack-tag">{s}</span>)}
										</div>
									</section>
								)}

								{entry.data.highlights && (
									<section class="sidebar-section">
										<h4>Points clés</h4>
										<ul class="sidebar-list highlights">
											{entry.data.highlights.map(h => <li>{h}</li>)}
										</ul>
									</section>
								)}

								{entry.data.href && (
									<div class="sidebar-cta">
										<a href={entry.data.href} target="_blank" rel="noopener noreferrer" class="visit-link">
											Visiter le site
											<Icon icon="arrow-right" size="1.2em" />
										</a>
									</div>
								)}
							</div>
						</aside>
					</div>
				</div>
			</main>
		</div>
		<ContactCTA />
	</div>
</BaseLayout>

<style>
	header {
		padding-bottom: 1.5rem;
	}

	.project-cta-wrapper {
		margin-top: 1.5rem;
		display: flex;
	}

	.project-external-link {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.8rem 1.5rem;
		background: var(--accent-regular);
		color: white;
		border-radius: 999rem;
		text-decoration: none;
		font-weight: 600;
		transition: all 0.3s ease;
		box-shadow: 0 4px 15px rgba(var(--accent-regular-rgb), 0.3);
	}

	.project-external-link:hover {
		background: var(--accent-dark);
		transform: translateY(-2px);
		box-shadow: 0 6px 20px rgba(var(--accent-regular-rgb), 0.4);
	}

	.back-link {
		display: none;
	}

	.details {
		display: flex;
		flex-direction: column;
		padding: 0.5rem 0;
		gap: 1.5rem;
		align-items: flex-start;
		width: 100%;
	}

	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		width: 100%;
		justify-content: flex-start;
	}

	.description {
		font-size: var(--text-lg);
		max-width: 54ch;
		color: var(--gray-300);
	}

	.project-layout-grid {
		display: grid;
		grid-template-columns: minmax(0, 1fr);
		gap: 2rem;
		width: 100%;
		overflow: hidden;
	}

	.hero-image-wrapper img {
		width: 100%;
		border-radius: 1.5rem;
		box-shadow: var(--shadow-md);
		border: 1px solid var(--gray-800);
		object-fit: cover;
	}

	.content-grid-full {
		width: 100%;
	}

	.main-column {
		width: 100%;
	}

	.prose {
		line-height: 1.6;
		color: var(--gray-200);
	}

	.prose :global(h2) {
		font-size: var(--text-2xl);
		margin-top: 2.5rem;
		margin-bottom: 1rem;
		color: var(--gray-0);
	}

	.prose :global(img),
	.prose :global(video),
	.prose :global(iframe) {
		max-width: 100%;
		height: auto;
		border-radius: 1rem;
	}

	.prose :global(pre) {
		max-width: 100%;
		overflow-x: auto;
	}

	.section-title {
		font-size: var(--text-2xl);
		margin-bottom: 0.25rem;
	}

	.section-subtitle {
		font-size: var(--text-md);
		color: var(--gray-400);
		margin-bottom: 1.5rem;
	}

	/* Premium Gallery Styles */
	.premium-gallery {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.main-viewer {
		position: relative;
		width: 100%;
		border-radius: 1rem;
		overflow: hidden;
		background: var(--gray-999);
		border: 1px solid var(--gray-800);
		box-shadow: var(--shadow-lg);
		aspect-ratio: 4 / 3;
	}

	@media (min-width: 50em) {
		.main-viewer {
			border-radius: 1.5rem;
			aspect-ratio: 16 / 10;
		}
	}

	.active-image-container {
		width: 100%;
		height: 100%;
		position: relative;
		perspective: 1000px;
	}

	.image-label {
		position: absolute;
		top: 1.5rem;
		left: 1.5rem;
		background: var(--accent-regular);
		color: white;
		padding: 0.4rem 1rem;
		border-radius: 2rem;
		font-size: var(--text-xs);
		font-weight: 700;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		z-index: 10;
		box-shadow: 0 4px 12px rgba(var(--accent-regular-rgb), 0.3);
		backdrop-filter: blur(4px);
		border: 1px solid var(--accent-light);
		transition: all 0.3s ease;
	}

	.image-label:empty {
		display: none;
	}

	.active-img {
		width: 100%;
		height: 100%;
		object-fit: contain;
		display: block;
		transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
		transform: translateZ(0);
	}

	.main-viewer:hover .active-img {
		transform: scale(1.02) translateZ(20px);
	}

	.expand-button {
		position: absolute;
		bottom: 1.5rem;
		right: 1.5rem;
		background: rgba(var(--gray-999-rgb), 0.8);
		border: 1px solid var(--gray-800);
		color: var(--gray-200);
		width: 3.5rem;
		height: 3.5rem;
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		cursor: pointer;
		backdrop-filter: blur(8px);
		transition: all 0.3s ease;
		z-index: 10;
	}

	.expand-button:hover {
		background: var(--accent-regular);
		color: white;
		transform: scale(1.1);
		border-color: var(--accent-light);
	}

	.thumbnails-container {
		width: 100%;
		overflow-x: auto;
		padding: 0.5rem 0.5rem 1rem;
		scrollbar-width: thin;
		scrollbar-color: var(--accent-regular) transparent;
		-webkit-overflow-scrolling: touch;
		cursor: grab;
		max-width: 100%;
	}

	.thumbnails-container:active {
		cursor: grabbing;
	}

	.thumbnails-container::-webkit-scrollbar {
		height: 4px;
	}

	.thumbnails-container::-webkit-scrollbar-thumb {
		background: var(--accent-regular);
		border-radius: 4px;
	}

	.thumbnails-grid {
		display: flex;
		gap: 1rem;
		width: max-content;
	}

	.thumb-item {
		width: 100px;
		aspect-ratio: 16 / 9;
		border-radius: 0.5rem;
		overflow: hidden;
		border: 2px solid var(--gray-800);
		padding: 0;
		cursor: pointer;
		position: relative;
		transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
		background: var(--gray-999);
		flex-shrink: 0;
	}

	@media (min-width: 50em) {
		.thumb-item {
			width: 120px;
			border-radius: 0.75rem;
		}
	}

	.thumb-item img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.3s ease;
	}

	.thumb-overlay {
		position: absolute;
		inset: 0;
		background: rgba(0, 0, 0, 0.2);
		transition: opacity 0.3s ease;
		display: block;
	}

	.thumb-item:hover .thumb-overlay {
		opacity: 0;
	}

	.thumb-item:hover img {
		transform: scale(1.1);
	}

	.thumb-item.active {
		border-color: var(--accent-regular);
		box-shadow: 0 0 15px rgba(var(--accent-regular-rgb), 0.4);
	}

	.thumb-label {
		position: absolute;
		bottom: 0;
		left: 0;
		right: 0;
		background: linear-gradient(transparent, rgba(0,0,0,0.8));
		color: white;
		font-size: 10px;
		padding: 0.5rem 0.2rem 0.2rem;
		text-align: center;
		opacity: 0.8;
		transition: opacity 0.3s ease;
	}

	.thumb-item:hover .thumb-label {
		opacity: 1;
	}

	/* Lightbox Styles */
	.lightbox {
		position: fixed;
		inset: 0;
		z-index: 9999;
		display: none;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		padding: 1rem;
		opacity: 0;
		transition: opacity 0.3s ease;
	}

	@media (min-width: 50em) {
		.lightbox {
			padding: 2rem;
		}
	}

	.lightbox.open {
		display: flex;
		opacity: 1;
	}

	.lightbox-overlay {
		position: absolute;
		inset: 0;
		background: rgba(var(--gray-999-rgb), 0.95);
		backdrop-filter: blur(10px);
	}

	.lightbox-close {
		position: absolute;
		top: 1rem;
		right: 1rem;
		background: rgba(var(--gray-0-rgb), 0.5);
		border: none;
		color: white;
		width: 3rem;
		height: 3rem;
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		cursor: pointer;
		z-index: 10;
		transition: all 0.3s ease;
	}

	@media (min-width: 50em) {
		.lightbox-close {
			top: 2rem;
			right: 2rem;
			background: none;
			color: var(--gray-200);
			width: auto;
			height: auto;
		}
	}

	.lightbox-close:hover {
		color: var(--accent-regular);
	}

	.lightbox-content {
		position: relative;
		display: flex;
		align-items: center;
		justify-content: center;
		width: 100%;
		max-width: 1400px;
		height: 60vh;
		z-index: 5;
	}

	@media (min-width: 50em) {
		.lightbox-content {
			height: 70vh;
		}
	}

	.lightbox-image-wrapper {
		width: 100%;
		height: 100%;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 1rem;
	}

	.lightbox-image-wrapper img {
		max-width: 100%;
		max-height: 100%;
		object-fit: contain;
		box-shadow: var(--shadow-xl);
		border-radius: 0.5rem;
	}

	.lightbox-info {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.5rem;
		margin-top: 1rem;
		text-align: center;
	}

	.lightbox-label {
		background: var(--accent-regular);
		color: white;
		padding: 0.2rem 0.8rem;
		border-radius: 2rem;
		font-size: var(--text-xs);
		font-weight: 700;
		text-transform: uppercase;
	}

	.lightbox-label:empty {
		display: none;
	}

	.lightbox-caption {
		color: var(--gray-300);
		font-size: var(--text-md);
	}

	.lightbox-nav {
		background: rgba(var(--gray-800-rgb), 0.5);
		border: none;
		color: white;
		width: 3rem;
		height: 3rem;
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		cursor: pointer;
		transition: all 0.3s ease;
		margin: 0 0.5rem;
		flex-shrink: 0;
	}

	@media (min-width: 50em) {
		.lightbox-nav {
			width: 4rem;
			height: 4rem;
			margin: 0 1rem;
		}
	}

	.lightbox-nav:hover {
		background: var(--accent-regular);
		transform: scale(1.1);
	}

	.lightbox-thumbnails {
		display: flex;
		gap: 1rem;
		margin-top: 2rem;
		overflow-x: auto;
		max-width: 100%;
		padding: 1rem;
		z-index: 5;
		scrollbar-width: thin;
		scrollbar-color: var(--accent-regular) transparent;
		cursor: grab;
	}

	.lightbox-thumbnails::-webkit-scrollbar {
		height: 4px;
	}

	.lightbox-thumbnails::-webkit-scrollbar-thumb {
		background: var(--accent-regular);
		border-radius: 4px;
	}

	.lightbox-thumb {
		width: 80px;
		aspect-ratio: 16 / 9;
		border-radius: 0.5rem;
		overflow: hidden;
		border: 2px solid transparent;
		padding: 0;
		cursor: pointer;
		opacity: 0.5;
		transition: all 0.3s ease;
		flex-shrink: 0;
	}

	.lightbox-thumb.active {
		opacity: 1;
		border-color: var(--accent-regular);
	}

	.lightbox-thumb img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.sidebar-column {
		width: 100%;
	}

	.sidebar {
		background: var(--gray-999_40);
		padding: 1.5rem;
		border-radius: 1.5rem;
		border: 1px solid var(--gray-800);
		height: fit-content;
		width: 100%;
		box-sizing: border-box;
	}

	@media (min-width: 50em) {
		.sidebar {
			padding: 2rem;
		}
	}

	@media (min-width: 64em) {
		.sidebar {
			position: sticky;
			top: 2rem;
		}
	}

	.sidebar-header {
		padding-bottom: 1rem;
		border-bottom: 1px solid var(--gray-800);
		margin-bottom: 1rem;
	}

	.sidebar-header h4 {
		font-size: var(--text-md);
		color: var(--gray-0);
		font-weight: 700;
	}

	.sidebar-content-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1.5rem;
	}

	@media (min-width: 30em) {
		.sidebar-content-grid {
			grid-template-columns: 1fr 1fr;
		}
	}

	.sidebar-section h4 {
		font-size: var(--text-xs);
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: var(--gray-500);
		margin-bottom: 0.5rem;
		font-weight: 600;
	}

	.sidebar-section p {
		font-size: var(--text-md);
		color: var(--gray-100);
		font-weight: 500;
	}

	.sidebar-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.sidebar-list li {
		color: var(--gray-200);
		margin-bottom: 0.4rem;
		font-size: var(--text-md);
	}

	.sidebar-list.highlights li::before {
		content: "→";
		color: var(--accent-regular);
		margin-right: 0.6rem;
		font-weight: bold;
	}

	.stack-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
	}

	.stack-tag {
		background: var(--gray-800);
		color: var(--gray-100);
		padding: 0.3rem 0.8rem;
		border-radius: 0.5rem;
		font-size: var(--text-xs);
		border: 1px solid var(--gray-700);
	}

	.visit-link {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.75rem;
		padding: 1rem 1.5rem;
		background: var(--accent-regular);
		color: white;
		text-decoration: none;
		border-radius: 1rem;
		font-weight: 700;
		transition: all 0.3s ease;
		box-shadow: 0 4px 12px rgba(var(--accent-regular-rgb), 0.3);
	}

	.visit-link:hover {
		background: var(--accent-light);
		transform: translateY(-3px);
		box-shadow: 0 6px 20px rgba(var(--accent-regular-rgb), 0.4);
	}

	@media (min-width: 64em) {
		.back-link {
			display: block;
			margin-bottom: 2rem;
		}

		.project-layout-grid {
			grid-template-columns: minmax(0, 1fr) 400px;
			gap: 5rem;
			align-items: start;
		}

		.hero-image-wrapper {
			margin-bottom: 2rem;
		}

		.sidebar-content-grid {
			grid-template-columns: 1fr;
		}
	}

	@media (min-width: 80em) {
		.project-layout-grid {
			grid-template-columns: minmax(0, 1fr) 480px;
			gap: 8rem;
		}
	}

	@media (max-width: 50em) {
		.sidebar-content-grid {
			grid-template-columns: 1fr;
		}

		.project-layout-grid {
			gap: 2rem;
		}

		.main-column {
			gap: 2rem;
			width: 100%;
			max-width: 100%;
		}

		.wrapper {
			padding-inline: 1rem;
			overflow-x: hidden;
		}
	}

	@keyframes fadeIn {
		from { opacity: 0; transform: translateY(10px); }
		to { opacity: 1; transform: translateY(0); }
	}
</style>

<script>
	function initGallery() {
		const activeImg = document.getElementById('active-gallery-img') as HTMLImageElement;
		const activeLabel = document.getElementById('active-label');
		const thumbButtons = document.querySelectorAll('.thumb-item');
		const openLightboxBtn = document.getElementById('open-lightbox');
		const lightbox = document.getElementById('gallery-lightbox');
		const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
		const lightboxClose = document.querySelector('.lightbox-close');
		const lightboxPrev = document.querySelector('.lightbox-nav.prev');
		const lightboxNext = document.querySelector('.lightbox-nav.next');
		const lightboxThumbs = document.querySelectorAll('.lightbox-thumb');
		const lightboxCaption = document.getElementById('lightbox-caption');
		const lightboxLabel = document.getElementById('lightbox-label');

		if (!activeImg || thumbButtons.length === 0) return;

		let currentIndex = 0;
		const images = Array.from(thumbButtons).map(btn => ({
			src: (btn as HTMLElement).dataset.src || '',
			label: (btn as HTMLElement).dataset.label || '',
			alt: (btn as HTMLElement).dataset.alt || ''
		}));

		// Switch active image
		function setActiveImage(index: number) {
			currentIndex = index;
			const item = images[index];
			if (!item) return;

			activeImg.style.opacity = '0';
			if (activeLabel) activeLabel.style.opacity = '0';

			setTimeout(() => {
				activeImg.src = item.src;
				activeImg.alt = item.alt;
				activeImg.style.opacity = '1';
				
				if (activeLabel) {
					activeLabel.textContent = item.label;
					activeLabel.style.opacity = item.label ? '1' : '0';
				}
			}, 200);

			thumbButtons.forEach((btn, i) => {
				if (i === index) {
					btn.classList.add('active');
					btn.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
				}
				else btn.classList.remove('active');
			});

			updateLightbox(index);
		}

		thumbButtons.forEach((btn, index) => {
			btn.addEventListener('click', () => setActiveImage(index));
		});

		// Lightbox logic
		function openLightbox(index: number) {
			if (!lightbox) return;
			updateLightbox(index);
			lightbox.classList.add('open');
			document.body.style.overflow = 'hidden';
			
			// Set focus for accessibility
			setTimeout(() => (lightbox as HTMLElement).focus(), 100);
		}

		function closeLightbox() {
			if (!lightbox) return;
			lightbox.classList.remove('open');
			document.body.style.overflow = '';
		}

		function updateLightbox(index: number) {
			currentIndex = index;
			const item = images[index];
			if (!item) return;

			if (lightboxImg) {
				lightboxImg.src = item.src;
				lightboxImg.alt = item.alt;
			}
			if (lightboxLabel) {
				lightboxLabel.textContent = item.label;
			}
			if (lightboxCaption) {
				lightboxCaption.textContent = `Image ${index + 1} sur ${images.length}`;
			}
			lightboxThumbs.forEach((thumb, i) => {
				if (i === index) {
					thumb.classList.add('active');
					thumb.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
				} else {
					thumb.classList.remove('active');
				}
			});
		}

		openLightboxBtn?.addEventListener('click', () => openLightbox(currentIndex));
		lightboxClose?.addEventListener('click', closeLightbox);
		
		lightboxPrev?.addEventListener('click', () => {
			const newIndex = (currentIndex - 1 + images.length) % images.length;
			updateLightbox(newIndex);
		});

		lightboxNext?.addEventListener('click', () => {
			const newIndex = (currentIndex + 1) % images.length;
			updateLightbox(newIndex);
		});

		lightboxThumbs.forEach((thumb, index) => {
			thumb.addEventListener('click', () => updateLightbox(index));
		});

		// Close on overlay click
		lightbox?.querySelector('.lightbox-overlay')?.addEventListener('click', closeLightbox);

		// Drag scroll for thumbnails
		const scrollContainers = document.querySelectorAll('.thumbnails-container, .lightbox-thumbnails');
		scrollContainers.forEach(container => {
			let isDown = false;
			let startX: number;
			let scrollLeft: number;

			container.addEventListener('mousedown', (e) => {
				isDown = true;
				container.classList.add('active');
				startX = (e as MouseEvent).pageX - (container as HTMLElement).offsetLeft;
				scrollLeft = (container as HTMLElement).scrollLeft;
			});
			container.addEventListener('mouseleave', () => {
				isDown = false;
			});
			container.addEventListener('mouseup', () => {
				isDown = false;
			});
			container.addEventListener('mousemove', (e) => {
				if(!isDown) return;
				e.preventDefault();
				const x = (e as MouseEvent).pageX - (container as HTMLElement).offsetLeft;
				const walk = (x - startX) * 2;
				(container as HTMLElement).scrollLeft = scrollLeft - walk;
			});
		});

		// Keyboard navigation
		document.addEventListener('keydown', (e) => {
			if (!lightbox?.classList.contains('open')) return;
			
			if (e.key === 'Escape') closeLightbox();
			if (e.key === 'ArrowLeft') lightboxPrev?.dispatchEvent(new Event('click'));
			if (e.key === 'ArrowRight') lightboxNext?.dispatchEvent(new Event('click'));
		});

		// Mobile Touch Support for Lightbox
		let touchStartX = 0;
		let touchEndX = 0;

		lightbox?.addEventListener('touchstart', (e) => {
			touchStartX = (e as TouchEvent).changedTouches[0].screenX;
		}, { passive: true });

		lightbox?.addEventListener('touchend', (e) => {
			touchEndX = (e as TouchEvent).changedTouches[0].screenX;
			handleSwipe();
		}, { passive: true });

		function handleSwipe() {
			const threshold = 50;
			if (touchEndX < touchStartX - threshold) {
				lightboxNext?.dispatchEvent(new Event('click'));
			}
			if (touchEndX > touchStartX + threshold) {
				lightboxPrev?.dispatchEvent(new Event('click'));
			}
		}
	}

	// Initialize on page load
	initGallery();

	// Support for view transitions
	document.addEventListener('astro:after-swap', initGallery);
</script>
