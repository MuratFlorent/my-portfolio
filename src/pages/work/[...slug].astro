---
import { type CollectionEntry, getCollection, render } from 'astro:content';

import BaseLayout from '../../layouts/BaseLayout.astro';

import ContactCTA from '../../components/ContactCTA.astro';
import Hero from '../../components/Hero.astro';
import Icon from '../../components/Icon.astro';
import Pill from '../../components/Pill.astro';

interface Props {
	entry: CollectionEntry<'work'>;
}

// This is a dynamic route that generates a page for every Markdown file in src/content/
// Read more about dynamic routes and this `getStaticPaths` function in the Astro docs:
// https://docs.astro.build/en/core-concepts/routing/#dynamic-routes
export async function getStaticPaths() {
	const work = await getCollection('work');
	return work.map((entry) => ({
		params: { slug: entry.id },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout 
	title={entry.data.seoTitle || entry.data.title} 
	description={entry.data.seoDescription || entry.data.description}
>
	<div class="stack gap-20">
		<div class="stack gap-15">
			<header>
				<div class="wrapper stack gap-2">
					<a class="back-link" href="/work/"><Icon icon="arrow-left" /> Tous les projets</a>
				</div>
			</header>
			<main class="wrapper">
				<div class="stack gap-10 content-grid-full">
					<div class="project-layout-grid">
						<div class="main-column stack gap-8">
							<Hero title={entry.data.title} align="start">
								<div class="details">
									<div class="tags">
										{entry.data.tags.map((t) => <Pill>{t}</Pill>)}
									</div>
									<p class="description">{entry.data.description}</p>
								</div>
							</Hero>

							<div class="prose content">
								<Content />
							</div>

							{entry.data.gallery && entry.data.gallery.length > 0 && (
								<section class="gallery stack gap-4">
									<h2 class="section-title">Galerie du projet</h2>
									<div class="gallery-container">
										<div class="gallery-grid" id="project-gallery">
											{entry.data.gallery.map((image, index) => (
												<div class={`gallery-item ${index >= 3 ? 'hidden-item' : ''}`}>
													<img src={image} alt="Capture d'écran du projet" loading="lazy" />
												</div>
											))}
										</div>
										{entry.data.gallery.length > 3 && (
											<button id="show-more-gallery" class="show-more-button">
												Voir plus d'images ({entry.data.gallery.length - 3})
												<Icon icon="arrow-down" size="1.2em" />
											</button>
										)}
									</div>
								</section>
							)}
						</div>

						<aside class="sidebar-column stack gap-8">
							{entry.data.img && (
								<div class="hero-image-wrapper">
									<img src={entry.data.img} alt={entry.data.img_alt || ''} />
								</div>
							)}

							<div class="sidebar stack gap-8">
								<div class="sidebar-header">
									<h4>Méta Projet</h4>
								</div>
								
								<div class="sidebar-content-grid">
									{entry.data.client && (
										<section class="sidebar-section">
											<h4>Client</h4>
											<p>{entry.data.client}</p>
										</section>
									)}

									{entry.data.year && (
										<section class="sidebar-section">
											<h4>Année</h4>
											<p>{entry.data.year}</p>
										</section>
									)}
								</div>

								{entry.data.services && (
									<section class="sidebar-section">
										<h4>Services</h4>
										<ul class="sidebar-list">
											{entry.data.services.map(s => <li>{s}</li>)}
										</ul>
									</section>
								)}

								{entry.data.stack && (
									<section class="sidebar-section">
										<h4>Stack</h4>
										<div class="stack-tags">
											{entry.data.stack.map(s => <span class="stack-tag">{s}</span>)}
										</div>
									</section>
								)}

								{entry.data.highlights && (
									<section class="sidebar-section">
										<h4>Points clés</h4>
										<ul class="sidebar-list highlights">
											{entry.data.highlights.map(h => <li>{h}</li>)}
										</ul>
									</section>
								)}

								{entry.data.href && (
									<div class="sidebar-cta">
										<a href={entry.data.href} target="_blank" rel="noopener noreferrer" class="visit-link">
											Visiter le site
											<Icon icon="arrow-right" size="1.2em" />
										</a>
									</div>
								)}
							</div>
						</aside>
					</div>
				</div>
			</main>
		</div>
		<ContactCTA />
	</div>
</BaseLayout>

<style>
	header {
		padding-bottom: 1.5rem;
	}

	.back-link {
		display: none;
	}

	.details {
		display: flex;
		flex-direction: column;
		padding: 0.5rem 0;
		gap: 1.5rem;
		align-items: flex-start;
	}

	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.description {
		font-size: var(--text-lg);
		max-width: 54ch;
		color: var(--gray-300);
	}

	.project-layout-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 3rem;
	}

	.hero-image-wrapper img {
		width: 100%;
		border-radius: 1.5rem;
		box-shadow: var(--shadow-md);
		border: 1px solid var(--gray-800);
		object-fit: cover;
	}

	.content-grid-full {
		width: 100%;
	}

	.main-column {
		width: 100%;
	}

	.prose {
		line-height: 1.6;
		color: var(--gray-200);
	}

	.prose :global(h2) {
		font-size: var(--text-2xl);
		margin-top: 2.5rem;
		margin-bottom: 1rem;
		color: var(--gray-0);
	}

	.prose :global(p) {
		margin-bottom: 1.5rem;
	}

	.section-title {
		font-size: var(--text-2xl);
		margin-bottom: 1rem;
	}

	.gallery-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: 1.5rem;
	}

	.gallery-item img {
		width: 100%;
		border-radius: 1rem;
		border: 1px solid var(--gray-800);
		aspect-ratio: 16 / 9;
		object-fit: cover;
		transition: transform 0.3s ease;
	}

	.gallery-item:hover img {
		transform: scale(1.02);
	}

	.sidebar-column {
		width: 100%;
	}

	.sidebar {
		background: var(--gray-999_40);
		padding: 2rem;
		border-radius: 1.5rem;
		border: 1px solid var(--gray-800);
		height: fit-content;
		position: sticky;
		top: 2rem;
	}

	.sidebar-header {
		padding-bottom: 1rem;
		border-bottom: 1px solid var(--gray-800);
		margin-bottom: 1rem;
	}

	.sidebar-header h4 {
		font-size: var(--text-md);
		color: var(--gray-0);
		font-weight: 700;
	}

	.sidebar-content-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1.5rem;
	}

	.sidebar-section h4 {
		font-size: var(--text-xs);
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: var(--gray-500);
		margin-bottom: 0.5rem;
		font-weight: 600;
	}

	.sidebar-section p {
		font-size: var(--text-md);
		color: var(--gray-100);
		font-weight: 500;
	}

	.sidebar-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.sidebar-list li {
		color: var(--gray-200);
		margin-bottom: 0.4rem;
		font-size: var(--text-md);
	}

	.sidebar-list.highlights li::before {
		content: "→";
		color: var(--accent-regular);
		margin-right: 0.6rem;
		font-weight: bold;
	}

	.stack-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
	}

	.stack-tag {
		background: var(--gray-800);
		color: var(--gray-100);
		padding: 0.3rem 0.8rem;
		border-radius: 0.5rem;
		font-size: var(--text-xs);
		border: 1px solid var(--gray-700);
	}

	.visit-link {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.75rem;
		padding: 1rem 1.5rem;
		background: var(--accent-regular);
		color: white;
		text-decoration: none;
		border-radius: 1rem;
		font-weight: 700;
		transition: all 0.3s ease;
		box-shadow: 0 4px 12px rgba(var(--accent-regular-rgb), 0.3);
	}

	.visit-link:hover {
		background: var(--accent-light);
		transform: translateY(-3px);
		box-shadow: 0 6px 20px rgba(var(--accent-regular-rgb), 0.4);
	}

	@media (min-width: 64em) {
		.back-link {
			display: block;
			margin-bottom: 2rem;
		}

		.project-layout-grid {
			grid-template-columns: 1fr 400px;
			gap: 5rem;
			align-items: start;
		}

		.hero-image-wrapper {
			margin-bottom: 2rem;
		}

		.sidebar-content-grid {
			grid-template-columns: 1fr;
		}
	}

	@media (min-width: 80em) {
		.project-layout-grid {
			grid-template-columns: 1fr 480px;
			gap: 8rem;
		}
	}

	@media (max-width: 50em) {
		.sidebar-content-grid {
			grid-template-columns: 1fr 1fr;
		}
	}

	@keyframes fadeIn {
		from { opacity: 0; transform: translateY(10px); }
		to { opacity: 1; transform: translateY(0); }
	}
</style>

<script>
	const showMoreBtn = document.getElementById('show-more-gallery');
	const galleryGrid = document.getElementById('project-gallery');

	if (showMoreBtn && galleryGrid) {
		showMoreBtn.addEventListener('click', () => {
			const hiddenItems = galleryGrid.querySelectorAll('.hidden-item');
			const isExpanded = galleryGrid.classList.contains('expanded');

			if (!isExpanded) {
				hiddenItems.forEach(item => {
					(item as HTMLElement).style.display = 'block';
				});
				galleryGrid.classList.add('expanded');
				showMoreBtn.innerHTML = `Voir moins <svg viewBox="0 0 256 256" width="1.2em" height="1.2em" fill="currentColor"><path d="M216.49,168.49a12,12,0,0,1-17,0L128,97,56.49,168.49a12,12,0,0,1-17-17l80-80a12,12,0,0,1,17,0l80,80A12,12,0,0,1,216.49,168.49Z"></path></svg>`;
			} else {
				hiddenItems.forEach(item => {
					(item as HTMLElement).style.display = 'none';
				});
				galleryGrid.classList.remove('expanded');
				showMoreBtn.innerHTML = `Voir plus d'images (${hiddenItems.length}) <svg viewBox="0 0 256 256" width="1.2em" height="1.2em" fill="currentColor"><path d="M216.49,104.49l-80,80a12,12,0,0,1-17,0l-80-80a12,12,0,0,1,17-17L128,159l71.51-71.52a12,12,0,0,1,17,17Z"></path></svg>`;
			}
		});
	}
</script>
