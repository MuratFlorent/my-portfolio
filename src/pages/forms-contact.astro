---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Formulaire de contact">
    <div class="wrapper">
        <h1>Formulaire de contact (Détection Netlify)</h1>
        <p>Cette page est utilisée pour permettre à Netlify de détecter le formulaire de contact rapide présent dans les modales.</p>

        <!-- Formulaire Contact Rapide -->
        <form 
            name="contact-rapide" 
            method="POST" 
            data-netlify="true" 
            data-netlify-recaptcha="true"
            data-netlify-honeypot="bot-field"
            action="/merci"
        >
            <input type="hidden" name="form-name" value="contact-rapide" />
            <p class="hidden">
                <label>Ne pas remplir si vous êtes humain : <input name="bot-field" /></label>
            </p>
            <label for="name-contact">Nom</label>
            <input type="text" name="name" id="name-contact" />
            <label for="email-contact">Email</label>
            <input type="email" name="email" id="email-contact" />
            <label for="activity-contact">Activité</label>
            <input type="text" name="activity" id="activity-contact" />
            <label for="message-contact">Message</label>
            <textarea name="message" id="message-contact"></textarea>
            <input type="hidden" name="source" />
            <div data-netlify-recaptcha="true"></div>
        </form>
    </div>
</BaseLayout>

<style>
    .wrapper {
        padding: 5rem 2rem;
        max-width: 800px;
        margin: 0 auto;
    }
    form {
        display: none;
    }
</style>
