---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactCTA from '../components/ContactCTA.astro';
import Hero from '../components/Hero.astro';
import Icon from '../components/Icon.astro';
import CallToAction from '../components/CallToAction.astro';
---

<BaseLayout
	title="Formation & Accompagnement | Florent Murat"
	description="Apprenez à maîtriser votre projet digital (WordPress, SEO, Design Intuitif) tout en le construisant. Formations éligibles CPF et OPCO."
>
	<div class="stack gap-20 lg:gap-48">
		<main class="wrapper stack gap-20">
			<header class="hero">
				<Hero
					title="Formez-vous sur votre propre projet"
					tagline="Une approche concrète pour monter en compétences tout en faisant avancer votre solution digitale."
					align="start"
				>
					<div class="details">
						<p>
							La formation n'est pas qu'une question de théorie. C'est un levier pour votre autonomie. 
							En partenariat avec le centre de formation <strong>AFI</strong>, je vous accompagne dans l'apprentissage 
							des outils qui feront le succès de votre présence en ligne.
						</p>
					</div>
				</Hero>
				<img
					alt="Florent Murat en session de formation"
					width="480"
					height="620"
					src="/assets/letItBe/eveil_et_science.jpeg"
				/>
			</header>

			<section class="section program bg-variant">
				<header class="section-header stack gap-2 lg:gap-4 centered">
					<div class="badge-accent mx-auto">Le Programme</div>
					<h2>WordPress, SEO et Design Intuitif</h2>
					<p class="max-w-2xl mx-auto">Un cursus complet et modulable selon vos besoins réels, certifié Qualiopi via AFI.</p>
				</header>

				<div class="grid">
					<div class="card stack gap-4">
						<Icon icon="code" color="var(--accent-regular)" size="2.5rem" gradient />
						<h3>Maîtrise de WordPress</h3>
						<p>De l'installation à la gestion avancée des contenus et des extensions. Apprenez à structurer votre site proprement.</p>
					</div>
					<div class="card stack gap-4">
						<Icon icon="rocket-launch" color="var(--accent-regular)" size="2.5rem" gradient />
						<h3>Stratégie SEO</h3>
						<p>Comprendre comment les moteurs de recherche fonctionnent pour positionner durablement votre projet.</p>
					</div>
					<div class="card stack gap-4">
						<Icon icon="magic-wand" color="var(--accent-regular)" size="2.5rem" gradient />
						<h3>Design Intuitif (UX/UI)</h3>
						<p>Penser l'expérience utilisateur pour rendre votre interface claire, accessible et efficace.</p>
					</div>
				</div>
			</section>

			<section class="section funding">
				<div class="funding-container stack gap-8">
					<div class="funding-content stack gap-4">
						<h2>Un financement simplifié</h2>
						<p>
							Grâce à la certification Qualiopi de notre partenaire <strong>AFI</strong>, votre formation peut être 
							prise en charge intégralement ou partiellement par :
						</p>
						<ul class="funding-list stack gap-2">
							<li><Icon icon="check" size="1.2em" color="var(--accent-regular)" /> Le Compte Personnel de Formation (CPF)</li>
							<li><Icon icon="check" size="1.2em" color="var(--accent-regular)" /> Votre OPCO (salariés et indépendants)</li>
							<li><Icon icon="check" size="1.2em" color="var(--accent-regular)" /> Pôle Emploi (AIF)</li>
						</ul>
						<p class="note">
							Nous vous accompagnons dans le montage de votre dossier administratif pour que vous n'ayez 
							qu'à vous concentrer sur votre apprentissage.
						</p>
					</div>
					<div class="cta-center centered">
						<CallToAction href="#contact">
							Vérifier mon éligibilité
							<Icon icon="paper-plane-tilt" size="1.2em" />
						</CallToAction>
					</div>
				</div>
			</section>
		</main>

		<ContactCTA id="contact" />
	</div>
</BaseLayout>

<style>
	.hero {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 2rem;
	}

	.details {
		max-width: 50ch;
		font-size: var(--text-lg);
		color: var(--gray-300);
	}

	.details strong {
		color: var(--accent-regular);
	}

	.hero img {
		aspect-ratio: 5 / 4;
		object-fit: cover;
		object-position: top;
		border-radius: 1.5rem;
		box-shadow: var(--shadow-md);
	}

	@media (min-width: 50em) {
		.hero {
			display: grid;
			grid-template-columns: 6fr 4fr;
			padding-inline: 2.5rem;
			gap: 3.75rem;
		}

		.hero img {
			aspect-ratio: 3 / 4;
			border-radius: 4.5rem;
		}
	}

	.section-header.centered {
		text-align: center;
		margin-inline: auto;
	}

	.grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 2rem;
	}

	@media (min-width: 50em) {
		.grid {
			grid-template-columns: repeat(3, 1fr);
		}
	}

	.card {
		padding: 2.5rem;
		background: var(--gray-999_40);
		border: 1px solid var(--gray-800);
		border-radius: 1.5rem;
		backdrop-filter: blur(10px);
	}

	.card h3 {
		font-size: var(--text-xl);
		color: var(--gray-0);
	}

	.card p {
		color: var(--gray-300);
	}

	.funding-container {
		padding: 3rem;
		background: var(--gradient-subtle);
		border-radius: 2.5rem;
		border: 1px solid var(--gray-800);
	}

	.funding-list {
		list-style: none;
		padding: 0;
	}

	.funding-list li {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		font-weight: 600;
		color: var(--gray-100);
	}

	.note {
		font-style: italic;
		font-size: var(--text-sm);
		color: var(--gray-400);
	}

	.centered {
		text-align: center;
	}

	.mx-auto {
		margin-inline: auto;
	}

	.max-w-2xl {
		max-width: 65ch;
	}

	.bg-variant {
		background: var(--gradient-subtle);
		margin-inline: calc(-1 * var(--padding-inline, 1.5rem));
		padding-inline: var(--padding-inline, 1.5rem);
		padding-block: 5rem;
	}

	@media (min-width: 50em) {
		.bg-variant {
			padding-block: 8rem;
			border-radius: 3rem;
			margin-inline: 0;
		}
	}
</style>
