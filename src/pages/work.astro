---
import { getCollection } from 'astro:content';

import BaseLayout from '../layouts/BaseLayout.astro';

import ContactCTA from '../components/ContactCTA.astro';
import PortfolioPreview from '../components/PortfolioPreview.astro';
import ReferenceCard from '../components/ReferenceCard.astro';
import Hero from '../components/Hero.astro';
import Grid from '../components/Grid.astro';
import ProjectModal from '../components/ProjectModal.astro';

const projects = (await getCollection('work'))
	.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
	.filter((project) => project.data.img.includes('/assets/projects/'));

const extraReferences = [
	{
		title: 'HelloRSE',
		role: 'Développeur Full Stack',
		period: '2022 - 2023',
		tags: ['Symfony', 'Sylius', 'DevOps', 'E-commerce'],
		description: 'Développement et maintenance d’une plateforme e-commerce sous Sylius / Symfony, avec mise en place d’outils DevOps, CI/CD, GitLab, Ansible et participation à un environnement technique orienté performance et déploiement.',
		image: '/assets/hello-rse.jpg'
	},
	{
		title: 'Famileo',
		role: 'Développeur Full Stack',
		period: '2020 - 2022',
		tags: ['Symfony', 'Sylius', 'International', 'E-commerce'],
		description: 'Développement et évolution d’une boutique en ligne sous Symfony / Sylius, gestion des comptes utilisateurs et accompagnement du déploiement international dans un contexte produit structuré.',
		image: '/assets/VIGNETTE_FAMILEO.png'
	},
	{
		title: 'Tediber',
		role: 'Développeur back-end Symfony / Sylius',
		period: '2018 - 2020',
		tags: ['Symfony', 'Sylius', 'ERP', 'Logistique'],
		description: 'Création et migration d’un ERP logistique sous Symfony vers Sylius, avec développement de solutions e-commerce et gestion des commandes dans un cadre exigeant et orienté métier.',
		image: '/assets/logo-tediber.jpg'
	}
];

const collaborations = [
	{
		title: 'Vibressence',
		activity: 'Sonothérapie',
		tags: ['Wix', 'CSS', 'JS'],
		description: 'Refonte de la page d’accueil, amélioration du menu sticky, travail de design custom, optimisation SEO / GEO et accompagnement sur la visibilité et le référencement.',
		image: '/assets/collab/Vibressence.png'
	},
	{
		title: 'Atelier Arbre Bleu',
		activity: 'Architecte paysagiste',
		tags: ['Statamic', 'SEO', 'Refresh UX'],
		description: 'Refonte ciblée de certaines pages, optimisation SEO, rafraîchissement global et nettoyage du projet pour améliorer la lisibilité et la présentation du site.',
		image: '/assets/collab/atelier_arbre_bleu.png'
	}
];

const extraDetails = {
	'HelloRSE': "Dans le cadre de mon expérience chez HelloRSE, j'ai travaillé sur une plateforme e-commerce complexe basée sur Sylius. Mes missions incluaient le développement de nouvelles fonctionnalités back-end et front-end, l'optimisation des performances, et la mise en place de processus de déploiement continu avec GitLab CI et Ansible. J'ai également participé à la maintenance évolutive de la plateforme pour répondre aux besoins spécifiques du marché de la RSE.",
	'Famileo': "Chez Famileo, j'ai intégré une équipe produit dynamique pour faire évoluer une boutique en ligne à fort trafic. Utilisant Symfony et Sylius, j'ai contribué au développement de fonctionnalités liées à la gestion des abonnements, au tunnel d'achat et à l'internationalisation du service. Le défi majeur était de maintenir une qualité de code élevée tout en assurant une livraison rapide de nouvelles fonctionnalités pour soutenir la croissance de l'entreprise.",
	'Tediber': "Mon passage chez Tediber a été marqué par la migration d'un ERP interne vers une solution plus robuste basée sur Sylius. J'ai conçu des modules sur mesure pour la gestion des stocks, la logistique et le suivi des commandes. Cette expérience m'a permis d'approfondir mes connaissances sur les processus métier e-commerce et sur l'architecture des systèmes d'information complexes.",
	'Vibressence': "Pour Vibressence, l'enjeu était de moderniser l'image de marque tout en conservant la simplicité de gestion de Wix. J'ai injecté du code personnalisé (Velo by Wix) pour améliorer l'expérience utilisateur, notamment sur le menu et la page d'accueil. Un travail approfondi sur le SEO local a été réalisé pour attirer une clientèle de proximité intéressée par la sonothérapie.",
	'Atelier Arbre Bleu': "L'accompagnement de l'Atelier Arbre Bleu a porté sur la refonte de sections clés du site sous Statamic. L'objectif était de valoriser les projets de l'architecte paysagiste par une mise en page plus aérée et visuelle. J'ai également optimisé la structure technique du site pour un meilleur référencement naturel sur des mots-clés liés à l'aménagement paysager."
};
---

<BaseLayout
	title="Réalisations & Portfolio | Light Developer"
	description="Découvrez les projets web sur mesure, l'optimisation SEO et les automatisations réalisés par Florent Murat (Light Developer)."
>
	<ProjectModal id="project-modal" />
	<div class="stack gap-20">
		<main class="wrapper stack gap-8">
			<Hero
				title="Mes projets"
				tagline="Je vous présente quelques-unes de mes créations, mes expériences en tant que développeur, les projets auxquels j'ai participé..."
				align="start"
			/>
			<Grid variant="offset">
				{
					projects.map((project) => (
						<li>
							<PortfolioPreview project={project} />	
						</li>
					))
				}
			</Grid>

			<section class="section references">
				<header class="section-header stack gap-4 lg:align-start">
					<div class="badge-accent">Expériences salariées</div>
					<h2 class="lg:text-left">Références complémentaires</h2>
					<p class="max-w-2xl lg:text-left">
						Quelques expériences marquantes en environnement produit, e-commerce et développement full stack.
					</p>
				</header>

				<div class="gallery">
					<Grid variant="small">
						{
							extraReferences.map((ref) => (
								<li>
									<ReferenceCard 
										title={ref.title}
										image={ref.image}
										period={ref.period}
										role={ref.role}
										description={ref.description}
										tags={ref.tags}
										details={extraDetails[ref.title as keyof typeof extraDetails]}
									/>
								</li>
							))
						}
					</Grid>
				</div>
			</section>

			<section class="section collaborations">
				<header class="section-header stack gap-4 lg:align-start">
					<div class="badge-accent">Accompagnements</div>
					<h2 class="lg:text-left">Autres collaborations</h2>
					<p class="max-w-2xl lg:text-left">
						Quelques interventions ciblées en refonte, optimisation et accompagnement digital.
					</p>
				</header>

				<div class="gallery">
					<Grid variant="small">
						{
							collaborations.map((collab) => (
								<li>
									<ReferenceCard 
										title={collab.title}
										image={collab.image}
										period={collab.activity}
										role=""
										description={collab.description}
										tags={collab.tags}
										details={extraDetails[collab.title as keyof typeof extraDetails]}
									/>
								</li>
							))
						}
					</Grid>
				</div>
				<div class="more-collaborations">
					<span class="dots">...</span>
					<p>
						Et bien d'autres interventions non répertoriées ici, où j'ai pu apporter mon expertise pour répondre à divers besoins digitaux et techniques.
					</p>
				</div>
			</section>
		</main>
		<ContactCTA />
	</div>
</BaseLayout>

<style>
	.section {
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	.section-header {
		text-align: center;
		max-width: 50rem;
		font-size: var(--text-md);
		color: var(--gray-300);
		margin-inline: auto;
	}

	.badge-accent {
		display: inline-block;
		padding: 0.4rem 1rem;
		background: var(--accent-subtle-overlay);
		color: var(--accent-regular);
		border-radius: var(--radius-full);
		font-size: var(--text-sm);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		width: fit-content;
		margin: 1.5rem auto 0.75rem auto;
	}

	h2 {
		font-size: var(--text-2xl);
		color: var(--gray-0);
	}

	.more-collaborations {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.5rem;
		margin-top: 1rem;
		text-align: center;
	}

	.more-collaborations .dots {
		font-size: var(--text-4xl);
		line-height: 1;
		color: var(--accent-regular);
		font-weight: bold;
		letter-spacing: 0.2em;
	}

	.more-collaborations p {
		color: var(--gray-400);
		font-size: var(--text-sm);
		font-style: italic;
		max-width: 600px;
	}

	@media (min-width: 50em) {
		.section {
			gap: 3rem;
		}

		.section-header {
			margin-inline: 0;
			text-align: left;
			align-items: flex-start;
		}

		.badge-accent {
			margin: 1.5rem 0 0.75rem 0;
		}

		h2 {
			font-size: var(--text-4xl);
		}
	}

	.references .gallery {
		margin-top: 1rem;
	}

	.references li {
		list-style: none;
	}

	@media (min-width: 50em) {
		.references {
			margin-top: 4rem;
		}
	}
</style>
