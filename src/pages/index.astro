---
import { getCollection } from 'astro:content';

// Layout import — provides basic page elements: <head>, <nav>, <footer> etc.
import BaseLayout from '../layouts/BaseLayout.astro';

// Component Imports
import CallToAction from '../components/CallToAction.astro';
import Grid from '../components/Grid.astro';
import Hero from '../components/Hero.astro';
import Icon from '../components/Icon.astro';
import Pill from '../components/Pill.astro';
import PortfolioPreview from '../components/PortfolioPreview.astro';
import ProjectModal from '../components/ProjectModal.astro';
import ScrollSpy from '../components/ScrollSpy.astro';
import Testimonials from '../components/Testimonials.astro';

// Page section components
import ContactCTA from '../components/ContactCTA.astro';
import Skills from '../components/Skills.astro';

// Content Fetching: List four most recent work projects
const projects = (await getCollection('work'))
	.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
	.slice(0, 6);

// Full Astro Component Syntax:
// https://docs.astro.build/core-concepts/astro-components/
---

<BaseLayout>
	<ProjectModal id="project-modal" />
	<ProjectModal id="universe-modal" />
	<ScrollSpy />
	<div class="stack gap-20 lg:gap-48">
		<div class="wrapper stack gap-8 lg:gap-20">
			<header id="accueil" class="hero">
				<Hero
					title="Développement web sur mesure, SEO et automatisation"
					tagline="Des solutions digitales adaptées à votre projet. Une approche humaine, claire et pensée selon vos besoins réels."
					align="start"
				>
					<div class="roles">
						<Pill href="/about" ariaLabel="Découvrir mon approche">
							<Icon icon="terminal-window" size="1.33em" /> Développeur web
						</Pill>
						<Pill href="#formation" ariaLabel="Voir la section formation">
							<Icon icon="pencil-line" size="1.33em" /> Formateur
						</Pill>
						<Pill href="#contact" ariaLabel="Parler de votre projet">
							<Icon icon="users-three" size="1.33em" /> Accompagnement sur mesure
						</Pill>
						<Pill href="https://wa.me/?text=Bonjour%20Florent%2C%20j%27aimerais%20parler%20de%20mon%20projet." target="_blank" rel="noopener" ariaLabel="Discuter sur WhatsApp">
							<Icon icon="whatsapp-logo" size="1.33em" /> WhatsApp dispo
						</Pill>
					</div>

					<div class="hero-ctas">
						<CallToAction href="/work/">
							Mes projets
							<Icon icon="arrow-right" size="1.2em" />
						</CallToAction>
						<CallToAction href="mailto:murat.light.developer@gmail.com">
							Me contacter
							<Icon icon="paper-plane-tilt" size="1.2em" />
						</CallToAction>
					</div>
				</Hero>

				<div class="hero-image-container">
					<img
						alt="Florent Murat Light Developer, pour accompagner avec bienveillance vos projets web"
						width="480"
						height="620"
						src="/assets/portrait2.jpeg"
					/>
					<div class="image-overlay">
						<p class="overlay-title">Florent Murat — Light Developer</p>
						<p class="overlay-text">Développeur web, formateur et accompagnant de projets sur mesure.</p>
					</div>
				</div>

			</header>

			<section id="solutions" class="section solutions bg-variant">
				<header class="section-header stack gap-2 lg:gap-4">
					<h3>Solutions personnalisées</h3>
					<p>Que vous ayez besoin d'une présence en ligne complète ou d'un outil métier spécifique, je conçois des solutions adaptées à vos enjeux.</p>
				</header>

				<div class="gallery">
					<Grid variant="small">
						<li class="service-card">
							<Icon icon="code" color="var(--accent-regular)" size="2.5rem" gradient />
							<h4>Sites & refontes</h4>
							<p>Développement de sites vitrines et applicatifs modernes, optimisés et sur mesure.</p>
						</li>
						<li class="service-card">
							<Icon icon="cpu" color="var(--accent-regular)" size="2.5rem" gradient />
							<h4>Plugins & modules</h4>
							<p>Extension des fonctionnalités de vos outils existants (WordPress, Sylius, etc.).</p>
						</li>
						<li class="service-card">
							<Icon icon="magic-wand" color="var(--accent-regular)" size="2.5rem" gradient />
							<h4>Automatisations</h4>
							<p>Gain de productivité via des scripts et outils connectés pour vos processus métier.</p>
						</li>
						<li class="service-card">
							<Icon icon="rocket-launch" color="var(--accent-regular)" size="2.5rem" gradient />
							<h4>SEO & Performance</h4>
							<p>Optimisation technique pour un référencement naturel durable et une rapidité exemplaire.</p>
						</li>
						<li class="service-card">
							<Icon icon="strategy" color="var(--accent-regular)" size="2.5rem" gradient />
							<h4>Formation</h4>
							<p>Transmission de savoir-faire technique pour monter en compétence en toute autonomie.</p>
						</li>
						<li class="service-card">
							<Icon icon="users-three" color="var(--accent-regular)" size="2.5rem" gradient />
							<h4>Accompagnement</h4>
							<p>Conseil stratégique et suivi humain tout au long de la vie de votre projet digital.</p>
						</li>
					</Grid>
				</div>
			</section>

			<main class="wrapper stack gap-20 lg:gap-48">
				<section id="projets" class="section projects with-cta">
					<header class="section-header stack gap-2 lg:gap-4">
						<h3>Mes projets, ma vie...</h3>
						<p>Une sélection de mes réalisations les plus marquantes, alliant expertise technique et approche humaine.</p>
					</header>

					<div class="gallery">
						<Grid variant="offset">
							{
								projects.map((project) => (
									<li>
										<PortfolioPreview project={project} />
									</li>
								))
							}
						</Grid>
					</div>

					<div class="cta">
						<CallToAction href="/work/">
							Découvrir
							<Icon icon="arrow-right" size="1.2em" />
						</CallToAction>
					</div>
				</section>

				<section id="univers" class="section with-background bg-variant universe">
					<header class="section-header stack gap-2 lg:gap-4">
						<h3>Mon univers</h3>
						<p>Découvrez les piliers et les outils qui animent ma démarche de Light Developer.</p>
					</header>

					<div class="gallery">
						<Grid variant="small">
							{
								[
									{ id: 'bienveillance', label: 'Bienveillance', icon: 'heart', description: 'Une approche humaine centrée sur l’écoute et l’empathie.' },
									{ id: 'technique', label: 'Rigueur technique', icon: 'code', description: 'Un code propre, maintenable et performant.' },
									{ id: 'clarté', label: 'Clarté', icon: 'sun', description: 'Apporter de la lumière et de la transparence sur chaque projet.' },
									{ id: 'transmission', label: 'Transmission', icon: 'strategy', description: 'Partager le savoir pour favoriser l’autonomie.' },
									{ id: 'outillage', label: 'Outillage', icon: 'terminal', description: 'Maîtrise des outils modernes pour une efficacité maximale.' },
									{ id: 'cloud', label: 'Cloud & DevOps', icon: 'cloud', description: 'Infrastructure solide et déploiements automatisés.' },
									{ id: 'whatsapp', label: 'WhatsApp', icon: 'whatsapp-logo', description: 'Un canal direct et fluide pour échanger sur vos besoins.' },
									{ id: 'conscience', label: 'Conscience', icon: 'eye', description: 'Une présence attentive à chaque étape du développement.' },
									{ id: 'automatisation', label: 'Automatisation', icon: 'magic-wand', description: 'Optimiser les processus pour libérer du temps créatif.' },
								].map((item) => (
									<li class="universe-item" data-universe-id={item.id} data-universe-data={JSON.stringify(item)}>
										<div class="universe-card">
											<Icon icon={item.icon as any} color="var(--accent-regular)" size="2.5rem" gradient />
											<p>{item.label}</p>
											<div class="universe-tooltip">{item.description}</div>
										</div>
									</li>
								))
							}
						</Grid>
					</div>

					<div class="cta">
						<button class="explore-universe-btn" id="open-universe-modal">
							Explorer mon univers complet
							<Icon icon="arrow-right" size="1.2em" />
						</button>
					</div>
				</section>

				<Testimonials />

				<section id="formation" class="section formation-premium bg-variant">
					<div class="formation-container stack gap-8 lg:gap-12">
						<header class="formation-header stack gap-4">
							<div class="badge-accent">Formation & Accompagnement</div>
							<h3>Financez votre projet tout en montant en compétences</h3>
							<p class="intro-text">
								En collaboration avec notre centre de formation partenaire, 
								débloquez vos crédits de formation (CPF, OPCO) pour construire votre projet 
								digital tout en apprenant à le maîtriser de A à Z.
							</p>
						</header>

						<div class="formation-content-grid">
							<div class="formation-image">
								<img
									alt="Florent Murat - Formation et transmission de savoir-faire"
									src="/assets/letItBe/eveil_et_science.jpeg" 
									loading="lazy" 
									decoding="async" 
								/>
								<div class="image-caption">
									<Icon icon="strategy" size="1.2em" />
									<span>Apprentissage concret sur votre propre projet</span>
								</div>
							</div>

							<div class="formation-details stack gap-6">
								<div class="benefit-item stack gap-2">
									<h4><Icon icon="rocket-launch" size="1.2em" gradient /> Autonomie réelle</h4>
									<p>Ne soyez plus dépendant de prestataires pour chaque petite modification. Apprenez à gérer votre interface en toute confiance.</p>
								</div>
								<div class="benefit-item stack gap-2">
									<h4><Icon icon="code" size="1.2em" gradient /> Expertise sur mesure</h4>
									<p>WordPress, SEO, structuration de données ou automatisation : le programme s'adapte à vos besoins réels et à votre niveau.</p>
								</div>
								<div class="benefit-item stack gap-2">
									<h4><Icon icon="heart" size="1.2em" gradient /> Financement facilité</h4>
									<p>Bénéficiez d'un accompagnement pour les démarches administratives liées au financement de votre formation.</p>
								</div>

								<div class="cta-wrapper">
									<CallToAction href="mailto:murat.light.developer@gmail.com">
										En savoir plus sur la formation
										<Icon icon="arrow-right" size="1.2em" />
									</CallToAction>
								</div>
							</div>
						</div>
					</div>
				</section>
			</main>
		</div>
		<ContactCTA id="contact" />
	</div>
</BaseLayout>

<script>
	// Logic for Universe Modal
	const openUniverseBtn = document.getElementById('open-universe-modal');
	const universeModal = document.getElementById('universe-modal') as HTMLDialogElement;

	if (openUniverseBtn && universeModal) {
		openUniverseBtn.addEventListener('click', () => {
			const modalTitle = universeModal.querySelector('.modal-title');
			const modalDescription = universeModal.querySelector('.modal-description');
			const modalSolution = universeModal.querySelector('.modal-solution-content');
			const modalImageWrapper = universeModal.querySelector('.image-wrapper');
			const modalHeader = universeModal.querySelector('.modal-header');

			if (modalTitle) modalTitle.textContent = "Mon Univers Complet";
			if (modalDescription) modalDescription.textContent = "Un aperçu détaillé de mes outils, de ma philosophie et de mes passions.";
			
			if (modalSolution) {
				modalSolution.innerHTML = `
					<div class="stack gap-4">
						<p>En tant que <strong>Light Developer</strong>, mon approche repose sur trois piliers : la Technique, la Bienveillance et la Clarté.</p>
						<p>Je combine l'excellence technique (PHP, Symfony, Astro) avec une écoute profonde des besoins humains pour créer des solutions qui ont du sens.</p>
						<ul class="stack gap-2">
							<li><strong>Développement :</strong> WordPress, Sylius, Symfony, Astro.</li>
							<li><strong>Mindset :</strong> Écoute, clarté, transmission, présence.</li>
							<li><strong>Outils :</strong> Terminal, Linux, Docker, Cloud.</li>
						</ul>
					</div>
				`;
			}

			// Masquer l'image pour le modal univers ou mettre une image par défaut
			if (modalImageWrapper) (modalImageWrapper as HTMLElement).style.display = 'none';
			if (modalHeader) (modalHeader as HTMLElement).style.setProperty('grid-template-columns', '1fr');

			universeModal.showModal();
		});
	}
</script>

<style>
	.hero {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 3rem;
	}

	.roles {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		justify-content: center;
	}

	.hero-ctas {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
		justify-content: center;
		margin-top: 1rem;
	}

	.hero-image-container {
		position: relative;
		overflow: hidden;
		border-radius: var(--radius-md);
		box-shadow: var(--shadow-md);
		transition: transform var(--theme-transition-slow), box-shadow var(--theme-transition);
	}

	.hero-image-container:hover {
		transform: scale(1.02);
		box-shadow: var(--glow-accent);
	}

	.hero-image-container img {
		display: block;
		width: 100%;
		height: auto;
		aspect-ratio: 5 / 4;
		object-fit: cover;
		object-position: center;
		transition: transform var(--theme-transition-slow);
	}

	.hero-image-container:hover img {
		transform: scale(1.05);
	}

	.image-overlay {
		position: absolute;
		inset: 0;
		display: flex;
		flex-direction: column;
		justify-content: flex-end;
		padding: 2.5rem;
		background: linear-gradient(to top, rgba(0, 0, 0, 0.8) 0%, transparent 60%);
		opacity: 0;
		transition: opacity var(--theme-transition);
		color: white;
		pointer-events: none;
	}

	.hero-image-container:hover .image-overlay {
		opacity: 1;
	}

	.overlay-title {
		font-size: var(--text-lg);
		font-weight: bold;
		margin-bottom: 0.25rem;
		transform: translateY(10px);
		transition: transform var(--theme-transition-slow);
	}

	.hero-image-container:hover .overlay-title {
		transform: translateY(0);
	}

	.overlay-text {
		font-size: var(--text-sm);
		opacity: 0.9;
		line-height: 1.4;
		transform: translateY(10px);
		transition: transform var(--theme-transition-slow) 0.1s;
	}

	.hero-image-container:hover .overlay-text {
		transform: translateY(0);
	}

	.img-center {
		margin:1.5rem 0;
	}

	.img-center img {
		width: 120rem;
	}

	p.formation {
		padding: 1.2rem;
	}

	@media (min-width: 50em) {
		.hero {
			display: grid;
			grid-template-columns: 6fr 4fr;
			padding-inline: 1.5rem;
			gap: 3rem;
			align-items: center;
		}

		.roles {
			margin-top: 0.5rem;
			justify-content: flex-start;
		}

		.hero-ctas {
			justify-content: flex-start;
		}

		.hero-image-container {
			border-radius: 3rem;
		}

		.hero-image-container img {
			aspect-ratio: 3 / 4;
		}
	}

	@media (min-width: 80em) {
		.hero {
			padding-inline: 2.5rem;
			gap: 5rem;
		}

		.hero-image-container {
			border-radius: 4.5rem;
		}
	}
	@media (max-width: 50em) {
		.formation h4{
			max-width: 20ch;
			font-size: var(--text-xl);
		}

		.formation p{
			max-width: 31ch;
		}

		.formation img{
			max-width: 18rem;
 		   padding-right: 1em;;
		}
	}

	.service-card {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		padding: 2.5rem;
		background: var(--gray-999);
		border: 1px solid var(--gray-800);
		border-radius: var(--radius-md);
		box-shadow: var(--shadow-sm);
		transition: transform var(--theme-transition), 
					box-shadow var(--theme-transition), 
					border-color var(--theme-transition);
		gap: 1.5rem;
		height: 100%;
	}

	.service-card:hover {
		transform: translateY(-8px);
		box-shadow: var(--glow-accent);
		border-color: var(--accent-regular);
	}

	.service-card:focus-within {
		outline: 3px solid var(--accent-regular);
		outline-offset: 4px;
	}

	.service-card h4 {
		font-size: var(--text-lg);
		color: var(--gray-0);
	}

	.service-card p {
		font-size: var(--text-sm);
		color: var(--gray-300);
		line-height: 1.5;
	}

	/* Univers section specific styles */
	.universe-card {
		position: relative;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		padding: 2.5rem;
		background: var(--gray-999);
		border: 1px solid var(--gray-800);
		border-radius: var(--radius-md);
		transition: transform var(--theme-transition), 
					box-shadow var(--theme-transition), 
					border-color var(--theme-transition);
		gap: 1rem;
		height: 100%;
		cursor: help;
	}

	.universe-card:hover {
		transform: translateY(-5px);
		box-shadow: var(--glow-accent);
		border-color: var(--accent-regular);
	}

	.universe-card p {
		margin-top: 0.75rem;
		font-weight: 600;
		color: var(--gray-0);
		font-size: var(--text-sm);
	}

	@media (min-width: 50em) {
		.universe-card p {
			font-size: var(--text-md);
		}
	}

	.universe-tooltip {
		position: absolute;
		bottom: calc(100% + 15px);
		left: 50%;
		transform: translateX(-50%) translateY(10px);
		width: 220px;
		padding: 1rem;
		background: var(--gray-0);
		color: var(--gray-999);
		border-radius: var(--radius-sm);
		font-size: var(--text-sm);
		text-align: center;
		opacity: 0;
		visibility: hidden;
		transition: opacity 0.3s ease, transform 0.3s ease, visibility 0.3s;
		box-shadow: var(--shadow-lg);
		z-index: 10;
		pointer-events: none;
	}

	.universe-tooltip::after {
		content: '';
		position: absolute;
		top: 100%;
		left: 50%;
		transform: translateX(-50%);
		border: 8px solid transparent;
		border-top-color: var(--gray-0);
	}

	.universe-card:hover .universe-tooltip {
		opacity: 1;
		visibility: visible;
		transform: translateX(-50%) translateY(0);
	}

	.explore-universe-btn {
		display: flex;
		align-items: center;
		gap: 0.8rem;
		padding: 0.8rem 2rem;
		background: transparent;
		color: var(--accent-regular);
		border: 2px solid var(--accent-regular);
		border-radius: var(--radius-full);
		font-size: var(--text-md);
		font-weight: bold;
		cursor: pointer;
		transition: all var(--theme-transition);
		margin: 2rem auto 0;
	}

	@media (min-width: 50em) {
		.explore-universe-btn {
			padding: 1.2rem 2.5rem;
			font-size: var(--text-lg);
		}
	}

	.explore-universe-btn:hover {
		background: var(--accent-regular);
		color: white;
		box-shadow: var(--glow-accent);
		transform: translateY(-2px);
	}

	.explore-universe-btn:focus-visible {
		outline: 3px solid var(--accent-regular);
		outline-offset: 4px;
	}

	.service-card p {
		font-size: var(--text-sm);
		color: var(--gray-300);
		line-height: 1.5;
	}

	.solutions {
		margin-top: 2rem;
	}

	@media (min-width: 50em) {
		.solutions {
			margin-top: 0;
		}
	}

	/* ====================================================== */

	.section {
		display: grid;
		gap: 2rem;
	}

	.with-background {
		position: relative;
	}

	.with-background::before {
		--hero-bg: var(--bg-image-subtle-2);

		content: '';
		position: absolute;
		pointer-events: none;
		left: 50%;
		width: 100vw;
		aspect-ratio: calc(2.25 / var(--bg-scale));
		top: 0;
		transform: translateY(-75%) translateX(-50%);
		background:
			url('/assets/backgrounds/noise.png') top center/220px repeat,
			var(--hero-bg) center center / var(--bg-gradient-size) no-repeat,
			var(--gray-999);
		background-blend-mode: overlay, normal, normal, normal;
		mix-blend-mode: var(--bg-blend-mode);
		z-index: -1;
	}

	.with-background.bg-variant::before {
		--hero-bg: var(--bg-image-subtle-1);
	}

	.section-header p {
		font-size: var(--text-md);
		color: var(--gray-300);
		max-width: 65ch;
		margin-inline: auto;
	}

	.section-header {
		text-align: center;
	}

	@media (min-width: 50em) {
		.section-header p {
			font-size: var(--text-lg);
		}
	}

	.section-header h3 {
		font-size: var(--text-2xl);
		margin-bottom: 0.5rem;
		line-height: 1.2;
		letter-spacing: -0.01em;
	}

	@media (min-width: 50em) {
		.section {
			grid-template-columns: repeat(4, 1fr);
			grid-template-areas: 'header header header header' 'gallery gallery gallery gallery';
			gap: 5rem;
		}

		.section.with-cta {
			grid-template-areas: 'header header header cta' 'gallery gallery gallery gallery';
		}

		.section-header {
			grid-area: header;
			justify-self: center;
			text-align: center;
		}

		.section-header h3 {
			font-size: var(--text-3xl);
		}

		.with-cta .section-header {
			justify-self: center;
			text-align: center;
		}

		.gallery {
			grid-area: gallery;
		}

		.cta {
			grid-area: cta;
			align-self: center;
			justify-self: flex-end;
		}
	}

	@media (min-width: 80em) {
		.section-header h3 {
			font-size: var(--text-4xl);
		}
	}

	/* ====================================================== */

	.mention-card {
		display: flex;
		height: 7rem;
		justify-content: center;
