---
import { getCollection } from 'astro:content';

// Layout import — provides basic page elements: <head>, <nav>, <footer> etc.
import BaseLayout from '../layouts/BaseLayout.astro';

// Component Imports
import CallToAction from '../components/CallToAction.astro';
import Grid from '../components/Grid.astro';
import Hero from '../components/Hero.astro';
import Icon from '../components/Icon.astro';
import Pill from '../components/Pill.astro';
import PortfolioPreview from '../components/PortfolioPreview.astro';
import ProjectModal from '../components/ProjectModal.astro';
import ScrollSpy from '../components/ScrollSpy.astro';

// Page section components
import ContactCTA from '../components/ContactCTA.astro';
import Skills from '../components/Skills.astro';

// Content Fetching: List four most recent work projects
const projects = (await getCollection('work'))
	.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
	.slice(0, 6);

// Full Astro Component Syntax:
// https://docs.astro.build/core-concepts/astro-components/
---

<BaseLayout>
	<ProjectModal id="project-modal" />
	<ProjectModal id="universe-modal" />
	<ScrollSpy />
	<div class="stack gap-20 lg:gap-48">
		<div class="wrapper stack gap-8 lg:gap-20">
			<header id="accueil" class="hero">
				<Hero
					title="Développement web sur mesure, SEO et automatisation"
					tagline="Des solutions digitales adaptées à votre projet. Une approche humaine, claire et pensée selon vos besoins réels."
					align="start"
				>
					<div class="roles">
						<Pill><Icon icon="code" size="1.33em" /> Développeur web</Pill>
						<Pill><Icon icon="strategy" size="1.33em" /> Formateur</Pill>
						<Pill><Icon icon="heart" size="1.33em" /> Accompagnement sur mesure</Pill>
					</div>

					<div class="hero-ctas">
						<CallToAction href="/work/">
							Mes projets
							<Icon icon="arrow-right" size="1.2em" />
						</CallToAction>
						<CallToAction href="mailto:murat.light.developer@gmail.com">
							Me contacter
							<Icon icon="paper-plane-tilt" size="1.2em" />
						</CallToAction>
					</div>
				</Hero>

				<div class="hero-image-container">
					<img
						alt="Florent Murat Light Developer, pour accompagner avec bienveillance vos projets web"
						width="480"
						height="620"
						src="/assets/portrait2.jpeg"
					/>
					<div class="image-overlay">
						<p class="overlay-title">Florent Murat — Light Developer</p>
						<p class="overlay-text">Développeur web, formateur et accompagnant de projets sur mesure.</p>
					</div>
				</div>

			</header>

			<section id="solutions" class="section solutions bg-variant">
				<header class="section-header stack gap-2 lg:gap-4">
					<h3>Solutions personnalisées</h3>
					<p>Que vous ayez besoin d'une présence en ligne complète ou d'un outil métier spécifique, je conçois des solutions adaptées à vos enjeux.</p>
				</header>

				<div class="gallery">
					<Grid variant="small">
						<li class="service-card">
							<Icon icon="code" color="var(--accent-regular)" size="2.5rem" gradient />
							<h4>Sites & refontes</h4>
							<p>Développement de sites vitrines et applicatifs modernes, optimisés et sur mesure.</p>
						</li>
						<li class="service-card">
							<Icon icon="cpu" color="var(--accent-regular)" size="2.5rem" gradient />
							<h4>Plugins & modules</h4>
							<p>Extension des fonctionnalités de vos outils existants (WordPress, Sylius, etc.).</p>
						</li>
						<li class="service-card">
							<Icon icon="magic-wand" color="var(--accent-regular)" size="2.5rem" gradient />
							<h4>Automatisations</h4>
							<p>Gain de productivité via des scripts et outils connectés pour vos processus métier.</p>
						</li>
						<li class="service-card">
							<Icon icon="rocket-launch" color="var(--accent-regular)" size="2.5rem" gradient />
							<h4>SEO & Performance</h4>
							<p>Optimisation technique pour un référencement naturel durable et une rapidité exemplaire.</p>
						</li>
						<li class="service-card">
							<Icon icon="strategy" color="var(--accent-regular)" size="2.5rem" gradient />
							<h4>Formation</h4>
							<p>Transmission de savoir-faire technique pour monter en compétence en toute autonomie.</p>
						</li>
						<li class="service-card">
							<Icon icon="users-three" color="var(--accent-regular)" size="2.5rem" gradient />
							<h4>Accompagnement</h4>
							<p>Conseil stratégique et suivi humain tout au long de la vie de votre projet digital.</p>
						</li>
					</Grid>
				</div>
			</section>

			<main class="wrapper stack gap-20 lg:gap-48">
				<section id="projets" class="section projects with-cta">
					<header class="section-header stack gap-2 lg:gap-4">
						<h3>Mes projets, ma vie...</h3>
						<p>Une sélection de mes réalisations les plus marquantes, alliant expertise technique et approche humaine.</p>
					</header>

					<div class="gallery">
						<Grid variant="offset">
							{
								projects.map((project) => (
									<li>
										<PortfolioPreview project={project} />
									</li>
								))
							}
						</Grid>
					</div>

					<div class="cta">
						<CallToAction href="/work/">
							Découvrir
							<Icon icon="arrow-right" size="1.2em" />
						</CallToAction>
					</div>
				</section>

				<section id="univers" class="section with-background bg-variant universe">
					<header class="section-header stack gap-2 lg:gap-4">
						<h3>Mon univers</h3>
						<p>Découvrez les piliers et les outils qui animent ma démarche de Light Developer.</p>
					</header>

					<div class="gallery">
						<Grid variant="small">
							{
								[
									{ id: 'bienveillance', label: 'Bienveillance', icon: 'heart', description: 'Une approche humaine centrée sur l’écoute et l’empathie.' },
									{ id: 'technique', label: 'Rigueur technique', icon: 'code', description: 'Un code propre, maintenable et performant.' },
									{ id: 'clarté', label: 'Clarté', icon: 'sun', description: 'Apporter de la lumière et de la transparence sur chaque projet.' },
									{ id: 'transmission', label: 'Transmission', icon: 'strategy', description: 'Partager le savoir pour favoriser l’autonomie.' },
									{ id: 'outillage', label: 'Outillage', icon: 'terminal', description: 'Maîtrise des outils modernes pour une efficacité maximale.' },
									{ id: 'cloud', label: 'Cloud & DevOps', icon: 'cloud', description: 'Infrastructure solide et déploiements automatisés.' },
									{ id: 'conscience', label: 'Conscience', icon: 'eye', description: 'Une présence attentive à chaque étape du développement.' },
									{ id: 'automatisation', label: 'Automatisation', icon: 'magic-wand', description: 'Optimiser les processus pour libérer du temps créatif.' },
								].map((item) => (
									<li class="universe-item" data-universe-id={item.id} data-universe-data={JSON.stringify(item)}>
										<div class="universe-card">
											<Icon icon={item.icon as any} color="var(--accent-regular)" size="2.5rem" gradient />
											<p>{item.label}</p>
											<div class="universe-tooltip">{item.description}</div>
										</div>
									</li>
								))
							}
						</Grid>
					</div>

					<div class="cta">
						<button class="explore-universe-btn" id="open-universe-modal">
							Explorer mon univers complet
							<Icon icon="arrow-right" size="1.2em" />
						</button>
					</div>
				</section>


				<section id="formation" class="section bg-variant formation">
					<header class="section-header stack gap-2 lg:gap-4">
						<h4>Financez l'élaboration de votre site tout en vous formant !</h4>
						<p class="formation gap-2 lg:gap-4">En collaboration avec notre centre de formation, nous pouvons débloquer des crédits de formation auxquels vous avez droit (tels que les CPF) et avancer ensemble dans un beau projet de construction et de prise en main de votre interface.</p>
						<div class="img-center mb-4">
							<img
								alt="Florent Murat Light Developer, pour accompagner avec bienveillance vos projets web"
								src="/assets/letItBe/eveil_et_science.jpeg" alt="eveilEtScience" loading="lazy" decoding="async" />
						</div>

						<div class="cta">
							<CallToAction href="mailto:murat.light.developer@gmail.com">
								Pour plus de renseignements
								<Icon icon="pencil-line" size="1.2em" />
							</CallToAction>
						</div>
					</header>
				</section>
			</main>
		</div>
		<ContactCTA id="contact" />
	</div>
</BaseLayout>

<script>
	// Logic for Universe Modal
	const openUniverseBtn = document.getElementById('open-universe-modal');
	const universeModal = document.getElementById('universe-modal') as HTMLDialogElement;

	if (openUniverseBtn && universeModal) {
		openUniverseBtn.addEventListener('click', () => {
			const modalTitle = universeModal.querySelector('.modal-title');
			const modalDescription = universeModal.querySelector('.modal-description');
			const modalSolution = universeModal.querySelector('.modal-solution-content');
			const modalImageWrapper = universeModal.querySelector('.image-wrapper');
			const modalHeader = universeModal.querySelector('.modal-header');

			if (modalTitle) modalTitle.textContent = "Mon Univers Complet";
			if (modalDescription) modalDescription.textContent = "Un aperçu détaillé de mes outils, de ma philosophie et de mes passions.";
			
			if (modalSolution) {
				modalSolution.innerHTML = `
					<div class="stack gap-4">
						<p>En tant que <strong>Light Developer</strong>, mon approche repose sur trois piliers : la Technique, la Bienveillance et la Clarté.</p>
						<p>Je combine l'excellence technique (PHP, Symfony, Astro) avec une écoute profonde des besoins humains pour créer des solutions qui ont du sens.</p>
						<ul class="stack gap-2">
							<li><strong>Développement :</strong> WordPress, Sylius, Symfony, Astro.</li>
							<li><strong>Mindset :</strong> Écoute, clarté, transmission, présence.</li>
							<li><strong>Outils :</strong> Terminal, Linux, Docker, Cloud.</li>
						</ul>
					</div>
				`;
			}

			// Masquer l'image pour le modal univers ou mettre une image par défaut
			if (modalImageWrapper) (modalImageWrapper as HTMLElement).style.display = 'none';
			if (modalHeader) (modalHeader as HTMLElement).style.setProperty('grid-template-columns', '1fr');

			universeModal.showModal();
		});
	}
</script>

<style>
	.hero {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 3rem;
	}

	.roles {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		justify-content: center;
	}

	.hero-ctas {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
		justify-content: center;
		margin-top: 1rem;
	}

	.hero-image-container {
		position: relative;
		overflow: hidden;
		border-radius: 1.5rem;
		box-shadow: var(--shadow-md);
		transition: transform 0.3s ease, box-shadow 0.3s ease;
	}

	.hero-image-container:hover {
		transform: scale(1.02);
		box-shadow: 0 0 20px var(--accent-overlay);
	}

	.hero-image-container img {
		display: block;
		width: 100%;
		height: auto;
		aspect-ratio: 5 / 4;
		object-fit: cover;
		object-position: center;
		transition: transform 0.5s ease;
	}

	.hero-image-container:hover img {
		transform: scale(1.05);
	}

	.image-overlay {
		position: absolute;
		inset: 0;
		display: flex;
		flex-direction: column;
		justify-content: flex-end;
		padding: 2rem;
		background: linear-gradient(to top, rgba(0, 0, 0, 0.8) 0%, transparent 60%);
		opacity: 0;
		transition: opacity 0.4s ease;
		color: white;
		pointer-events: none;
	}

	.hero-image-container:hover .image-overlay {
		opacity: 1;
	}

	.overlay-title {
		font-size: var(--text-lg);
		font-weight: bold;
		margin-bottom: 0.25rem;
	}

	.overlay-text {
		font-size: var(--text-sm);
		opacity: 0.9;
	}

	.img-center {
		margin:1.5rem 0;
	}

	.img-center img {
		width: 120rem;
	}

	p.formation {
		padding: 1.2rem;
	}

	@media (min-width: 50em) {
		.hero {
			display: grid;
			grid-template-columns: 6fr 4fr;
			padding-inline: 2.5rem;
			gap: 5rem;
			align-items: center;
		}

		.roles {
			margin-top: 0.5rem;
			justify-content: flex-start;
		}

		.hero-ctas {
			justify-content: flex-start;
		}

		.hero-image-container {
			border-radius: 4.5rem;
		}

		.hero-image-container img {
			aspect-ratio: 3 / 4;
		}
	}
	@media (max-width: 50em) {
		.formation h4{
			max-width: 20ch;
			font-size: var(--text-xl);
		}

		.formation p{
			max-width: 31ch;
		}

		.formation img{
			max-width: 18rem;
 		   padding-right: 1em;;
		}
	}

	.service-card {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		padding: 2rem;
		background: var(--gradient-subtle);
		border: 1px solid var(--gray-800);
		border-radius: 1.5rem;
		box-shadow: var(--shadow-sm);
		transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
		gap: 1rem;
	}

	.service-card:hover {
		transform: translateY(-5px);
		box-shadow: 0 10px 30px var(--accent-overlay);
		border-color: var(--accent-regular);
	}

	.service-card h4 {
		font-size: var(--text-lg);
		color: var(--gray-0);
	}

	/* Univers section specific styles */
	.universe-card {
		position: relative;
		display: flex;
		flex-direction: column;
		align-items: center;
		padding: 1.5rem;
		background: var(--gradient-subtle);
		border: 1px solid var(--gray-800);
		border-radius: 1rem;
		text-align: center;
		transition: all 0.3s ease;
		cursor: help;
	}

	.universe-card:hover {
		transform: scale(1.05);
		border-color: var(--accent-regular);
		box-shadow: 0 5px 15px var(--accent-overlay);
	}

	.universe-card p {
		margin-top: 0.75rem;
		font-weight: 500;
		color: var(--gray-200);
	}

	.universe-tooltip {
		position: absolute;
		bottom: 100%;
		left: 50%;
		transform: translateX(-50%) translateY(-10px);
		background: var(--gray-0);
		color: white;
		padding: 0.5rem 1rem;
		border-radius: 0.5rem;
		font-size: var(--text-sm);
		width: 200px;
		opacity: 0;
		pointer-events: none;
		transition: all 0.3s ease;
		z-index: 20;
		box-shadow: var(--shadow-md);
	}

	.universe-card:hover .universe-tooltip {
		opacity: 1;
		transform: translateX(-50%) translateY(-20px);
	}

	.explore-universe-btn {
		display: flex;
		align-items: center;
		gap: 0.8em;
		padding: 0.8rem 1.6rem;
		color: var(--accent-text-over);
		background: var(--gradient-accent-orange);
		border: none;
		border-radius: 999rem;
		font-size: var(--text-md);
		cursor: pointer;
		transition: transform 0.2s ease, box-shadow 0.2s ease;
		box-shadow: var(--shadow-md);
	}

	.explore-universe-btn:hover {
		transform: scale(1.05);
		box-shadow: var(--shadow-lg);
	}

	.service-card p {
		font-size: var(--text-sm);
		color: var(--gray-400);
		line-height: 1.5;
	}

	.solutions {
		margin-top: 2rem;
	}

	@media (min-width: 50em) {
		.solutions {
			margin-top: 0;
		}

		.service-card {
			padding: 2.5rem;
		}

		.service-card h4 {
			font-size: var(--text-xl);
		}
	}

	/* ====================================================== */

	.section {
		display: grid;
		gap: 2rem;
	}

	.with-background {
		position: relative;
	}

	.with-background::before {
		--hero-bg: var(--bg-image-subtle-2);

		content: '';
		position: absolute;
		pointer-events: none;
		left: 50%;
		width: 100vw;
		aspect-ratio: calc(2.25 / var(--bg-scale));
		top: 0;
		transform: translateY(-75%) translateX(-50%);
		background:
			url('/assets/backgrounds/noise.png') top center/220px repeat,
			var(--hero-bg) center center / var(--bg-gradient-size) no-repeat,
			var(--gray-999);
		background-blend-mode: overlay, normal, normal, normal;
		mix-blend-mode: var(--bg-blend-mode);
		z-index: -1;
	}

	.with-background.bg-variant::before {
		--hero-bg: var(--bg-image-subtle-1);
	}

	.section-header {
		justify-self: center;
		text-align: center;
		max-width: 50ch;
		font-size: var(--text-md);
		color: var(--gray-300);
	}

	.section-header h3 {
		font-size: var(--text-2xl);
	}

	@media (min-width: 50em) {
		.section {
			grid-template-columns: repeat(4, 1fr);
			grid-template-areas: 'header header header header' 'gallery gallery gallery gallery';
			gap: 5rem;
		}

		.section.with-cta {
			grid-template-areas: 'header header header cta' 'gallery gallery gallery gallery';
		}

		.section-header {
			grid-area: header;
			font-size: var(--text-lg);
		}

		.section-header h3 {
			font-size: var(--text-4xl);
		}

		.with-cta .section-header {
			justify-self: flex-start;
			text-align: left;
		}

	.gallery {
		grid-area: gallery;
	}

	.cta {
		grid-area: cta;
	}
}

	/* ====================================================== */

	.mention-card {
		display: flex;
		height: 7rem;
		justify-content: center;
		align-items: center;
		text-align: center;
		border: 1px solid var(--gray-800);
		border-radius: 1.5rem;
		color: var(--gray-300);
		background: var(--gradient-subtle);
		box-shadow: var(--shadow-sm);
	}

	@media (min-width: 50em) {
		.mention-card {
			border-radius: 1.5rem;
			height: 9.5rem;
		}
	}
	.projects .gallery {
		margin-top: 1rem;
	}

	@media (min-width: 50em) {
		.projects .gallery {
			margin-top: 2rem;
		}
	}
</style>
