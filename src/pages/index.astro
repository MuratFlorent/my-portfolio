---
import { getCollection } from 'astro:content';

// Layout import — provides basic page elements: <head>, <nav>, <footer> etc.
import BaseLayout from '../layouts/BaseLayout.astro';

// Component Imports
import CallToAction from '../components/CallToAction.astro';
import Grid from '../components/Grid.astro';
import Hero from '../components/Hero.astro';
import Icon from '../components/Icon.astro';
import Pill from '../components/Pill.astro';
import PortfolioPreview from '../components/PortfolioPreview.astro';
import ProjectModal from '../components/ProjectModal.astro';
import UniverseModal from '../components/UniverseModal.astro';
import ScrollSpy from '../components/ScrollSpy.astro';
import Testimonials from '../components/Testimonials.astro';

// AFI Data
import afiContent from '../../docs/lightdeveloper-afi-pack/afi-content.lightdeveloper.json';

// Page section components
import ContactCTA from '../components/ContactCTA.astro';
import Skills from '../components/Skills.astro';

// Content Fetching: List six most recent work projects
const projects = (await getCollection('work'))
	.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
	.filter((project) => project.data.img.includes('/assets/projects/'))
	.slice(0, 6);

// Full Astro Component Syntax:
// https://docs.astro.build/core-concepts/astro-components/
---

<BaseLayout>
	<ProjectModal id="project-modal" />
	<UniverseModal id="universe-modal" />
	<ScrollSpy />
	<div class="stack gap-12 lg:gap-16">
		<header id="accueil" class="hero section">
			<div class="section-shell">
   	<Hero
					title="Donnez vie à vos projets web avec un accompagnement sur mesure"
					tagline="Création de sites vitrines, e-commerce et outils personnalisés."
					align="start"
				>
					<div class="mobile-hero-image">
						<img
							alt="Florent Murat - Créateur site internet"
							src="/assets/new_portrait2.jpeg"
							loading="eager"
							decoding="async"
						/>
					</div>
					<div class="roles">
						<Pill href="/approche" ariaLabel="Découvrir mon approche" class="expertise-pill">
							<Icon icon="code" size="1.33em" /> Développeur web
						</Pill>
						<Pill href="/formation" ariaLabel="Voir la section formation et financement" class="expertise-pill">
							<Icon icon="graduation-cap" size="1.33em" /> Formation & Financement
						</Pill>
						<Pill 
							href="#contact" 
							ariaLabel="Parler de votre projet" 
							class="expertise-pill quote-cta-button"
							data-tab="quote"
							data-message="Bonjour, je souhaiterais un accompagnement sur mesure pour mon projet."
						>
							<Icon icon="users" size="1.33em" /> Accompagnement sur mesure
						</Pill>
  				<Pill href="tel:+33669952710" ariaLabel="Appeler le service client" class="expertise-pill">
							<Icon icon="phone" size="1.33em" /> Rendez-vous téléphonique
						</Pill>
					</div>

					<div class="hero-ctas">
						<CallToAction href="/work/">
							Découvrir mes projets
							<Icon icon="arrow-right" size="1.2em" />
						</CallToAction>
						<CallToAction 
							href="#contact" 
							class="quote-cta-button"
							data-tab="quote"
							data-message="Bonjour, je souhaiterais obtenir un devis gratuit pour mon projet."
						>
							Estimer mon projet
							<Icon icon="paper-plane-tilt" size="1.2em" />
						</CallToAction>
					</div>
				</Hero>

   	<div class="hero-image-container desktop-only">
					<img
						alt="Florent Murat - Créateur site internet Saint-Jeannet 06640 et Nice freelance spécialisé en SEO local"
						width="3205"
						height="3981"
						src="/assets/new_portrait2.jpeg"
						loading="eager"
						decoding="async"
					/>
					<div class="image-overlay">
						<p class="overlay-title">Florent Murat — Light Developer</p>
						<p class="overlay-text">Développeur Freelance à Saint-Jeannet (06) — Intervention sur Nice, Cannes, Antibes et toute la France.</p>
					</div>
				</div>
			</div>
		</header>

		<section id="solutions" class="section solutions">
			<div class="solutions-bg"></div>
			<div class="section-shell">
					<header class="section-header stack gap-2 lg:gap-4 lg:align-start">
					<h2 class="lg:text-left">Accompagnement, Refonte & E-commerce</h2>
					<p class="lg:text-left">Des solutions simples, efficaces et évolutives pour répondre à vos besoins concrets de développement et de stratégie digitale.</p>
				</header>

				<ul class="service-grid">
					<li class="service-card">
						<a href="/creation-site-web-sur-mesure" class="service-link">
							<Icon icon="code" color="var(--accent-regular)" size="2.5rem" gradient />
							<h4>Site Vitrine & E-commerce</h4>
							<p>Présentez votre activité ou vendez vos produits avec un site professionnel, moderne et facile à gérer.</p>
						</a>
					</li>
					<li class="service-card">
						<a href="/refonte-site-web" class="service-link">
							<Icon icon="cpu" color="var(--accent-regular)" size="2.5rem" gradient />
							<h4>Refonte de site web</h4>
							<p>Modernisez votre image et boostez vos performances techniques en conservant vos acquis SEO.</p>
						</a>
					</li>
					<li class="service-card">
						<a href="/automatisation-web" class="service-link">
							<Icon icon="magic-wand" color="var(--accent-regular)" size="2.5rem" gradient />
							<h4>Réservation & Rendez-vous</h4>
							<p>Simplifiez la vie de vos clients avec des systèmes de prise de rendez-vous ou de réservation en ligne directs.</p>
						</a>
					</li>
					<li class="service-card">
						<a href="/optimisation-seo" class="service-link">
							<Icon icon="rocket-launch" color="var(--accent-regular)" size="2.5rem" gradient />
							<h4>Visibilité sur Google</h4>
							<p>Améliorez votre positionnement pour attirer naturellement plus de clients locaux ou nationaux chaque jour.</p>
						</a>
					</li>
					<li class="service-card">
						<a href="/formation" class="service-link">
							<Icon icon="strategy" color="var(--accent-regular)" size="2.5rem" gradient />
							<h4>Accompagnement & Formation</h4>
							<p>Je vous aide à comprendre vos outils et à devenir autonome pour piloter votre présence en ligne.</p>
						</a>
					</li>
					<li class="service-card">
						<a href="/creation-site-web-sur-mesure" class="service-link">
							<Icon icon="users-three" color="var(--accent-regular)" size="2.5rem" gradient />
							<h4>Stratégie & Conseil</h4>
							<p>Besoin d'un avis d'expert pour votre stratégie digitale ? Je vous accompagne sur la durée.</p>
						</a>
					</li>
				</ul>
			</div>
		</section>

		<main class="stack gap-12 lg:gap-24">
			<section id="projets" class="section grid-projets" style="padding-top: 1rem;">
				<div class="section-shell stack gap-10 lg:gap-12">
					<header class="section-header stack gap-4 lg:align-start px-4">
						<div class="badge-accent mx-auto lg:mx-0">Réalisations</div>
						<h2 class="lg:text-left">Un aperçu de mes projets</h2>
						<p class="max-w-2xl mx-auto lg:mx-0 lg:text-left">Découvrez des exemples concrets de sites et d’outils créés pour mes clients.</p>
					</header>

					<div class="gallery px-4 md:px-0">
						<Grid variant="projects">
							{
								projects.map((project) => (
									<li class="project-item">
										<PortfolioPreview project={project} />
									</li>
								))
							}
						</Grid>
						<div class="cta-inline lg:projects-cta">
 						<CallToAction href="/work/">
 							Voir plus de projets
 							<Icon icon="arrow-right" size="1.2em" />
 						</CallToAction>
						</div>
					</div>
				</div>
			</section>

			<section id="univers" class="section universe">
				<div class="section-shell stack gap-10 lg:gap-15">
					<header class="section-header stack gap-4 lg:align-start">
						<div class="badge-accent mx-auto lg:mx-0">Mon ADN</div>
						<h2 class="lg:text-left">Pourquoi travailler avec moi ?</h2>
						<p class="max-w-2xl mx-auto lg:mx-0 lg:text-left">
							Plus qu’un développeur, je suis votre partenaire technique. Mon rôle est de vous rassurer et de construire avec vous des outils qui simplifient votre quotidien.
						</p>
					</header>

					<div class="gallery">
						<div class="universe-grid">
							{
								[
									{ id: 'bienveillance', label: 'Écoute & Humain', icon: 'heart', description: 'Un accompagnement proche de vous pour comprendre vos vrais besoins.' },
									{ id: 'technique', label: 'Travail soigné', icon: 'code', description: 'Des solutions robustes qui durent dans le temps.' },
									{ id: 'clarté', label: 'Zéro Jargon', icon: 'sun', description: 'Je vous explique les choses simplement, sans mots compliqués.' },
									{ id: 'transmission', label: 'Votre Autonomie', icon: 'strategy', description: 'Mon but est que vous soyez à l’aise avec vos outils.' },
									{ id: 'outillage', label: 'Sur Mesure', icon: 'terminal', description: 'Je choisis les outils qui servent vraiment votre projet.' },
									{ id: 'automatisation', label: 'Simplification', icon: 'magic-wand', description: 'Simplifier vos tâches pour vous faire gagner du temps.' },
								].map((item) => (
									<div class="universe-item" data-universe-id={item.id} data-universe-data={JSON.stringify(item)}>
										<div class="universe-card-inner">
											<div class="icon-box">
												<Icon icon={item.icon as any} color="var(--accent-regular)" size="2rem" gradient />
											</div>
											<h4>{item.label}</h4>
											<p>{item.description}</p>
										</div>
									</div>
								))
							}
						</div>
					</div>

					<div class="cta centered">
						<button class="explore-universe-btn" id="open-universe-modal">
							<span>Explorer mon univers complet</span>
							<Icon icon="arrow-right" size="1.2em" />
						</button>
					</div>
				</div>
			</section>

			<Testimonials />

			<section id="formation" class="section formation-new">
				<div class="section-shell stack gap-10 lg:gap-12">
					<header class="section-header stack gap-4 lg:align-start">
						<div class="badge-accent mx-auto lg:mx-0">{afiContent.homeSection.eyebrow}</div>
						<h2 class="lg:text-left">{afiContent.homeSection.title}</h2>
						<p class="max-w-2xl mx-auto lg:mx-0 lg:text-left">{afiContent.homeSection.intro}</p>
					</header>

					<div class="formation-image-main">
						<img src="/assets/afi/afi-home-columns.png" alt="Accompagnement AFI formation" class="home-afi-img" />
					</div>

					<div class="formation-grid">
						{afiContent.homeSection.cards.map((card) => (
							<div class="formation-card">
								<div class="formation-card-content stack gap-4">
									<h4>{card.title}</h4>
									<p>{card.description}</p>
									<div class="card-cta">
										<a href={card.ctaUrl} target="_blank" rel="noopener noreferrer" class="link-explorer">
											<span>{card.ctaLabel}</span>
											<Icon icon="arrow-right" size="1.2em" />
										</a>
									</div>
								</div>
							</div>
						))}
					</div>

					<div class="highlights-container">
						{afiContent.homeSection.highlights.map((highlight) => (
							<div class="highlight-card">
								<div class="highlight-icon">
									<Icon icon="check-circle" size="1.2em" color="var(--accent-regular)" />
								</div>
								<span class="highlight-text">{highlight}</span>
							</div>
						))}
					</div>

					<div class="cta centered">
						<CallToAction href="/formation-financement">
							Voir les solutions de financement
							<Icon icon="graduation-cap" size="1.2em" />
						</CallToAction>
					</div>
				</div>
			</section>

		<section id="faq" class="section faq-section">
			<div class="section-shell stack gap-10 lg:gap-15">
				<header class="section-header stack gap-4 lg:align-start">
					<div class="badge-accent mx-auto lg:mx-0">FAQ</div>
					<h2 class="lg:text-left">Questions fréquentes</h2>
					<p class="max-w-2xl mx-auto lg:mx-0 lg:text-left">Tout ce qu'il faut savoir sur la création de sites web sur mesure, l'optimisation SEO et l'automatisation.</p>
				</header>
				<div class="faq-grid">
					<details class="faq-item">
						<summary>Pourquoi choisir un site web sur mesure plutôt qu'un CMS générique ?</summary>
						<div class="faq-content">
							<p>Un site sur mesure s’adapte aux besoins spécifiques de votre activité sans les lourdeurs techniques des thèmes pré-faits. Cela permet une optimisation maximale de la performance (Core Web Vitals), un meilleur SEO technique et une expérience utilisateur unique qui renforce votre image de marque.</p>
						</div>
					</details>
					<details class="faq-item">
						<summary>Quelle est la différence entre SEO (Google) et GEO (IA) ?</summary>
						<div class="faq-content">
							<p>Le SEO classique vise les moteurs de recherche traditionnels comme Google. Le GEO (Generative Engine Optimization) est une approche plus récente consistant à optimiser votre contenu pour qu'il soit cité par les IA génératives (ChatGPT, Perplexity, Google SGE). Je combine ces deux approches pour maximiser votre visibilité future.</p>
						</div>
					</details>
					<details class="faq-item">
						<summary>Comment mesurez-vous le retour sur investissement (ROI) de mon projet ?</summary>
						<div class="faq-content">
							<p>Au-delà du design, nous définissons des indicateurs clés (KPI) : augmentation du taux de conversion, amélioration du temps de chargement, gain de positions sur des mots-clés stratégiques ou encore automatisation de tâches répétitives. Un site performant doit être un levier de croissance mesurable.</p>
						</div>
					</details>
					<details class="faq-item">
						<summary>Proposez-vous un accompagnement après la mise en ligne ?</summary>
						<div class="faq-content">
							<p>Oui, je propose des contrats de maintenance pour assurer la sécurité, les mises à jour et l'évolution continue de votre site. Mon objectif est d'être un partenaire technique sur le long terme pour que votre outil web reste performant et sécurisé face aux nouvelles normes du web.</p>
						</div>
					</details>
					<details class="faq-item">
						<summary>Est-ce que mon site sera accessible et éco-conçu ?</summary>
						<div class="faq-content">
							<p>Absolument. Je respecte les standards d'accessibilité (RGAA) pour que votre contenu soit consultable par tous. De plus, un code propre et optimisé réduit l'empreinte carbone de votre site (éco-conception) tout en améliorant radicalement sa vitesse de chargement.</p>
						</div>
					</details>
					<details class="faq-item">
						<summary>Puis-je gérer mon contenu en autonomie après le développement ?</summary>
						<div class="faq-content">
							<p>C'est une priorité. Je mets en place des interfaces d'administration intuitives (CMS Headless ou WordPress optimisé) et je fournis une formation personnalisée. Vous restez maître de vos textes et images sans avoir besoin de connaissances techniques approfondies. Ces formations peuvent d'ailleurs être financées par votre CPF ou OPCO.</p>
						</div>
					</details>
					<details class="faq-item">
						<summary>Pourquoi travailler avec un freelance expert plutôt qu'une agence ?</summary>
						<div class="faq-content">
							<p>Travailler avec moi, c'est bénéficier d'un interlocuteur unique, d'une communication directe et d'une grande réactivité. Mon approche est globale : je ne me contente pas de coder, je vous conseille sur la stratégie, le SEO et l'expérience utilisateur avec une agilité que les grosses structures n'ont pas toujours.</p>
						</div>
					</details>
					<details class="faq-item">
						<summary>Quels sont les délais types pour un projet complet ?</summary>
						<div class="faq-content">
							<p>Selon la complexité, un projet web sur mesure prend généralement entre 4 et 8 semaines. Ce délai inclut les phases de stratégie, design, développement technique, tests rigoureux et optimisation pour le lancement.</p>
						</div>
					</details>
				</div>
			</div>
		</section>
		</main>

		<ContactCTA id="contact" />
	</div>
</BaseLayout>

<script>
	const openUniverseBtn = document.getElementById('open-universe-modal');
	const universeModal = document.getElementById('universe-modal') as HTMLDialogElement;

	if (openUniverseBtn && universeModal) {
		openUniverseBtn.addEventListener('click', () => {
			universeModal.showModal();
		});
	}

	const openQuotePill = document.getElementById('open-quote-pill');
	const heroContactCta = document.getElementById('hero-contact-cta');

	const triggerContact = (e: Event, source: string = 'Page Accueil', message: string = "Bonjour, je souhaiterais discuter d'un accompagnement sur mesure pour mon projet...") => {
		e.preventDefault();
		window.dispatchEvent(new CustomEvent('open-contact', {
			detail: {
				tab: 'quote',
				source: source,
				message: message
			}
		}));
	};

	if (openQuotePill) {
		openQuotePill.addEventListener('click', (e) => triggerContact(e, 'Pill Accompagnement'));
	}

	if (heroContactCta) {
		heroContactCta.addEventListener('click', (e) => triggerContact(e, 'Hero Page Accueil', 'Je souhaite obtenir un devis gratuit pour mon projet.'));
	}
</script>
	<style>
		.hero {
			display: flex;
			flex-direction: column;
		align-items: center;
		gap: 2rem;
		text-align: center;
		padding-top: 2rem !important;
	}

	@media (min-width: 50em) {
		.hero .section-shell {
			display: grid;
			grid-template-columns: 6fr 4fr;
			gap: 3.75rem;
			align-items: center;
		}

		.hero {
			text-align: left;
		}

		.roles {
			justify-content: flex-start !important;
		}

		.hero-ctas {
			justify-content: flex-start !important;
		}
	}

	.roles {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		width: 100%;
		align-items: stretch;
		margin-bottom: 2rem;
	}

	@media (max-width: 50em) {
		.expertise-pill {
			width: 100%;
			justify-content: center;
			padding: 1rem !important; /* Pills plus grandes sur mobile */
		}
	}

	.expertise-pill {
		background: var(--gray-999_40) !important;
		border: 1px solid var(--gray-800) !important;
		color: var(--gray-200) !important;
		font-weight: 500 !important;
		box-shadow: none !important;
		position: relative;
		overflow: hidden;
	}

	.expertise-pill:hover {
		background: var(--gray-900) !important;
		border-color: var(--accent-regular) !important;
		color: var(--gray-0) !important;
		transform: translateY(-2px) !important;
	}

	/* Indicateur discret que c'est un bouton (petit trait en bas) */
	.expertise-pill::after {
		content: "";
		position: absolute;
		bottom: 0;
		left: 50%;
		width: 0;
		height: 2px;
		background: var(--gradient-accent-orange);
		transition: width 0.3s ease, left 0.3s ease;
	}

	.expertise-pill:hover::after,
	.expertise-pill:focus-within::after {
		width: 100%;
		left: 0;
	}

	.expertise-pill:active {
		transform: translateY(0) scale(0.98) !important;
	}

	.expertise-pill :global(svg) {
		color: var(--accent-regular);
	}

	@media (min-width: 36em) {
		.roles {
			display: grid;
			grid-template-columns: repeat(2, 1fr);
			gap: 0.75rem;
		}
	}

	@media (min-width: 60em) {
		.roles {
			display: flex;
			flex-direction: row;
			flex-wrap: wrap;
			width: auto;
			justify-content: center;
			gap: 0.75rem;
		}
	}

	.hero-ctas {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1.25rem; /* Augmenter l'espace entre les CTAs principaux */
		width: 100%;
		margin-top: 2rem;
	}

	@media (max-width: 50em) {
		.hero-ctas {
			order: -1; /* Place les boutons au-dessus des pills sur mobile */
			margin-bottom: 2rem;
		}
		
		.hero-ctas :global(.cta) {
			width: 100%;
			padding: 1.25rem; /* Rendre les boutons plus imposants */
			font-size: 1.1rem;
		}
	}

	@media (min-width: 30em) {
		.hero-ctas {
			flex-direction: row;
			justify-content: center;
			width: auto;
		}
	}

	.hero-image-container {
		position: relative;
		overflow: hidden;
		border-radius: var(--radius-md);
		box-shadow: var(--shadow-md);
		transition: transform var(--theme-transition-slow), box-shadow var(--theme-transition);
		margin-top: 2rem;
	}

	.desktop-only {
		display: none;
	}

	.mobile-hero-image {
		display: block;
		margin: 1rem 0;
		border-radius: 1rem;
		overflow: hidden;
		box-shadow: var(--shadow-sm);
	}

	.mobile-hero-image img {
		width: 100%;
		height: auto;
		display: block;
	}

	@media (min-width: 50em) {
		.hero-image-container {
			margin-top: 0;
		}
		.desktop-only {
			display: block;
		}
		.mobile-hero-image {
			display: none;
		}
	}

	.hero-image-container:hover {
		transform: scale(1.02);
		box-shadow: var(--glow-accent);
	}

	.hero-image-container img {
		display: block;
		width: 100%;
		height: auto;
		aspect-ratio: 1 / 1.1;
		object-fit: cover;
		object-position: center center;
		transform: scale(1);
		transition: transform var(--theme-transition-slow);
	}

	@media (min-width: 30em) {
		.hero-image-container img {
			aspect-ratio: 5 / 4;
			object-position: center center;
			transform: scale(1);
		}
	}

	.hero-image-container:hover img {
		transform: scale(1.05);
	}

	.image-overlay {
		position: absolute;
		inset: 0;
		display: flex;
		flex-direction: column;
		justify-content: flex-end;
		padding: 2.5rem;
		background: linear-gradient(to top, rgba(0, 0, 0, 0.8) 0%, transparent 60%);
		opacity: 0;
		transition: opacity var(--theme-transition);
		color: white;
		pointer-events: none;
	}

	.hero-image-container:hover .image-overlay {
		opacity: 1;
