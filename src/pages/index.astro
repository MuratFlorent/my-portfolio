---
import { getCollection } from 'astro:content';

// Layout import — provides basic page elements: <head>, <nav>, <footer> etc.
import BaseLayout from '../layouts/BaseLayout.astro';

// Component Imports
import CallToAction from '../components/CallToAction.astro';
import Grid from '../components/Grid.astro';
import Hero from '../components/Hero.astro';
import Icon from '../components/Icon.astro';
import Pill from '../components/Pill.astro';
import PortfolioPreview from '../components/PortfolioPreview.astro';
import ProjectModal from '../components/ProjectModal.astro';
import UniverseModal from '../components/UniverseModal.astro';
import ScrollSpy from '../components/ScrollSpy.astro';
import Testimonials from '../components/Testimonials.astro';

// Page section components
import ContactCTA from '../components/ContactCTA.astro';
import Skills from '../components/Skills.astro';

// Content Fetching: List four most recent work projects
const projects = (await getCollection('work'))
	.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
	.slice(0, 4);

// Full Astro Component Syntax:
// https://docs.astro.build/core-concepts/astro-components/
---

<BaseLayout>
	<ProjectModal id="project-modal" />
	<UniverseModal id="universe-modal" />
	<ScrollSpy />
	<div class="stack gap-12 lg:gap-16">
		<header id="accueil" class="hero section">
			<div class="section-shell">
				<Hero
					title="Sites web sur mesure et visibilité sur Google"
					tagline="Je conçois des solutions digitales adaptées à votre projet pour améliorer votre présence en ligne et attirer les bons clients."
					align="start"
				>
					<div class="roles">
						<Pill href="/developpeur-web-freelance" ariaLabel="Découvrir mon approche">
							<Icon icon="code" size="1.33em" /> Développeur web
						</Pill>
						<Pill href="/formation" ariaLabel="Voir la section formation">
							<Icon icon="graduation-cap" size="1.33em" /> Formateur
						</Pill>
						<Pill href="#contact" ariaLabel="Parler de votre projet" id="open-quote-pill">
							<Icon icon="users" size="1.33em" /> Accompagnement sur mesure
						</Pill>
						<Pill href="tel:+33682027290" ariaLabel="Appeler Florent Murat">
							<Icon icon="phone" size="1.33em" /> Rendez-vous téléphonique
						</Pill>
					</div>

					<div class="hero-ctas">
						<CallToAction href="/work/">
							Mes projets
							<Icon icon="arrow-right" size="1.2em" />
						</CallToAction>
						<CallToAction href="mailto:murat.light.developer@gmail.com">
							Discutons de votre projet
							<Icon icon="paper-plane-tilt" size="1.2em" />
						</CallToAction>
					</div>
				</Hero>

				<div class="hero-image-container">
					<img
						alt="Florent Murat - Développeur web freelance spécialisé en création de site sur mesure et SEO"
						width="1365"
						height="2048"
						src="/assets/portrait2.jpeg"
						loading="eager"
						decoding="async"
					/>
					<div class="image-overlay">
						<p class="overlay-title">Florent Murat — Light Developer</p>
						<p class="overlay-text">Développeur web, formateur et accompagnant de projets sur mesure.</p>
					</div>
				</div>
			</div>
		</header>

		<section id="solutions" class="section solutions">
			<div class="solutions-bg"></div>
			<div class="section-shell">
				<header class="section-header stack gap-2 lg:gap-4">
					<h2>Solutions personnalisées</h2>
					<p>Que vous ayez besoin d'une présence en ligne complète ou d'un outil métier spécifique, je conçois des solutions adaptées à vos enjeux.</p>
				</header>

				<ul class="service-grid">
					<li class="service-card">
						<a href="/creation-site-web-sur-mesure" class="service-link">
							<Icon icon="code" color="var(--accent-regular)" size="2.5rem" gradient />
							<h4>Sites & refontes</h4>
							<p>Création de sites vitrines et applicatifs modernes, optimisés pour votre activité.</p>
						</a>
					</li>
					<li class="service-card">
						<Icon icon="cpu" color="var(--accent-regular)" size="2.5rem" gradient />
						<h4>Fonctionnalités sur mesure</h4>
						<p>Extension des capacités de vos outils existants (WordPress, Sylius, etc.) via des plugins spécifiques.</p>
					</li>
					<li class="service-card">
						<a href="/automatisation-web" class="service-link">
							<Icon icon="magic-wand" color="var(--accent-regular)" size="2.5rem" gradient />
							<h4>Automatisations & gain de temps</h4>
							<p>Optimisation de vos processus métier via des scripts and outils connectés pour gagner en productivité.</p>
						</a>
					</li>
					<li class="service-card">
						<a href="/optimisation-seo" class="service-link">
							<Icon icon="rocket-launch" color="var(--accent-regular)" size="2.5rem" gradient />
							<h4>Visibilité sur Google</h4>
							<p>Amélioration de votre référencement naturel (SEO) pour attirer durablement de nouveaux clients.</p>
						</a>
					</li>
					<li class="service-card">
						<a href="/formation" class="service-link">
							<Icon icon="strategy" color="var(--accent-regular)" size="2.5rem" gradient />
							<h4>Formation & transmission</h4>
							<p>Apprenez à maîtriser vos outils numériques pour monter en compétence en toute autonomie.</p>
						</a>
					</li>
					<li class="service-card">
						<Icon icon="users-three" color="var(--accent-regular)" size="2.5rem" gradient />
						<h4>Accompagnement projet</h4>
						<p>Conseil stratégique et suivi humain tout au long de la vie de votre projet digital.</p>
					</li>
				</ul>
			</div>
		</section>

		<main class="stack gap-12 lg:gap-24">
			<section id="projets" class="section grid-projets" style="padding-top: 1rem;">
				<div class="section-shell stack gap-10 lg:gap-12">
					<header class="section-header stack gap-4 lg:align-start centered px-4">
						<div class="badge-accent mx-auto lg:mx-0">Réalisations</div>
						<h2 class="lg:text-left">Projets réalisés</h2>
						<p class="max-w-2xl mx-auto lg:mx-0 lg:text-left">Une sélection de mes réalisations les plus marquantes, alliant expertise technique et approche humaine.</p>
					</header>

					<div class="gallery px-4 md:px-0">
						<Grid variant="projects">
							{
								projects.map((project) => (
									<li class="project-item">
										<PortfolioPreview project={project} />
									</li>
								))
							}
						</Grid>
						<div class="cta-inline lg:projects-cta">
							<CallToAction href="/work/">
								Toutes les réalisations
								<Icon icon="arrow-right" size="1.2em" />
							</CallToAction>
						</div>
					</div>
				</div>
			</section>

			<section id="univers" class="section universe">
				<div class="section-shell stack gap-10 lg:gap-15">
					<header class="section-header stack gap-4 centered">
						<div class="badge-accent mx-auto">Mon approche</div>
						<h2>Expertise & Valeurs</h2>
						<p class="max-w-2xl mx-auto">
							Développeur web freelance avec plus de 10 ans d'expérience, j'accompagne mes clients dans la création de solutions digitales performantes et humaines.
						</p>
					</header>

					<div class="gallery">
						<div class="universe-grid">
							{
								[
									{ id: 'bienveillance', label: 'Bienveillance', icon: 'heart', description: 'Une approche humaine centrée sur l’écoute et l’empathie.' },
									{ id: 'technique', label: 'Rigueur technique', icon: 'code', description: 'Un code propre, robuste et performant.' },
									{ id: 'clarté', label: 'Clarté & pédagogie', icon: 'sun', description: 'Démystifier la technique pour vous donner une vision claire.' },
									{ id: 'transmission', label: 'Transmission', icon: 'strategy', description: 'Partager le savoir pour favoriser votre autonomie.' },
									{ id: 'outillage', label: 'Technologies', icon: 'terminal', description: 'Sélection des meilleurs outils pour répondre à vos besoins.' },
									{ id: 'automatisation', label: 'Gain de temps', icon: 'magic-wand', description: 'Automatiser les tâches répétitives pour libérer votre créativité.' },
								].map((item) => (
									<div class="universe-item" data-universe-id={item.id} data-universe-data={JSON.stringify(item)}>
										<div class="universe-card-inner">
											<div class="icon-box">
												<Icon icon={item.icon as any} color="var(--accent-regular)" size="2rem" gradient />
											</div>
											<h4>{item.label}</h4>
											<p>{item.description}</p>
										</div>
									</div>
								))
							}
						</div>
					</div>

					<div class="cta centered">
						<button class="explore-universe-btn" id="open-universe-modal">
							<span>Explorer mon univers complet</span>
							<Icon icon="arrow-right" size="1.2em" />
						</button>
					</div>
				</div>
			</section>

			<Testimonials />

			<section id="faq" class="section faq-section">
				<div class="section-shell stack gap-10 lg:gap-15">
					<header class="section-header stack gap-4 centered">
						<div class="badge-accent mx-auto">FAQ</div>
						<h2>Questions fréquentes</h2>
						<p class="max-w-2xl mx-auto">Tout ce qu'il faut savoir sur la création de sites web sur mesure, l'optimisation SEO et l'automatisation.</p>
					</header>
					<div class="faq-grid">
						<details class="faq-item">
							<summary>Pourquoi choisir un site web sur mesure plutôt qu'un CMS générique ?</summary>
							<div class="faq-content">
								<p>Un site sur mesure s’adapte aux besoins spécifiques de votre activité sans les lourdeurs techniques des thèmes pré-faits. Cela permet une optimisation maximale de la performance (Core Web Vitals), un meilleur SEO technique et une expérience utilisateur unique qui renforce votre image de marque.</p>
							</div>
						</details>
						<details class="faq-item">
							<summary>Quelle est la différence entre SEO (Google) et GEO (IA) ?</summary>
							<div class="faq-content">
								<p>Le SEO classique vise les moteurs de recherche traditionnels comme Google. Le GEO (Generative Engine Optimization) est une approche plus récente consistant à optimiser votre contenu pour qu'il soit cité par les IA génératives (ChatGPT, Perplexity, Google SGE). Je combine ces deux approches pour maximiser votre visibilité future.</p>
							</div>
						</details>
						<details class="faq-item">
							<summary>Comment mesurez-vous le retour sur investissement (ROI) de mon projet ?</summary>
							<div class="faq-content">
								<p>Au-delà du design, nous définissons des indicateurs clés (KPI) : augmentation du taux de conversion, amélioration du temps de chargement, gain de positions sur des mots-clés stratégiques ou encore automatisation de tâches répétitives. Un site performant doit être un levier de croissance mesurable.</p>
							</div>
						</details>
						<details class="faq-item">
							<summary>Proposez-vous un accompagnement après la mise en ligne ?</summary>
							<div class="faq-content">
								<p>Oui, je propose des contrats de maintenance pour assurer la sécurité, les mises à jour et l'évolution continue de votre site. Mon objectif est d'être un partenaire technique sur le long terme pour que votre outil web reste performant et sécurisé face aux nouvelles normes du web.</p>
							</div>
						</details>
						<details class="faq-item">
							<summary>Est-ce que mon site sera accessible et éco-conçu ?</summary>
							<div class="faq-content">
								<p>Absolument. Je respecte les standards d'accessibilité (RGAA) pour que votre contenu soit consultable par tous. De plus, un code propre et optimisé réduit l'empreinte carbone de votre site (éco-conception) tout en améliorant radicalement sa vitesse de chargement.</p>
							</div>
						</details>
						<details class="faq-item">
							<summary>Puis-je gérer mon contenu en autonomie après le développement ?</summary>
							<div class="faq-content">
								<p>C'est une priorité. Je mets en place des interfaces d'administration intuitives (CMS Headless ou WordPress optimisé) et je fournis une formation personnalisée. Vous restez maître de vos textes et images sans avoir besoin de connaissances techniques approfondies.</p>
							</div>
						</details>
						<details class="faq-item">
							<summary>Pourquoi travailler avec un freelance expert plutôt qu'une agence ?</summary>
							<div class="faq-content">
								<p>Travailler avec moi, c'est bénéficier d'un interlocuteur unique, d'une communication directe et d'une grande réactivité. Mon approche est globale : je ne me contente pas de coder, je vous conseille sur la stratégie, le SEO et l'expérience utilisateur avec une agilité que les grosses structures n'ont pas toujours.</p>
							</div>
						</details>
						<details class="faq-item">
							<summary>Quels sont les délais types pour un projet complet ?</summary>
							<div class="faq-content">
								<p>Selon la complexité, un projet web sur mesure prend généralement entre 4 et 8 semaines. Ce délai inclut les phases de stratégie, design, développement technique, tests rigoureux et optimisation pour le lancement.</p>
							</div>
						</details>
					</div>
				</div>
			</section>
		</main>

		<section id="formation" class="section formation-premium">
			<div class="formation-bg"></div>
			<div class="section-shell">
				<div class="stack gap-12 lg:gap-16">
					<header class="section-header stack gap-4 centered">
						<div class="badge-accent mx-auto">Formation & Accompagnement</div>
						<h2>Formation et accompagnement</h2>
						<p class="max-w-2xl mx-auto">
							Bâtissez votre projet (WordPress, SEO, Design) tout en apprenant à le maîtriser. 
							Profitez d'un financement (CPF, OPCO) via notre centre partenaire certifié AFI.
						</p>
					</header>

					<div class="formation-content-grid">
						<div class="formation-image-wrapper">
							<img
								alt="Florent Murat - Formation et transmission de savoir-faire"
								src="/assets/letItBe/eveil_et_science.jpeg" 
								loading="lazy" 
								decoding="async" 
							/>
							<div class="image-badge">
								<Icon icon="strategy" size="1.2em" />
								<span>Apprentissage concret</span>
							</div>
						</div>

						<div class="formation-features stack gap-8">
							<div class="feature-item">
								<div class="icon-circle">
									<Icon icon="rocket-launch" size="1.5rem" gradient />
								</div>
								<div class="feature-text stack gap-1">
									<h4>Expertise de 10+ ans</h4>
									<p>Une expérience solide acquise sur plus de 50 projets web réussis.</p>
								</div>
							</div>
							<div class="feature-item">
								<div class="icon-circle">
									<Icon icon="strategy" size="1.5rem" gradient />
								</div>
								<div class="feature-text stack gap-1">
									<h4>Autonomie réelle</h4>
									<p>Ne soyez plus dépendant. Apprenez à gérer votre interface et vos contenus en toute confiance.</p>
								</div>
							</div>
							<div class="feature-item">
								<div class="icon-circle">
									<Icon icon="code" size="1.5rem" gradient />
								</div>
								<div class="feature-text stack gap-1">
									<h4>Expertise sur mesure</h4>
									<p>Le programme s'adapte à votre projet : WordPress, SEO ou structuration de données.</p>
								</div>
							</div>
							<div class="feature-item">
								<div class="icon-circle">
									<Icon icon="heart" size="1.5rem" gradient />
								</div>
								<div class="feature-text stack gap-1">
									<h4>Financement facilité</h4>
									<p>Accompagnement administratif pour vos dossiers CPF, OPCO ou Pôle Emploi.</p>
								</div>
							</div>

							<div class="cta-group">
								<CallToAction href="/formation">
									Découvrir l'offre de formation
									<Icon icon="arrow-right" size="1.2em" />
								</CallToAction>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>
		<ContactCTA id="contact" />
	</div>
</BaseLayout>

<script>
	const openUniverseBtn = document.getElementById('open-universe-modal');
	const universeModal = document.getElementById('universe-modal') as HTMLDialogElement;

	if (openUniverseBtn && universeModal) {
		openUniverseBtn.addEventListener('click', () => {
			universeModal.showModal();
		});
	}

	const openQuotePill = document.getElementById('open-quote-pill');
	if (openQuotePill) {
		openQuotePill.addEventListener('click', (e) => {
			e.preventDefault();
			window.dispatchEvent(new CustomEvent('open-contact', {
				detail: {
					tab: 'quote',
					message: "Bonjour, je souhaiterais discuter d'un accompagnement sur mesure pour mon projet..."
				}
			}));
		});
	}
</script>

<style>
	.hero {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 2rem;
		text-align: center;
		padding-top: 2rem !important;
	}

	@media (min-width: 50em) {
		.hero .section-shell {
			display: grid;
			grid-template-columns: 6fr 4fr;
			gap: 3.75rem;
			align-items: center;
		}

		.hero {
			text-align: left;
		}

		.roles {
			justify-content: flex-start !important;
		}

		.hero-ctas {
			justify-content: flex-start !important;
		}
	}

	.roles {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		width: 100%;
		align-items: stretch; /* Largeur cohérente en mobile */
	}

	@media (min-width: 36em) {
		.roles {
			display: grid;
			grid-template-columns: repeat(2, 1fr);
			gap: 0.75rem;
		}
	}

	@media (min-width: 60em) {
		.roles {
			display: flex;
			flex-direction: row;
			flex-wrap: wrap;
			width: auto;
			justify-content: center;
			gap: 0.75rem;
		}
	}

	.hero-ctas {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1rem;
		width: 100%;
		margin-top: 1rem;
	}

	@media (min-width: 30em) {
		.hero-ctas {
			flex-direction: row;
			justify-content: center;
			width: auto;
		}
	}

	.hero-image-container {
		position: relative;
		overflow: hidden;
		border-radius: var(--radius-md);
		box-shadow: var(--shadow-md);
		transition: transform var(--theme-transition-slow), box-shadow var(--theme-transition);
		margin-top: 2rem;
	}

	@media (min-width: 50em) {
		.hero-image-container {
			margin-top: 0;
		}
	}

	.hero-image-container:hover {
		transform: scale(1.02);
		box-shadow: var(--glow-accent);
	}

	.hero-image-container img {
		display: block;
		width: 100%;
		height: auto;
		aspect-ratio: 5 / 4;
		object-fit: cover;
		object-position: center;
		transition: transform var(--theme-transition-slow);
	}

	.hero-image-container:hover img {
		transform: scale(1.05);
	}

	.image-overlay {
		position: absolute;
		inset: 0;
		display: flex;
		flex-direction: column;
		justify-content: flex-end;
		padding: 2.5rem;
		background: linear-gradient(to top, rgba(0, 0, 0, 0.8) 0%, transparent 60%);
		opacity: 0;
		transition: opacity var(--theme-transition);
		color: white;
		pointer-events: none;
	}

	.hero-image-container:hover .image-overlay {
		opacity: 1;
	}

	.overlay-title {
		font-size: var(--text-lg);
		font-weight: bold;
		margin-bottom: 0.25rem;
		transform: translateY(10px);
		transition: transform var(--theme-transition-slow);
	}

	.hero-image-container:hover .overlay-title {
		transform: translateY(0);
	}

	.overlay-text {
		font-size: var(--text-sm);
		opacity: 0.9;
		line-height: 1.4;
		transform: translateY(10px);
		transition: transform var(--theme-transition-slow) 0.1s;
	}

	.hero-image-container:hover .overlay-text {
		transform: translateY(0);
	}

	.img-center {
		margin:1.5rem 0;
	}

	.img-center img {
		width: 120rem;
	}

	p.formation {
		padding: 1.2rem;
	}

	@media (min-width: 50em) {
		.hero {
			display: grid;
			grid-template-columns: 6fr 4fr;
			padding-inline: 1.5rem;
			gap: 3rem;
			align-items: center;
		}

		.roles {
			margin-top: 0.5rem;
			justify-content: flex-start;
		}

		.hero-ctas {
			justify-content: flex-start;
		}

		.hero-image-container {
			border-radius: 3rem;
		}

		.hero-image-container img {
			aspect-ratio: 3 / 4;
		}
	}

	@media (min-width: 80em) {
		.hero {
			padding-inline: 2.5rem;
			gap: 5rem;
		}

		.hero-image-container {
			border-radius: 4.5rem;
		}
	}
	@media (max-width: 50em) {
		.formation h4{
			max-width: 20ch;
			font-size: var(--text-xl);
		}

		.formation p{
			max-width: 31ch;
		}

		.formation img{
			max-width: 18rem;
 		   padding-right: 1em;;
		}
	}

	@media (max-width: 50em) {
		.formation-premium .badge-accent {
			margin-inline: auto;
		}

		.formation-image-wrapper {
			max-width: 100%;
			margin-inline: auto;
		}

		.formation-image-wrapper img {
			aspect-ratio: 16 / 9;
		}
	}

	.service-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1.5rem;
		width: 100%;
		max-width: 1200px;
		margin: 0 auto;
		list-style: none;
		padding: 0;
	}

	@media (min-width: 40em) {
		.service-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (min-width: 64em) {
		.service-grid {
			grid-template-columns: repeat(3, 1fr);
			gap: 2rem;
		}
	}

	.service-card {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		padding: 2.5rem;
		background: var(--gray-999);
		border: 1px solid var(--gray-800);
		border-radius: var(--radius-md);
		box-shadow: var(--shadow-sm);
