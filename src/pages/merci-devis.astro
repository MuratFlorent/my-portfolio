---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactCTA from '../components/ContactCTA.astro';
import Hero from '../components/Hero.astro';
import Icon from '../components/Icon.astro';
---

<BaseLayout title="Demande reçue | Light Developer" description="Merci pour votre demande de devis.">
	<div class="stack gap-20 lg:gap-48">
		<main class="wrapper stack gap-12 text-center">
			<div class="success-header stack gap-6">
				<div class="icon-circle">
					<Icon icon="magic-wand" size="3.5rem" />
				</div>
				<Hero
					title="Demande de devis reçue !"
					tagline="Merci pour la confiance accordée à votre projet. Je vais étudier vos besoins et je reviens vers vous avec une proposition détaillée sous 48h."
					align="center"
				/>
			</div>
			
			<div class="actions">
				<a href="/" class="btn-primary">
					<Icon icon="arrow-left" size="1.2em" />
					Retour à l'accueil
				</a>
			</div>
		</main>
		<ContactCTA />
	</div>
</BaseLayout>

<style>
	main {
		padding-top: 10rem;
		padding-bottom: 5rem;
		min-height: 60vh;
	}

	.icon-circle {
		width: 7rem;
		height: 7rem;
		background: var(--gradient-accent-orange);
		color: white;
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		margin: 0 auto;
		box-shadow: var(--glow-accent);
	}

	.actions {
		display: flex;
		justify-content: center;
		gap: 1.5rem;
	}

	.btn-primary {
		display: inline-flex;
		align-items: center;
		gap: 0.75rem;
		padding: 1rem 2rem;
		background: var(--gradient-accent-orange);
		color: var(--accent-text-over);
		text-decoration: none;
		border-radius: var(--radius-full);
		font-weight: 700;
		font-size: var(--text-lg);
		transition: transform 0.2s ease, box-shadow 0.2s ease;
		box-shadow: var(--shadow-md);
	}

	.btn-primary:hover {
		transform: translateY(-3px);
		box-shadow: var(--shadow-lg), var(--glow-accent);
	}

	@media (max-width: 50em) {
		main {
			padding-top: 6rem;
		}
		
		.icon-circle {
			width: 6rem;
			height: 6rem;
		}
	}
</style>
