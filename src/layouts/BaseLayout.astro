---
// Learn about using Astro layouts:
// https://docs.astro.build/en/core-concepts/layouts/

// Component Imports
import MainHead from '../components/MainHead.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import FloatingContact from '../components/FloatingContact.astro';
import CookieBanner from '../components/CookieBanner.astro';

interface Props {
	title?: string | undefined;
	description?: string | undefined;
}

const { title, description } = Astro.props;
---

<html lang="fr">
	<head>
		<meta charset="UTF-8" />
		<title>{title || 'Light Developer'}</title>
		<MainHead title={title} description={description} />
		<script type="application/ld+json">
				{
					"@context": "https://schema.org",
					"@type": "ProfessionalService",
					"name": "Light Developer - Créateur site web Nice 06",
					"description": "Créateur de site web 06 - Côte d'Azur : Développement web sur mesure, SEO et automatisation à Nice, Cannes et Antibes.",
					"url": "https://lightdeveloper.fr",
     "telephone": "+33669952710",
					"areaServed": [
						{
							"@type": "City",
							"name": "Saint-Jeannet"
						},
						{
							"@type": "City",
							"name": "Vence"
						},
						{
							"@type": "City",
							"name": "La Gaude"
						},
						{
							"@type": "City",
							"name": "Gattières"
						},
						{
							"@type": "City",
							"name": "Carros"
						},
						{
							"@type": "City",
							"name": "Nice"
						},
						{
							"@type": "City",
							"name": "Cagnes-sur-Mer"
						},
						{
							"@type": "City",
							"name": "Saint-Laurent-du-Var"
						},
						{
							"@type": "City",
							"name": "Cannes"
						},
						{
							"@type": "City",
							"name": "Antibes"
						},
						{
							"@type": "AdministrativeArea",
							"name": "Alpes-Maritimes"
						}
					],
					"founder": {
						"@type": "Person",
						"name": "Florent Murat"
					},
					"address": {
						"@type": "PostalAddress",
						"streetAddress": "Saint-Jeannet",
						"addressLocality": "Saint-Jeannet",
						"postalCode": "06640",
						"addressRegion": "Provence-Alpes-Côte d'Azur",
						"addressCountry": "FR"
					},
					"geo": {
						"@type": "GeoCoordinates",
						"latitude": "43.7483",
						"longitude": "7.1424"
					}
				}
			</script>
		</head>
	<body>
		<div class="stack backgrounds">
			<div class="nav-container scrolled-wrapper">
				<Nav />
			</div>
			<slot />
			<Footer />
		</div>
		<FloatingContact />
		<CookieBanner />

		<script>
			// Add “loaded” class once the document has completely loaded.
			addEventListener('load', () => document.documentElement.classList.add('loaded'));
		</script>

		<style>
			html {
				scroll-behavior: smooth;
			}

			/* Custom scrollbar for the entire site */
			::-webkit-scrollbar {
				width: 10px;
			}

			::-webkit-scrollbar-track {
				background: var(--gray-999);
			}

			::-webkit-scrollbar-thumb {
				background: var(--gray-700);
				border-radius: 10px;
				border: 2px solid var(--gray-999);
			}

			::-webkit-scrollbar-thumb:hover {
				background: var(--gray-600);
			}

			/* For Firefox */
			* {
				scrollbar-width: thin;
				scrollbar-color: var(--gray-700) transparent;
			}

			:root {
				--_placeholder-bg: linear-gradient(transparent, transparent);
				--bg-image-main: url('/assets/backgrounds/bg-main-light-800w.jpg');
				--bg-image-main-curves: url('/assets/backgrounds/bg-main-light.svg');
				--bg-image-subtle-1: var(--_placeholder-bg);
				--bg-image-subtle-2: var(--_placeholder-bg);
				--bg-image-footer: var(--_placeholder-bg);
				--bg-svg-blend-mode: overlay;
				--bg-blend-mode: darken;
				--bg-image-aspect-ratio: 2.25;
				--bg-scale: 1.68;
				--bg-aspect-ratio: calc(var(--bg-image-aspect-ratio) / var(--bg-scale));
				--bg-gradient-size: calc(var(--bg-scale) * 100%);
			}

			:root.theme-dark {
				--bg-image-main: url('/assets/backgrounds/bg-main-dark-800w.jpg');
				--bg-image-main-curves: url('/assets/backgrounds/bg-main-dark.svg');
				--bg-svg-blend-mode: darken;
				--bg-blend-mode: lighten;
			}

			/* These backgrounds are displayed below the fold, so we lazy load them
			   once the `.loaded` class has been set.  */
			:root.loaded {
				--bg-image-subtle-1: url('/assets/backgrounds/bg-subtle-1-light-800w.jpg');
				--bg-image-subtle-2: url('/assets/backgrounds/bg-subtle-2-light-800w.jpg');
				--bg-image-footer: url('/assets/backgrounds/bg-footer-light-800w.jpg');
			}
			:root.loaded.theme-dark {
				--bg-image-subtle-1: url('/assets/backgrounds/bg-subtle-1-dark-800w.jpg');
				--bg-image-subtle-2: url('/assets/backgrounds/bg-subtle-2-dark-800w.jpg');
				--bg-image-footer: url('/assets/backgrounds/bg-footer-dark-800w.jpg');
			}

			@media (min-width: 50em) {
				:root {
					--bg-scale: 1;
					--bg-image-main: url('/assets/backgrounds/bg-main-light-1440w.jpg');
				}
				:root.theme-dark {
					--bg-image-main: url('/assets/backgrounds/bg-main-dark-1440w.jpg');
				}

				:root.loaded {
					--bg-image-subtle-1: url('/assets/backgrounds/bg-subtle-1-light-1440w.jpg');
					--bg-image-subtle-2: url('/assets/backgrounds/bg-subtle-2-light-1440w.jpg');
					--bg-image-footer: url('/assets/backgrounds/bg-footer-light-1440w.jpg');
				}
				:root.loaded.theme-dark {
					--bg-image-subtle-1: url('/assets/backgrounds/bg-subtle-1-dark-1440w.jpg');
					--bg-image-subtle-2: url('/assets/backgrounds/bg-subtle-2-dark-1440w.jpg');
					--bg-image-footer: url('/assets/backgrounds/bg-footer-dark-1440w.jpg');
				}
			}

			.nav-container {
				position: -webkit-sticky;
				position: sticky;
				top: 0;
				z-index: 9999;
				width: 100%;
				transition: background-color var(--theme-transition), backdrop-filter var(--theme-transition), box-shadow var(--theme-transition), padding var(--theme-transition);
				background-color: transparent;
				height: fit-content;
			}

			.nav-container.scrolled {
				background-color: var(--gray-999_40);
				backdrop-filter: blur(10px);
				-webkit-backdrop-filter: blur(10px);
				box-shadow: var(--shadow-sm);
			}

			.backgrounds {
				min-height: 100%;
				isolation: isolate;
				background:
					/*noise*/
					url('/assets/backgrounds/noise.png') top center/220px repeat,
					/*footer*/ var(--bg-image-footer) bottom center/var(--bg-gradient-size) no-repeat,
					/*header1*/ var(--bg-image-main-curves) top center/var(--bg-gradient-size) no-repeat,
					/*header2*/ var(--bg-image-main) top center/var(--bg-gradient-size) no-repeat,
					/*base*/ var(--gray-999);
				background-attachment: scroll;
				background-blend-mode: /*noise*/
					overlay,
					/*footer*/ var(--bg-blend-mode),
					/*header1*/ var(--bg-svg-blend-mode),
					/*header2*/ normal,
					/*base*/ normal;
			}
			@media (min-width: 50em) {
				.backgrounds {
					background-attachment: fixed;
				}
			}
			@media (forced-colors: active) {
				/* Deactivate custom backgrounds for high contrast users. */
				.backgrounds {
					background: none;
					background-blend-mode: normal;
					--bg-gradient-size: none;
				}
			}
		</style>
	</body>
</html>
